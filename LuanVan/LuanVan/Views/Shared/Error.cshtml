@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<h1 class="text-danger">Đã xảy ra lỗi.</h1>
<h2 class="text-danger">Hệ thống gặp sự cố khi xử lý yêu cầu của bạn.</h2>

@if (Model.ShowRequestId)
{
    <p>
        <strong>Mã yêu cầu:</strong> <code>@Model.RequestId</code>
    </p>
}

<h3>Chế độ Development</h3>
<p>
    Khi chuyển sang môi trường <strong>Development</strong>, hệ thống sẽ hiển thị thông tin chi tiết hơn về lỗi.
</p>
<p>
    <strong>Không nên bật môi trường Development trên hệ thống đã triển khai thực tế.</strong>
    Việc này có thể làm lộ thông tin nhạy cảm từ exception cho người dùng cuối.
    Khi cần debug cục bộ, hãy đặt biến môi trường <strong>ASPNETCORE_ENVIRONMENT</strong> thành <strong>Development</strong>
    và khởi động lại ứng dụng.
</p>


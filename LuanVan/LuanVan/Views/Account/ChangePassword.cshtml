@model LuanVan.Models.ChangePasswordViewModel

<section class="page-head">
    <div>
        <h2>Đổi mật khẩu</h2>
    </div>
</section>

 

<section class="panel mt-3" style="max-width: 640px;">
    @if (TempData["AuthSuccess"] is string success)
    {
        <div class="alert alert-success">@success</div>
    }

    <form method="post" asp-action="ChangePassword" asp-controller="Account" novalidate>
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

        <div class="mb-3">
            <label asp-for="CurrentPassword" class="form-label"></label>
            <div class="password-field-wrap">
                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                <button class="password-toggle" type="button" data-target="CurrentPassword" aria-label="Hiện mật khẩu">Hiện</button>
            </div>
            <span asp-validation-for="CurrentPassword" class="field-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="NewPassword" class="form-label"></label>
            <div class="password-field-wrap">
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <button class="password-toggle" type="button" data-target="NewPassword" aria-label="Hiện mật khẩu">Hiện</button>
            </div>
            <span asp-validation-for="NewPassword" class="field-error"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <div class="password-field-wrap">
                <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                <button class="password-toggle" type="button" data-target="ConfirmPassword" aria-label="Hiện mật khẩu">Hiện</button>
            </div>
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-primary" type="submit">Lưu mật khẩu mới</button>
            <a class="btn btn-outline-secondary" asp-controller="Portal" asp-action="Profile">Quay lại hồ sơ</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

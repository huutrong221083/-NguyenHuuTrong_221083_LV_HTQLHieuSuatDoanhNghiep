@model LuanVan.Models.ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
}

<div class="auth-page">
    <div class="auth-panel">
        <div class="auth-brand">
            <span class="logo-badge" aria-hidden="true">
                <svg viewBox="0 0 48 48" role="img" focusable="false">
                    <defs>
                        <linearGradient id="forgotPerfLogoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" stop-color="#2563eb" />
                            <stop offset="100%" stop-color="#0ea5e9" />
                        </linearGradient>
                    </defs>
                    <rect x="5" y="5" width="38" height="38" rx="11" fill="url(#forgotPerfLogoGrad)" />
                    <path d="M15 31h4V21h-4v10zm7 0h4V17h-4v14zm7 0h4V24h-4v7z" fill="#f8fafc" />
                    <path d="M13 34h22" stroke="#bfdbfe" stroke-width="2" stroke-linecap="round" />
                </svg>
            </span>
            <div>
                <h1>Quản lý hiệu suất</h1>
                <p>Khôi phục tài khoản an toàn</p>
            </div>
        </div>

        <section>
            <div class="auth-section-head">
                <h2>Quên mật khẩu</h2>
                <a class="auth-link-btn" asp-controller="Account" asp-action="Login">Quay lại đăng nhập</a>
            </div>

            @if (Model.IsSubmitted)
            {
                <div class="alert alert-success">
                    Liên kết đặt lại mật khẩu đã được gửi đến email của bạn. Vui lòng kiểm tra hộp thư.
                </div>
            }

            <form method="post" asp-action="ForgotPassword" asp-controller="Account" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label"></label>
                    <input asp-for="Email" class="form-control" autocomplete="email" placeholder="example@company.vn" />
                    <span asp-validation-for="Email" class="field-error"></span>
                </div>

                <button class="btn btn-primary w-100" type="submit">Gửi liên kết đặt lại mật khẩu</button>
            </form>
        </section>

        <p class="auth-note">Token đặt lại mật khẩu có thời hạn và chỉ dùng được một lần.</p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

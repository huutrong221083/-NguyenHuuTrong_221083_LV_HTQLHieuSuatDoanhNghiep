@{
    var role = (ViewData["Role"]?.ToString() ?? "Admin").Trim().ToLowerInvariant();
    var canEdit = role == "admin" || role == "manager";
}
<style>
    .kpix-block { border: 1px solid #e6ebf2; border-radius: 12px; padding: 14px; background: #fff; }
    .kpix-block > header { border-bottom: 1px dashed #e6ebf2; padding-bottom: 8px; margin-bottom: 10px; }
    .kpix-section-tag { display: inline-block; font-size: .74rem; font-weight: 600; color: #334155; background: #eef4ff; border: 1px solid #dbe8ff; border-radius: 999px; padding: 2px 9px; margin-bottom: 6px; }
    .kpix-toolbar-wrap { border: 1px solid #e6ebf2; border-radius: 12px; padding: 12px; background: #fff; }
    .kpix-toolbar { display: grid; grid-template-columns: repeat(6, minmax(140px, 1fr)); gap: 8px; align-items: center; }
    .kpix-mini-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 10px; }
    .kpix-mini-grid .panel.mini { margin: 0; border: 1px solid #eef2f7; border-radius: 10px; padding: 10px 12px; box-shadow: none; }
    .kpix-mini-grid .panel.mini h6 { font-size: .8rem; color: #6b7280; margin-bottom: 4px; }
    .kpix-stat { font-size: 1.1rem; font-weight: 700; margin: 0; line-height: 1.2; }
    .table-responsive { max-height: 360px; overflow: auto; }
    .table-responsive thead th { position: sticky; top: 0; z-index: 2; background: #f8fafc; box-shadow: inset 0 -1px 0 #e5e7eb; }
    .kpix-analysis-grid { display: grid; grid-template-columns: 1fr; gap: 12px; }
    .kpix-analysis-item { border: 1px solid #eef2f7; border-radius: 10px; padding: 8px; background: #fff; }
    .kpix-analysis-item canvas { width: 100% !important; height: 300px !important; }
    .kpix-analysis-item.pie canvas { height: 220px !important; }
    .kpix-analysis-item.pie { max-width: 420px; }
    .kpix-ai-box { margin-top: 10px !important; padding: 10px; border-radius: 10px; font-size: .92rem; }
    .kpix-weight-box { margin-top: 10px; border: 1px solid #dbeafe; border-radius: 10px; background: #f8fbff; padding: 10px; }
    .kpix-employee-table-wrap { max-height: 520px; min-height: 520px; }
    .kpix-employee-side {
        min-height: 520px;
        max-height: 520px;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }
    .kpix-employee-detail-wrap {
        flex: 1 1 auto;
        min-height: 0;
        overflow: auto;
        border: 1px dashed #dbe3ef;
        border-radius: 12px;
        padding: 12px;
        background: #fcfdff;
    }
    .kpix-employee-history-wrap {
        flex: 0 0 160px;
        border: 1px solid #e8eef7;
        border-radius: 12px;
        padding: 8px 10px;
        background: #fff;
    }
    .kpix-employee-history-wrap canvas { height: 140px !important; width: 100% !important; }
    #employeeAppliedWeightPanel.kpix-weight-box {
        max-height: 300px;
        overflow: auto;
    }
    .kpix-weight-table th { background: #f1f5f9; font-size: .83rem; }
    .kpix-weight-table td { font-size: .86rem; }
    .kpix-proposal-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: 14px; }
    .kpix-proposal-admin { margin-top: 12px; }
    .kpix-proposal-form {
        border: 1px solid #d8e3f2;
        border-radius: 12px;
        padding: 12px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.05);
    }
    .kpix-proposal-card {
        border: 1px solid #dbe7ff;
        border-radius: 12px;
        background: #fff;
        overflow: hidden;
    }
    .kpix-proposal-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 12px;
        background: #eff6ff;
        border-bottom: 1px solid #dbeafe;
    }
    .kpix-proposal-card-body { padding: 10px 12px; }
    .kpix-proposal-card h6 { margin: 0; font-weight: 700; color: #1e3a8a; }
    .kpix-proposal-sub { font-size: .82rem; color: #64748b; }
    .kpix-proposal-actions { display: flex; gap: 6px; flex-wrap: wrap; }
    .kpix-proposal-meta { font-size: .82rem; color: #64748b; }
    .kpix-proposal-form .form-label { font-size: .83rem; font-weight: 600; color: #334155; margin-bottom: 4px; }
    .kpix-proposal-form .form-control,
    .kpix-proposal-form .form-select { border-color: #cbd5e1; }
    .kpix-proposal-form .form-control:focus,
    .kpix-proposal-form .form-select:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 .2rem rgba(59,130,246,.18);
    }
    .kpix-proposal-table thead th {
        background: #f1f5f9;
        border-bottom: 1px solid #cbd5e1;
        font-weight: 700;
        color: #1e293b;
    }
    .kpix-proposal-table tbody tr:hover { background: #f8fbff; }
    .kpix-proposal-table tbody tr + tr td { border-top: 1px dashed #e2e8f0; }
    @@media (max-width: 1200px) { .kpix-toolbar { grid-template-columns: repeat(4, minmax(120px, 1fr)); } }
    @@media (max-width: 992px) {
        .kpix-toolbar { grid-template-columns: repeat(2, minmax(140px, 1fr)); }
        .kpix-mini-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .kpix-employee-table-wrap { max-height: 420px; min-height: 420px; }
        .kpix-employee-side { min-height: auto; max-height: none; }
        .kpix-employee-detail-wrap { max-height: 420px; }
    }
    @@media (max-width: 992px) { .kpix-analysis-item canvas { height: 260px !important; } .kpix-analysis-item.pie canvas { height: 210px !important; } }
    @@media (max-width: 992px) { .kpix-proposal-grid { grid-template-columns: 1fr; } }
    @@media (max-width: 576px) { .kpix-mini-grid { grid-template-columns: 1fr; } }
</style>



<section class="panel mt-3 kpix-toolbar-wrap">
    <div class="kpix-toolbar">
        <input id="kpiKeyword" class="form-control" placeholder="Tìm theo tên KPI..." />
        <select id="kpiDepartmentFilter" class="form-select"><option value="">Tất cả phòng ban</option></select>
        <select id="kpiTeamFilter" class="form-select"><option value="">Tất cả nhóm</option></select>
        <select id="kpiMonthFilter" class="form-select"></select>
        <select id="kpiYearFilter" class="form-select"></select>
        <select id="kpiTypeFilter" class="form-select"><option value="">Tất cả loại KPI</option></select>
        <select id="kpiLevelFilter" class="form-select">
            <option value="">Tất cả mức KPI</option>
            <option value="xuat-sac">Xuất sắc</option>
            <option value="tot">Tốt</option>
            <option value="trung-binh">Trung bình</option>
            <option value="thap">Thấp</option>
        </select>
        @if (role == "admin" || role == "manager")
        {
            <button id="btnAddKpi" class="btn btn-primary" type="button"><i class="bi bi-plus-circle"></i> @(role == "manager" ? "Đề xuất KPI" : "Thêm KPI")</button>
        }
        <div class="btn-group">
            <button class="btn btn-outline-info dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-eye"></i> Xem trước
            </button>
            <ul class="dropdown-menu">
                <li><button id="btnPreviewExportOverview" class="dropdown-item" type="button">Tổng quan KPI</button></li>
                <li><button id="btnPreviewExportDetail" class="dropdown-item" type="button">Chi tiết KPI áp dụng</button></li>
            </ul>
        </div>
        <div class="btn-group">
            <button class="btn btn-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-file-earmark-arrow-down"></i> Xuất
            </button>
                <ul class="dropdown-menu">
                <li><button id="btnExportOverview" class="dropdown-item text-success" type="button">Xuất Tổng quan KPI</button></li>
                <li><button id="btnExportDetail" class="dropdown-item text-success" type="button">Xuất Chi tiết KPI áp dụng</button></li>
            </ul>
        </div>
    </div>
    <div id="kpiCalcResult" class="small mt-2 text-muted"></div>
</section>

<section class="panel mt-3 kpix-block">
    
    <div class="kpix-mini-grid">
        <article class="panel mini"><h6>KPI TB hệ thống</h6><p id="kpiAvgScore" class="kpix-stat">0</p></article>
        <article class="panel mini"><h6>KPI cao nhất</h6><p id="kpiMaxScore" class="kpix-stat text-success">0</p></article>
        <article class="panel mini"><h6>KPI thấp nhất</h6><p id="kpiMinScore" class="kpix-stat text-danger">0</p></article>
        <article class="panel mini"><h6>% đạt KPI</h6><p id="kpiAchievedRate" class="kpix-stat text-primary">0%</p></article>
    </div>
</section>

<section class="panel mt-3 kpix-block">
    <header class="d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0">KPI nhân viên theo kỳ</h4>
        </div>
        <small class="text-muted">Click vào nhân viên để xem chi tiết KPI</small>
    </header>
    <div class="row g-3 mt-1">
        <div class="col-lg-7">
            <div class="table-responsive kpix-employee-table-wrap">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Phòng ban</th>
                            <th>KPI</th>
                            <th>Hoàn thành</th>
                            <th>Trễ hạn</th>
                        </tr>
                    </thead>
                    <tbody id="kpiEmployeeTableBody">
                        <tr><td colspan="5" class="text-muted">Đang tải dữ liệu KPI nhân viên...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="kpix-employee-side">
                <div id="kpiEmployeeDetailPanel" class="kpix-info-box text-muted kpix-employee-detail-wrap">Chọn một nhân viên để xem chi tiết KPI.</div>
                <div class="kpix-employee-history-wrap">
                    <canvas id="kpiEmployeeHistoryChart" height="140"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="panel mt-3 kpix-block">
    <header class="d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0">KPI nhóm và phòng ban</h4>
        </div>
        <small class="text-muted">Tổng hợp theo tháng và bộ lọc hiện tại</small>
    </header>
    <div class="kpix-mini-grid">
        <article class="panel mini"><h6>KPI TB Nhóm</h6><p id="teamAvgKpi" class="kpix-stat">0</p></article>
        <article class="panel mini"><h6>KPI TB Phòng ban</h6><p id="deptAvgKpi" class="kpix-stat">0</p></article>
        <article class="panel mini"><h6>Nhóm tốt nhất</h6><p id="bestTeamName" class="kpix-stat text-success">-</p></article>
        <article class="panel mini"><h6>Nhóm KPI thấp</h6><p id="lowTeamName" class="kpix-stat text-danger">-</p></article>
    </div>
    <div class="row g-3 mt-1">
        <div class="col-lg-6">
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr><th>Nhóm</th><th>KPI TB</th><th>Thành viên</th></tr>
                    </thead>
                    <tbody id="teamSummaryBody">
                        <tr><td colspan="3" class="text-muted">Đang tải dữ liệu nhóm...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="col-lg-6">
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr><th>Phòng ban</th><th>KPI TB</th><th>Nhân viên</th></tr>
                    </thead>
                    <tbody id="deptSummaryBody">
                        <tr><td colspan="3" class="text-muted">Đang tải dữ liệu phòng ban...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</section>

<section class="kpix-main mt-3">
    <div class="kpix-left">
        <section class="panel kpix-block">
            <header class="d-flex justify-content-between align-items-center">
                <div>
                    <h4 class="mb-0">Danh sách KPI</h4>
                </div>
                <small class="text-muted">tổng trọng số KPI gốc (tham chiếu): <span id="kpiTotalWeight">0</span>%</small>
            </header>
            <div class="table-responsive mt-3">
                <table class="table align-middle kpix-table">
                    <thead>
                        <tr>
                            <th>Tên KPI</th>
                            <th>Mô tả</th>
                            <th>Trọng số gốc</th>
                            <th>Áp dụng</th>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="kpiTableBody">
                        <tr><td colspan="7" class="text-muted">Đang tải danh muc KPI...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <aside class="panel kpix-detail kpix-block" id="kpiDetailPanel">
        <header class="d-flex justify-content-between align-items-center">
            <div>
                <h4 id="kpiDetailTitle" class="mb-0">Chi tiết KPI</h4>
            </div>
            <div class="d-flex gap-2 align-items-center">
                <span id="kpiDetailType"></span>
                @if (canEdit)
                {
                    <button id="btnToggleKpiStatus" class="btn btn-sm btn-outline-warning" type="button"></button>
                }
            </div>
        </header>

        <ul class="nav nav-tabs mt-3" role="tablist">
            <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#kpiTabInfo" type="button">Thông tin</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#kpiTabAssign" type="button">Gán đối tượng</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#kpiTabResult" type="button">Kết quả</button></li>
            <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#kpiTabAnalysis" type="button">Phân tích</button></li>
        </ul>

        <div class="tab-content pt-3">
            <div class="tab-pane fade show active" id="kpiTabInfo">
                <div id="kpiInfoContent" class="kpix-info-box text-muted">Chọn KPI để xem thông tin.</div>
                <div id="kpiWeightValidation" class="small mt-2"></div>
            </div>

            <div class="tab-pane fade" id="kpiTabAssign">
                <div class="kpix-assignment-toolbar mb-2">
                    <select id="assignObjectType" class="form-select form-select-sm">
                        <option value="employee">Nhân viên</option>
                        <option value="team">Nhóm</option>
                        <option value="project">Dự án</option>
                        <option value="department">Phòng ban</option>
                    </select>
                    <select id="assignObjectId" class="form-select form-select-sm"><option value="">Chọn đối tượng</option></select>
                    <input id="assignNote" type="text" class="form-control form-control-sm" placeholder="Ghi chú" />
                    <button id="btnAssignObject" class="btn btn-sm btn-outline-primary" type="button">Thêm</button>
                    <button id="btnSaveAssignments" class="btn btn-sm btn-primary" type="button">Lưu gán KPI</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Đối tượng</th>
                                <th>Loại</th>
                                <th>Ghi chú</th>
                                <th>Trạng thái</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="kpiAssignmentBody">
                            <tr><td colspan="5" class="text-muted">Chưa có dữ liệu gán KPI.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="kpiTabResult">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Nhân viên</th>
                                <th>KPI</th>
                                <th>Điểm</th>
                                <th>Tháng</th>
                                <th>Xếp loại</th>
                            </tr>
                        </thead>
                        <tbody id="kpiResultBody">
                            <tr><td colspan="5" class="text-muted">Chưa có kết quả KPI.</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="tab-pane fade" id="kpiTabAnalysis">
                <div class="kpix-analysis-grid">
                    <div class="kpix-analysis-item"><canvas id="kpiTrendChart"></canvas></div>
                    <div class="kpix-analysis-item"><canvas id="kpiEmployeeChart"></canvas></div>
                </div>
                <div class="kpix-analysis-item pie mt-2"><canvas id="kpiPieChart"></canvas></div>
                <div id="kpiAiInsight" class="kpix-ai-box">Chưa có dữ liệu AI.</div>
            </div>
        </div>
    </aside>
</section>

@if (role == "manager")
{
    <section class="panel mt-3 kpix-block" id="kpiProposalSection">
        <header>
            <span class="kpix-section-tag">6. Quy trình đề xuất KPI</span>
            <h4 class="mb-0">Manager đề xuất, Admin duyệt</h4>
        </header>

        <div class="kpix-proposal-grid">
            <article class="kpix-proposal-card">
                <div class="kpix-proposal-card-header">
                    <h6>1. Tạo / cập nhật đề xuất KPI</h6>
                    <span class="kpix-proposal-sub">Nhập thông tin rồi gửi cho admin duyệt</span>
                </div>
                <div class="kpix-proposal-card-body kpix-proposal-form">
                <div class="row g-2">
                    <div class="col-md-4">
                        <label class="form-label">Loại đề xuất</label>
                        <select id="proposalType" class="form-select form-select-sm">
                            <option value="TaoMoiKPI">Tạo mới KPI</option>
                            <option value="ApDungKPI">Áp dụng KPI</option>
                            <option value="DieuChinhKPI">Điều chỉnh KPI</option>
                            <option value="HuyApDungKPI">Hủy áp dụng KPI</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">KPI hiện có (nếu cần)</label>
                        <select id="proposalKpiId" class="form-select form-select-sm"><option value="">Chọn KPI</option></select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Loại KPI (khi tạo mới)</label>
                        <select id="proposalLoaiKpi" class="form-select form-select-sm"><option value="">Chọn loại KPI</option></select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Tên KPI đề xuất</label>
                        <input id="proposalTenKpi" class="form-control form-control-sm" placeholder="Bắt buộc khi Tạo mới KPI" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Trọng số đề xuất (%)</label>
                        <input id="proposalTrongSo" type="number" min="0" max="100" step="0.01" class="form-control form-control-sm" value="0" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đối tượng áp dụng</label>
                        <select id="proposalTargetType" class="form-select form-select-sm">
                            <option value="employee">Nhân viên</option>
                            <option value="team">Nhóm</option>
                            <option value="department">Phòng ban</option>
                            <option value="project">Dự án</option>
                        </select>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Đối tượng cụ thể</label>
                        <select id="proposalTargetId" class="form-select form-select-sm"><option value="">Chọn đối tượng</option></select>
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Từ ngày</label>
                        <input id="proposalFromDate" type="date" class="form-control form-control-sm" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Đến ngày</label>
                        <input id="proposalToDate" type="date" class="form-control form-control-sm" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Mô tả KPI đề xuất</label>
                        <input id="proposalMoTa" class="form-control form-control-sm" placeholder="Mô tả ngắn KPI mới/điều chỉnh" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Lý do</label>
                        <input id="proposalLyDo" class="form-control form-control-sm" placeholder="Lý do đề xuất" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Ghi chú</label>
                        <input id="proposalGhiChu" class="form-control form-control-sm" placeholder="Ghi chú thêm cho admin" />
                    </div>
                </div>
                <div class="kpix-proposal-actions mt-2">
                    <button id="btnSubmitProposal" class="btn btn-sm btn-primary" type="button">Gửi đề xuất</button>
                    <button id="btnResetProposalForm" class="btn btn-sm btn-outline-secondary" type="button">Làm mới form</button>
                </div>
                <div id="proposalFormHint" class="small mt-2 text-muted">Manager tạo đề xuất, Admin duyệt thì mới áp dụng vào KPI chính thức.</div>
                </div>
            </article>

            <article class="kpix-proposal-card">
                <div class="kpix-proposal-card-header">
                    <h6>2. Đề xuất KPI của tôi</h6>
                    <span class="kpix-proposal-sub">Bấm vào từng dòng để xem phản hồi từ admin</span>
                </div>
                <div class="kpix-proposal-card-body">
                <div class="table-responsive kpix-proposal-table">
                    <table class="table table-sm align-middle mb-0">
                        <thead>
                            <tr><th>Loại đề xuất</th><th>KPI / Đối tượng</th><th>Trạng thái</th><th>Thao tác</th></tr>
                        </thead>
                        <tbody id="proposalMineBody">
                            <tr><td colspan="4" class="text-muted">Đang tải đề xuất...</td></tr>
                        </tbody>
                    </table>
                </div>
                <div id="proposalMineDetailPanel" class="kpix-proposal-form mt-3 text-muted">Chọn một đề xuất để xem chi tiết và phản hồi từ admin.</div>
                </div>
            </article>
        </div>
    </section>
}


        async function loadEmployeeKpiList() {
            const query = new URLSearchParams();
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);
            if (kpiDepartmentFilter.value) query.set('maPhongBan', kpiDepartmentFilter.value);
            if (kpiTeamFilter.value) query.set('maNhom', kpiTeamFilter.value);
            if (kpiLevelFilter.value) query.set('mucKpi', kpiLevelFilter.value);

            const res = await fetchJson(`/kpi/employees?${query.toString()}`);
            if (!res.success || !res.data) {
                kpiEmployeeTableBody.innerHTML = `<tr><td colspan="5" class="text-danger">${escapeHtml(res.message || 'Không tải được KPI nhân viên.')}</td></tr>`;
                return;
            }

            state.employeeKpis = res.data.items || [];
            renderEmployeeKpiRows();
            if (state.employeeKpis.length) {
                await openEmployeeKpiDetail(state.employeeKpis[0].maNhanVien);
            }
        }

        async function openEmployeeKpiDetail(employeeId) {
            if (!employeeId) return;

            const query = new URLSearchParams();
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);

            const res = await fetchJson(`/kpi/employees/${employeeId}/detail?${query.toString()}`);
            if (!res.success || !res.data) {
                kpiEmployeeDetailPanel.innerHTML = `<span class="text-danger">${escapeHtml(res.message || 'Không tải được chi tiết KPI nhân viên.')}</span>`;
                return;
            }

            const d = res.data;
            state.selectedEmployeeDetail = d;
            const appliedRows = d.kpiTrongSoApDung || [];
            const appliedSummary = appliedRows.length
                ? `${appliedRows.length} KPI đang áp dụng`
                : 'Chưa có KPI áp dụng';
            kpiEmployeeDetailPanel.innerHTML = `
                <div><strong>${escapeHtml(d.hoTen || `NV ${d.maNhanVien}`)}</strong></div>
                <div>Phòng ban: ${escapeHtml(d.tenPhongBan || '-')}</div>
                <div>KPI hiện tại: <strong>${Number(d.diemKpiHienTai || 0).toFixed(2)}</strong></div>
                <div>Tổng công việc: ${d.tongCongViec || 0}</div>
                <div>Đúng hạn: ${d.congViecDungHan || 0}</div>
                <div>Trễ hạn: ${d.congViecTreHan || 0}</div>
                <button id="btnToggleAppliedWeightPanel" class="btn btn-sm btn-outline-primary mt-2" type="button">
                    Xem trọng số KPI áp dụng (${appliedSummary})
                </button>
                <div id="employeeAppliedWeightPanel" class="kpix-weight-box d-none">
                    ${renderAppliedWeightPanel(d)}
                </div>
            `;

            const toggleBtn = document.getElementById('btnToggleAppliedWeightPanel');
            const weightPanel = document.getElementById('employeeAppliedWeightPanel');
            if (toggleBtn && weightPanel) {
                toggleBtn.addEventListener('click', () => {
                    const isHidden = weightPanel.classList.contains('d-none');
                    weightPanel.classList.toggle('d-none', !isHidden);
                    toggleBtn.textContent = isHidden
                        ? 'Ẩn trọng số KPI áp dụng'
                        : `Xem trọng số KPI áp dụng (${appliedSummary})`;
                });
            }

            const history = d.kpiTheoThang || [];
            if (state.employeeHistoryChart) state.employeeHistoryChart.destroy();
            state.employeeHistoryChart = new Chart(kpiEmployeeHistoryCanvas, {
                type: 'line',
                data: {
                    labels: history.map(x => `${x.thang}/${x.nam}`),
                    datasets: [{
                        label: 'KPI theo tháng',
                        data: history.map(x => x.diem),
                        borderColor: '#2563EB',
                        backgroundColor: 'rgba(37,99,235,0.15)',
                        fill: true,
                        tension: 0.35
                    }]
                },
                options: {
                    scales: { y: { beginAtZero: true, max: 100 } },
                    plugins: { legend: { display: false } }
                }
            });
        }

        function renderAppliedWeightPanel(detail) {
            const rows = detail.kpiTrongSoApDung || [];
            const scoreRows = detail.kpiDiemChiTiet || [];
            if (!rows.length) {
                return '<div class="text-muted">Nhân viên này chưa có KPI áp dụng trong kỳ đang chọn.</div>';
            }

            const total = rows.reduce((sum, x) => sum + Number(x.trongSoApDung || 0), 0);
            const totalContribution = scoreRows.reduce((sum, x) => sum + Number(x.dongGop || 0), 0);
            return `
                <div class="small mb-2 text-muted">Các KPI và trọng số đang áp dụng của nhân viên trong kỳ.</div>
                <div class="table-responsive">
                    <table class="table table-sm kpix-weight-table align-middle mb-1">
                        <thead>
                            <tr>
                                <th>KPI</th>
                                <th>Loại KPI</th>
                                <th>Trọng số gốc</th>
                                <th>Trọng số áp dụng</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${rows.map(x => `
                                <tr>
                                    <td>${escapeHtml(x.tenKpi || `KPI ${x.maKpi}`)}<div class="small text-muted">#${x.maKpi}</div></td>
                                    <td>${escapeHtml(x.tenLoaiKpi || '-')}</td>
                                    <td>${Number(x.trongSoGoc || 0).toFixed(2)}%</td>
                                    <td><strong>${Number(x.trongSoApDung || 0).toFixed(2)}%</strong></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                <div class="small ${Math.abs(total - 100) < 0.01 ? 'text-success' : 'text-warning'}">
                    Tổng trọng số áp dụng: <strong>${total.toFixed(2)}%</strong>
                </div>
                <hr class="my-2" />
                <div class="small mb-2 text-muted">Giải thích điểm KPI theo từng mục trong kỳ.</div>
                <div class="table-responsive">
                    <table class="table table-sm kpix-weight-table align-middle mb-1">
                        <thead>
                            <tr>
                                <th>KPI</th>
                                <th>Điểm Rule</th>
                                <th>Điểm AI</th>
                                <th>Điểm cuối</th>
                                <th>Trọng số áp dụng</th>
                                <th>Đóng góp</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${(scoreRows.length ? scoreRows : rows.map(x => ({
                                maKpi: x.maKpi,
                                tenKpi: x.tenKpi,
                                ruleScore: 0,
                                aiScore: null,
                                finalScore: 0,
                                trongSoApDung: x.trongSoApDung,
                                dongGop: 0,
                                coSuDungAi: false
                            }))).map(x => `
                                <tr>
                                    <td>${escapeHtml(x.tenKpi || `KPI ${x.maKpi}`)}</td>
                                    <td>${Number(x.ruleScore || 0).toFixed(2)}</td>
                                    <td>${x.aiScore == null ? '-' : Number(x.aiScore).toFixed(2)} ${x.coSuDungAi ? '' : '<span class="small text-muted">(chưa đủ dữ liệu)</span>'}</td>
                                    <td><strong>${Number(x.finalScore || 0).toFixed(2)}</strong></td>
                                    <td>${Number(x.trongSoApDung || 0).toFixed(2)}%</td>
                                    <td><strong>${Number(x.dongGop || 0).toFixed(2)}</strong></td>
                                </tr>
                            `).join('')}
                        </tbody>
                    </table>
                </div>
                <div class="small text-primary">
                    Tổng đóng góp kỳ này: <strong>${totalContribution.toFixed(2)}</strong>
                </div>
            `;
        }

        async function loadTeamSummary() {
            const query = new URLSearchParams();
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);
            if (kpiDepartmentFilter.value) query.set('maPhongBan', kpiDepartmentFilter.value);

            const res = await fetchJson(`/kpi/team-summary?${query.toString()}`);
            if (!res.success || !res.data) {
                teamSummaryBody.innerHTML = `<tr><td colspan="3" class="text-danger">${escapeHtml(res.message || 'Không tải được dữ liệu nhóm.')}</td></tr>`;
                deptSummaryBody.innerHTML = `<tr><td colspan="3" class="text-danger">${escapeHtml(res.message || 'Không tải được dữ liệu phòng ban.')}</td></tr>`;
                return;
            }

            const data = res.data;
            teamAvgKpi.textContent = Number(data.kpiTrungBinhNhom || 0).toFixed(2);
            deptAvgKpi.textContent = Number(data.kpiTrungBinhPhongBan || 0).toFixed(2);
            bestTeamName.textContent = data.nhomTotNhat?.tenNhom || '-';
            lowTeamName.textContent = data.nhomKpiThap?.tenNhom || '-';

            const teams = data.teams || [];
            const depts = data.departments || [];

            teamSummaryBody.innerHTML = teams.length
                ? teams.map(x => `<tr><td>${escapeHtml(x.tenNhom || `Nhóm ${x.maNhom}`)}</td><td>${Number(x.kpiTrungBinh || 0).toFixed(2)}</td><td>${x.soThanhVien || 0}</td></tr>`).join('')
                : '<tr><td colspan="3" class="text-muted">Không có dữ liệu nhóm.</td></tr>';

            deptSummaryBody.innerHTML = depts.length
                ? depts.map(x => `<tr><td>${escapeHtml(x.tenPhongBan || '-')}</td><td>${Number(x.kpiTrungBinh || 0).toFixed(2)}</td><td>${x.soNhanVien || 0}</td></tr>`).join('')
                : '<tr><td colspan="3" class="text-muted">Không có dữ liệu phòng ban.</td></tr>';
        }

        async function openKpiDetail(kpiId) {
            state.selectedKpiId = kpiId;
            const query = new URLSearchParams();
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);

            const res = await fetchJson(`/kpi/catalog/${kpiId}?${query.toString()}`);
            if (!res.success) {
                kpiInfoContent.innerHTML = `<span class="text-danger">${escapeHtml(res.message || 'Không tải được chi tiết KPI')}</span>`;
                return;
            }

            const detail = res.data;
            state.kpiDetail = detail;
            kpiDetailTitle.textContent = detail.tenKpi || `KPI ${kpiId}`;
            kpiDetailType.innerHTML = `<span class="pill info">${escapeHtml(detail.tenLoaiKpi || '-')}</span>`;

            kpiInfoContent.innerHTML = `
                <div class="kpix-info-grid">
                    <div><span class="kpix-label">Tên KPI</span><p>${escapeHtml(detail.tenKpi || '-')}</p></div>
                    <div><span class="kpix-label">Trọng số gốc</span><p>${Number(detail.trongSoGoc || detail.trongSo || 0).toFixed(2)}%</p></div>
                    <div><span class="kpix-label">Loại KPI</span><p>${escapeHtml(detail.tenLoaiKpi || '-')}</p></div>
                    <div><span class="kpix-label">Trạng thái</span><p>${renderStatusPill(detail.trangThai)}</p></div>
                    <div><span class="kpix-label">Thời gian</span><p>tháng ${kpiMonthFilter.value || '--'} / năm ${kpiYearFilter.value || '--'}</p></div>
                    <div class="kpix-span-2"><span class="kpix-label">Mô tả</span><p>${escapeHtml(detail.moTa || '-')}</p></div>
                </div>
            `;

            updateToggleKpiStatusButton(detail.trangThai);

            const totalWeight = state.kpis
                .filter(x => getKpiStatusLabel(x.trangThai) === 'Active')
                .reduce((s, x) => s + Number(x.trongSoGoc || x.trongSo || 0), 0);
            kpiWeightValidation.className = 'small mt-2 text-muted';
            kpiWeightValidation.textContent = `Tổng trọng số KPI gốc đang hoạt động: ${totalWeight.toFixed(2)}% (chỉ là tham chiếu, không cần bằng 100%).`;

            renderAssignmentTab(detail);
            renderResultTab(detail);
            renderAnalysisTab(detail);
        }

        function renderAssignmentTab(detail) {
            const key = detail.maKpi;
            if (!state.assignmentDraft.has(key)) {
                const seed = (detail.assignments || []).map(x => ({
                    objectId: x.objectId,
                    objectName: x.tenDoiTuong,
                    loai: x.loai,
                    loaiCode: x.loaiCode,
                    ghiChu: x.ghiChu,
                    trangThai: x.trangThai
                }));
                state.assignmentDraft.set(key, seed);
            }

            const rows = state.assignmentDraft.get(key) || [];
            if (!rows.length) {
                kpiAssignmentBody.innerHTML = '<tr><td colspan="5" class="text-muted">Chưa có đối tượng gán KPI.</td></tr>';
                return;
            }

            kpiAssignmentBody.innerHTML = rows.map((x, idx) => `
                <tr>
                    <td>${escapeHtml(x.objectName || '-')}<div class="small text-muted">#${escapeHtml(x.objectId ?? '')}</div></td>
                    <td>${escapeHtml(x.loai || '-')}</td>
                    <td>${escapeHtml(x.ghiChu || '-')}</td>
                    <td>${(x.trangThai || 'Active') === 'Active' ? '<span class="pill ok">Active</span>' : '<span class="pill">Inactive</span>'}</td>
                    <td>${canAssign ? `<button class="btn btn-sm btn-outline-danger kpi-assign-delete" data-idx="${idx}" type="button"><i class="bi bi-trash"></i></button>` : ''}</td>
                </tr>
            `).join('');

            document.querySelectorAll('.kpi-assign-delete').forEach(btn => {
                btn.addEventListener('click', () => {
                    const idx = Number(btn.getAttribute('data-idx'));
                    const current = state.assignmentDraft.get(key) || [];
                    current.splice(idx, 1);
                    state.assignmentDraft.set(key, current);
                    renderAssignmentTab(detail);
                });
            });
        }

        function renderResultTab(detail) {
            const rows = detail.results || [];
            if (!rows.length) {
                kpiResultBody.innerHTML = '<tr><td colspan="5" class="text-muted">Chưa có kết quả KPI trong kỳ.</td></tr>';
                return;
            }

            kpiResultBody.innerHTML = rows.map(x => `
                <tr>
                    <td>${escapeHtml(x.hoTen || `NV ${x.maNhanVien}`)}</td>
                    <td>${escapeHtml(detail.tenKpi || '-')}</td>
                    <td>
                        <div class="progress mb-1" style="height:8px"><div class="progress-bar ${x.diem >= 90 ? 'good' : (x.diem >= 70 ? 'info' : (x.diem >= 50 ? 'warn' : 'bad'))}" style="width:${Math.max(0, Math.min(100, x.diem))}%"></div></div>
                        <small>${Number(x.diem || 0).toFixed(2)}</small>
                    </td>
                    <td>${x.thang}/${x.nam}</td>
                    <td>${rankBadge(Number(x.diem || 0))}</td>
                </tr>
            `).join('');
        }

        function renderAnalysisTab(detail) {
            const trendRows = detail.trend || [];
            const resultRows = detail.results || [];

            if (state.trendChart) state.trendChart.destroy();
            state.trendChart = new Chart(document.getElementById('kpiTrendChart'), {
                type: 'line',
                data: {
                    labels: trendRows.map(x => x.label),
                    datasets: [{
                        label: 'KPI theo thời gian',
                        data: trendRows.map(x => x.value),
                        borderColor: '#2563EB',
                        backgroundColor: 'rgba(37,99,235,0.12)',
                        fill: true,
                        tension: 0.35
                    }]
                },
                options: { scales: { y: { beginAtZero: true, max: 100 } }, plugins: { legend: { display: false } } }
            });

            const byEmployee = Object.entries(resultRows.reduce((acc, item) => {
                const name = item.hoTen || `NV ${item.maNhanVien}`;
                if (!acc[name]) acc[name] = [];
                acc[name].push(Number(item.diem || 0));
                return acc;
            }, {})).map(([name, values]) => ({ name, avg: values.reduce((s, v) => s + v, 0) / values.length }));

            if (state.employeeChart) state.employeeChart.destroy();
            state.employeeChart = new Chart(document.getElementById('kpiEmployeeChart'), {
                type: 'bar',
                data: {
                    labels: byEmployee.map(x => x.name),
                    datasets: [{
                        label: 'KPI theo nhân viên',
                        data: byEmployee.map(x => x.avg),
                        backgroundColor: '#0EA5E9'
                    }]
                },
                options: {
                    indexAxis: 'y',
                    scales: { x: { beginAtZero: true, max: 100 } },
                    plugins: { legend: { display: false } }
                }
            });

            const pieData = {
                xuatSac: resultRows.filter(x => x.diem >= 90).length,
                tot: resultRows.filter(x => x.diem >= 70 && x.diem < 90).length,
                trungBinh: resultRows.filter(x => x.diem >= 50 && x.diem < 70).length,
                kem: resultRows.filter(x => x.diem < 50).length
            };

            if (state.pieChart) state.pieChart.destroy();
            state.pieChart = new Chart(document.getElementById('kpiPieChart'), {
                type: 'pie',
                data: {
                    labels: ['Xuất sắc', 'Tốt', 'Trung bình', 'Kém'],
                    datasets: [{
                        data: [pieData.xuatSac, pieData.tot, pieData.trungBinh, pieData.kem],
                        backgroundColor: ['#16A34A', '#2563EB', '#F59E0B', '#DC2626']
                    }]
                },
                options: { plugins: { legend: { position: 'bottom' } } }
            });

            const sorted = [...resultRows].sort((a, b) => a.diem - b.diem);
            const lowest = sorted[0];
            const forecastNext = trendRows.length ? trendRows[trendRows.length - 1].value + 2.5 : 0;
            kpiAiInsight.innerHTML = `
                <div><strong>Dự đoán:</strong> KPI tháng sau ~ ${Math.max(0, Math.min(100, forecastNext)).toFixed(1)}</div>
                <div><strong>Cảnh báo:</strong> ${lowest ? `${escapeHtml(lowest.hoTen || `NV ${lowest.maNhanVien}`)} có xu hướng KPI giảm.` : 'Chưa có dữ liệu cảnh báo.'}</div>
                <div><strong>Gợi ý:</strong> Nên đào tạo kỹ năng liên quan và cân đối lại khối lượng công việc cho nhóm dưới 70 điểm.</div>
            `;
        }

        function bindKpiTableEvents() {
            document.querySelectorAll('.kpi-action-view').forEach(btn => {
                btn.addEventListener('click', () => openKpiDetail(Number(btn.getAttribute('data-kpi-id'))));
            });

            document.querySelectorAll('.kpix-row').forEach(row => {
                row.addEventListener('click', (e) => {
                    if (e.target.closest('button')) return;
                    openKpiDetail(Number(row.getAttribute('data-kpi-id')));
                });
            });

            document.querySelectorAll('.kpi-action-edit').forEach(btn => {
                btn.addEventListener('click', () => openKpiForm(Number(btn.getAttribute('data-kpi-id'))));
            });

            document.querySelectorAll('.kpi-action-toggle').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = Number(btn.getAttribute('data-kpi-id'));
                    await toggleKpiStatus(id);
                });
            });

            document.querySelectorAll('.kpi-action-delete').forEach(btn => {
                btn.addEventListener('click', async () => {
                    const id = Number(btn.getAttribute('data-kpi-id'));
                    if (!confirm('Bạn có chắc muốn xóa KPI này?')) return;
                    const res = await fetchJson(`/kpi/catalog/${id}`, { method: 'DELETE' });
                    if (!res.success) {
                        alert(res.message || 'Không thể xóa KPI.');
                        return;
                    }
                    await loadKpiCatalog();
                });
            });
        }

        function openKpiForm(id) {
            if (!canCreate) return;
            state.editingKpiId = id || null;
            kpiFormResult.textContent = '';
            kpiFormResult.className = 'small mt-2';

            if (!id) {
                kpiFormTitle.textContent = 'Thêm KPI';
                formKpiName.value = '';
                formKpiDesc.value = '';
                formKpiWeight.value = '';
                if (state.kpiTypes.length) formKpiType.value = String(state.kpiTypes[0].maLoaiKpi);
            } else {
                const kpi = state.kpis.find(x => x.maKpi === id);
                if (!kpi) return;
                kpiFormTitle.textContent = 'Sửa KPI';
                formKpiName.value = kpi.tenKpi || '';
                formKpiDesc.value = kpi.moTa || '';
                formKpiWeight.value = Number(kpi.trongSoGoc ?? kpi.trongSo ?? 0).toFixed(2);
                formKpiType.value = String(kpi.maLoaiKpi);
            }

            updateKpiWeightPreview();
            kpiFormModal.show();
        }

        async function toggleKpiStatus(kpiId) {
            if (!canEdit || !kpiId) return;

            const currentStatus = getKpiStatusLabel(state.kpiDetail?.trangThai || state.kpis.find(x => x.maKpi === kpiId)?.trangThai);
            const confirmMessage = currentStatus === 'Active'
                ? 'Bạn có chắc muốn tạm dừng KPI này?'
                : 'Bạn có chắc muốn kích hoạt KPI này?';

            if (!confirm(confirmMessage)) return;

            const res = await fetchJson(`/kpi/catalog/${kpiId}/status/toggle`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' }
            });

            kpiCalcResult.className = `small mt-2 ${res.success ? 'text-success' : 'text-danger'}`;
            kpiCalcResult.textContent = res.message || (res.success ? 'Cập nhật trạng thái KPI thành công.' : 'Không thể cập nhật trạng thái KPI.');

            if (!res.success) return;

            await loadKpiCatalog();
            if (state.selectedKpiId) {
                await openKpiDetail(state.selectedKpiId);
            }
        }

        function updateKpiWeightPreview() {
            const draftWeight = Number(formKpiWeight.value || 0);
            const baseTotal = state.kpis
                .filter(item => !state.editingKpiId || item.maKpi !== state.editingKpiId)
                .reduce((sum, item) => sum + Number(item.trongSo || 0), 0);
            const totalAfterSave = baseTotal + draftWeight;

            if (!formKpiWeightPreview) return;

            if (!draftWeight) {
                formKpiWeightPreview.textContent = 'Nhập trọng số gốc > 0 để lưu KPI.';
                return;
            }

            if (draftWeight > 0 && draftWeight <= 100) {
                formKpiWeightPreview.className = 'small mt-1 text-success';
                formKpiWeightPreview.textContent = `Trọng số gốc nhập: ${draftWeight.toFixed(2)}% | Tổng KPI gốc sau lưu: ${totalAfterSave.toFixed(2)}% (không bắt buộc = 100%).`;
                return;
            }

            formKpiWeightPreview.className = 'small mt-1 text-danger';
            formKpiWeightPreview.textContent = 'Trọng số gốc phải > 0 và <= 100.';
        }

        async function saveKpi() {
            const payload = {
                tenKpi: formKpiName.value.trim(),
                moTa: formKpiDesc.value.trim(),
                trongSoGoc: Number(formKpiWeight.value),
                trongSo: Number(formKpiWeight.value),
                maLoaiKpi: Number(formKpiType.value),
                thang: Number(formKpiMonth.value),
                nam: Number(formKpiYear.value)
            };

            if (!payload.tenKpi) {
                kpiFormResult.className = 'small mt-2 text-danger';
                kpiFormResult.textContent = 'Tên KPI là bắt buộc.';
                return;
            }
            if (!(payload.trongSoGoc > 0 && payload.trongSoGoc <= 100)) {
                kpiFormResult.className = 'small mt-2 text-danger';
                kpiFormResult.textContent = 'Trọng số KPI gốc phải > 0 và <= 100.';
                return;
            }

            const isEdit = !!state.editingKpiId;
            const url = isEdit ? `/kpi/catalog/${state.editingKpiId}` : '/kpi/catalog';
            const method = isEdit ? 'PUT' : 'POST';

            const res = await fetchJson(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            kpiFormResult.className = `small mt-2 ${res.success ? 'text-success' : 'text-danger'}`;
            kpiFormResult.textContent = res.message;
            if (!res.success) return;

            kpiFormModal.hide();
            await loadKpiCatalog();
        }

        function addAssignmentDraft() {
            if (!canAssign || !state.kpiDetail) return;
            if (!assignObjectId.value) return;

            const key = state.kpiDetail.maKpi;
            const rows = state.assignmentDraft.get(key) || [];
            const selectedText = assignObjectId.options[assignObjectId.selectedIndex]?.text || '';
            rows.push({
                objectId: Number(assignObjectId.value),
                objectName: selectedText,
                loai: assignObjectType.value === 'department' ? 'Phòng ban' : (assignObjectType.value === 'team' ? 'Nhóm' : (assignObjectType.value === 'project' ? 'Dự án' : 'Nhân viên')),
                loaiCode: assignObjectType.value,
                ghiChu: assignNote.value.trim(),
                trangThai: 'Active'
            });
            state.assignmentDraft.set(key, rows);
            renderAssignmentTab(state.kpiDetail);
        }

        async function saveAssignments() {
            if (!canAssign || !state.kpiDetail) return;

            const key = state.kpiDetail.maKpi;
            const rows = state.assignmentDraft.get(key) || [];
            const payload = rows.map(item => ({
                loaiCode: item.loaiCode,
                objectId: Number(item.objectId || 0),
                ghiChu: item.ghiChu || null,
                trangThai: item.trangThai === 'Inactive' ? 0 : 1
            }));

            kpiCalcResult.className = 'small mt-2 text-muted';
            kpiCalcResult.textContent = 'Đang lưu gán KPI...';

            const res = await fetchJson(`/kpi/catalog/${key}/assignments/sync`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            kpiCalcResult.className = `small mt-2 ${res.success ? 'text-success' : 'text-danger'}`;
            kpiCalcResult.textContent = res.message || (res.success ? 'Lưu gán KPI thành công.' : 'Không thể lưu gán KPI.');

            if (res.success) {
                await loadKpiCatalog();
            }
        }

        function buildExportQuery(type = 'overview') {
            const query = new URLSearchParams();
            if (kpiKeyword.value.trim()) query.set('keyword', kpiKeyword.value.trim());
            if (kpiTypeFilter.value) query.set('maLoaiKpi', kpiTypeFilter.value);
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);
            query.set('type', type);
            query.set('roleScope', role);
            return query;
        }

        function downloadExportBlob(blob, filename) {
            const objectUrl = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = objectUrl;
            a.download = filename || 'kpi-manager-scope.csv';
            a.click();
            URL.revokeObjectURL(objectUrl);
        }

        function parseSemicolonCsv(csvText) {
            const rows = [];
            let row = [];
            let cell = '';
            let inQuotes = false;

            for (let i = 0; i < csvText.length; i++) {
                const ch = csvText[i];
                const next = csvText[i + 1];

                if (inQuotes) {
                    if (ch === '"' && next === '"') {
                        cell += '"';
                        i++;
                    } else if (ch === '"') {
                        inQuotes = false;
                    } else {
                        cell += ch;
                    }
                    continue;
                }

                if (ch === '"') {
                    inQuotes = true;
                    continue;
                }

                if (ch === ';') {
                    row.push(cell);
                    cell = '';
                    continue;
                }

                if (ch === '\r') continue;
                if (ch === '\n') {
                    row.push(cell);
                    rows.push(row);
                    row = [];
                    cell = '';
                    continue;
                }

                cell += ch;
            }

            if (cell.length > 0 || row.length > 0) {
                row.push(cell);
                rows.push(row);
            }

            return rows.filter(r => r.some(c => String(c || '').trim() !== ''));
        }

        async function exportCsv(type = 'overview') {
            const query = buildExportQuery(type);
            const url = `/kpi/export?${query.toString()}`;
            kpiCalcResult.className = 'small mt-2 text-muted';
            kpiCalcResult.textContent = `Đang chuẩn bị file xuất ${type === 'detail' ? 'chi tiết' : 'tổng quan'}...`;

            try {
                const response = await fetch(url);
                if (!response.ok) {
                    const raw = await response.text();
                    throw new Error(raw || `HTTP ${response.status}`);
                }

                const blob = await response.blob();
                const disposition = response.headers.get('content-disposition') || '';
                const match = disposition.match(/filename=\"?([^\";]+)\"?/i);
                const filename = match?.[1] || (type === 'detail' ? 'kpi-detail.csv' : 'kpi-overview.csv');
                downloadExportBlob(blob, filename);

                kpiCalcResult.className = 'small mt-2 text-success';
                kpiCalcResult.textContent = 'Xuất file thành công.';
            } catch (error) {
                console.error(error);
                kpiCalcResult.className = 'small mt-2 text-danger';
                kpiCalcResult.textContent = 'Không thể xuất file KPI.';
            }
        }

        async function previewExportCsv(type = 'overview') {
            const query = buildExportQuery(type);
            const url = `/kpi/export?${query.toString()}`;
            kpiCalcResult.className = 'small mt-2 text-muted';
            kpiCalcResult.textContent = `Đang tải dữ liệu xem trước ${type === 'detail' ? 'chi tiết' : 'tổng quan'}...`;

            try {
                const response = await fetch(url);
                if (!response.ok) {
                    const raw = await response.text();
                    throw new Error(raw || `HTTP ${response.status}`);
                }

                const blob = await response.blob();
                const disposition = response.headers.get('content-disposition') || '';
                const match = disposition.match(/filename=\"?([^\";]+)\"?/i);
                exportPreviewFilename = match?.[1] || (type === 'detail' ? 'kpi-detail.csv' : 'kpi-overview.csv');
                exportPreviewBlob = blob;

                const contentText = await blob.text();
                const matrix = parseSemicolonCsv(contentText);
                if (!matrix.length) {
                    kpiExportPreviewHead.innerHTML = '';
                    kpiExportPreviewBody.innerHTML = '<tr><td class="text-muted">Không có dữ liệu xem trước.</td></tr>';
                } else {
                    let headerIndex = 0;
                    if (type === 'overview') {
                        headerIndex = matrix.findIndex(r => (r?.[0] || '').trim() === 'MaKPI');
                        if (headerIndex < 0) headerIndex = 0;
                    }
                    const headers = matrix[headerIndex];
                    const rowLimit = type === 'detail' ? 50 : 30;
                    const rows = matrix.slice(headerIndex + 1, headerIndex + 1 + rowLimit);
                    kpiExportPreviewHead.innerHTML = `<tr>${headers.map(h => `<th>${escapeHtml(h)}</th>`).join('')}</tr>`;
                    kpiExportPreviewBody.innerHTML = rows.length
                        ? rows.map(r => `<tr>${headers.map((_, idx) => `<td>${escapeHtml(r[idx] ?? '')}</td>`).join('')}</tr>`).join('')
                        : `<tr><td colspan="${headers.length}" class="text-muted">Không có dòng dữ liệu.</td></tr>`;
                }
                const showNote = type === 'detail' ? ' | Đang hiển thị 50 dòng đầu tiên.' : '';
                kpiExportPreviewMeta.textContent = `Tổng số dòng dữ liệu: ${Math.max(0, matrix.length - 1)} | Tệp: ${exportPreviewFilename}${showNote}`;

                kpiExportPreviewModal.show();
                kpiCalcResult.className = 'small mt-2 text-success';
                kpiCalcResult.textContent = 'Đã tải dữ liệu xem trước.';
            } catch (error) {
                console.error(error);
                kpiCalcResult.className = 'small mt-2 text-danger';
                kpiCalcResult.textContent = 'Không thể xem trước dữ liệu xuất.';
            }
        }

        let autoKpiTimer = null;
        let autoKpiRunning = false;
        let kpiAlertSyncRunning = false;
        let exportPreviewBlob = null;
        let exportPreviewFilename = 'kpi-overview.csv';

        async function runKpiCalculation(skipReload = false) {
            if (!state.kpis.length) {
                kpiCalcResult.className = 'small mt-2 text-danger';
                kpiCalcResult.textContent = 'Không có KPI nào để tính.';
                return;
            }

            const payload = {
                thang: kpiMonthFilter.value ? Number(kpiMonthFilter.value) : new Date().getMonth() + 1,
                nam: kpiYearFilter.value ? Number(kpiYearFilter.value) : new Date().getFullYear()
            };

            kpiCalcResult.className = 'small mt-2 text-muted';
            kpiCalcResult.textContent = 'Đang tính tất cả KPI...';

            const result = await fetchJson('/api/kpi/calculate-all', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!result.success) {
                kpiCalcResult.className = 'small mt-2 text-danger';
                kpiCalcResult.textContent = result.message || 'Không thể tính KPI.';
                return;
            }

            kpiCalcResult.className = 'small mt-2 text-success';
            kpiCalcResult.textContent = `Tính tất cả KPI thành công: ${result.data?.tongKPI || 0} KPI, ${result.data?.soBanGhiCapNhat || 0} bản ghi cập nhật, ${result.data?.soBanGhiTaoMoi || 0} bản ghi mới.`;
            if (!skipReload) {
                await loadKpiCatalog();
            }
        }

        async function autoRefreshKpiData() {
            await loadKpiCatalog();
            await syncKpiAlertsIfNeeded();
            if (!canAssign || autoKpiRunning) return;

            autoKpiRunning = true;
            try {
                await runKpiCalculation(true);
            } finally {
                autoKpiRunning = false;
            }
        }

        async function syncKpiAlertsIfNeeded() {
            if (kpiAlertSyncRunning) return;
            if (!(role === 'manager' || role === 'admin')) return;

            kpiAlertSyncRunning = true;
            try {
                const query = new URLSearchParams();
                if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
                if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);
                await fetchJson(`/thongbao/kpi-alerts/sync?${query.toString()}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
            } finally {
                kpiAlertSyncRunning = false;
            }
        }

        function startAutoKpiRefresh() {
            if (autoKpiTimer) {
                clearInterval(autoKpiTimer);
            }

            if (!canAssign) {
                return;
            }

            autoKpiTimer = setInterval(() => {
                if (document.visibilityState === 'visible') {
                    autoRefreshKpiData();
                }
            }, 60000);

            document.addEventListener('visibilitychange', () => {
                if (document.visibilityState === 'visible') {
                    autoRefreshKpiData();
                }
            });
        }

        assignObjectType.addEventListener('change', refillAssignmentObject);
        btnAssignObject.addEventListener('click', addAssignmentDraft);
        btnSaveAssignments.addEventListener('click', saveAssignments);

        if (proposalTargetType) proposalTargetType.addEventListener('change', refillProposalTargetOptions);
        if (proposalType) proposalType.addEventListener('change', syncProposalFormByType);
        if (btnSubmitProposal) btnSubmitProposal.addEventListener('click', submitProposal);
        if (btnResetProposalForm) btnResetProposalForm.addEventListener('click', resetProposalForm);

        kpiKeyword.addEventListener('input', () => autoRefreshKpiData());
        kpiDepartmentFilter.addEventListener('change', async () => {
            await refreshTeamFilterOptions();
            await autoRefreshKpiData();
        });
        kpiTeamFilter.addEventListener('change', autoRefreshKpiData);
        kpiMonthFilter.addEventListener('change', autoRefreshKpiData);
        kpiYearFilter.addEventListener('change', autoRefreshKpiData);
        kpiTypeFilter.addEventListener('change', autoRefreshKpiData);
        kpiLevelFilter.addEventListener('change', autoRefreshKpiData);

        formKpiWeight.addEventListener('input', updateKpiWeightPreview);
        formKpiWeight.addEventListener('change', updateKpiWeightPreview);

        if (btnAddKpi) btnAddKpi.addEventListener('click', () => {
            if (isManager && document.getElementById('kpiProposalSection')) {
                document.getElementById('kpiProposalSection').scrollIntoView({ behavior: 'smooth', block: 'start' });
                return;
            }
            openKpiForm();
        });
        if (btnPreviewExportOverview) btnPreviewExportOverview.addEventListener('click', () => previewExportCsv('overview'));
        if (btnPreviewExportDetail) btnPreviewExportDetail.addEventListener('click', () => previewExportCsv('detail'));
        if (btnToggleKpiStatus) btnToggleKpiStatus.addEventListener('click', () => toggleKpiStatus(state.selectedKpiId));
        btnSaveKpi.addEventListener('click', saveKpi);
        if (btnExportOverview) btnExportOverview.addEventListener('click', () => exportCsv('overview'));
        if (btnExportDetail) btnExportDetail.addEventListener('click', () => exportCsv('detail'));
        if (btnExportFromPreview) {
            btnExportFromPreview.addEventListener('click', () => {
                if (!exportPreviewBlob) return;
                downloadExportBlob(exportPreviewBlob, exportPreviewFilename);
                kpiExportPreviewModal.hide();
            });
        }

        (async function init() {
            initDateFilters();
            await loadReferences();
            await autoRefreshKpiData();
            if (proposalFromDate) proposalFromDate.value = new Date().toISOString().slice(0, 10);
            resetProposalForm();
            await loadProposalData();
            startAutoKpiRefresh();
        })();
    </script>
}







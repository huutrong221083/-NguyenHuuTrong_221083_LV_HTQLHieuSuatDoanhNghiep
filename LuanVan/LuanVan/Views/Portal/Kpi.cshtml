        async function loadProposalData() {
            if (!(isManager || isAdmin)) return;

            if (proposalMineBody) {
                const mineRes = await fetchJson('/kpi/proposals');
                if (!mineRes.success) {
                    proposalMineBody.innerHTML = `<tr><td colspan="4" class="text-danger">${escapeHtml(mineRes.message || 'Không tải được danh sách đề xuất.')}</td></tr>`;
                    state.proposalMine = [];
                    if (proposalMineDetailPanel) {
                        proposalMineDetailPanel.className = 'kpix-proposal-form mt-3 text-danger';
                        proposalMineDetailPanel.textContent = mineRes.message || 'Không tải được chi tiết đề xuất của bạn.';
                    }
                } else {
                    state.proposalMine = mineRes.data || [];
                    renderMyProposals();
                }
            }

            if (isAdmin && proposalPendingBody) {
                const pendingRes = await fetchJson('/kpi/proposals/pending');
                if (!pendingRes.success) {
                    proposalPendingBody.innerHTML = `<tr><td colspan="5" class="text-danger">${escapeHtml(pendingRes.message || 'Không tải được danh sách chờ duyệt.')}</td></tr>`;
                    state.proposalPending = [];
                    if (proposalPendingDetailPanel) {
                        proposalPendingDetailPanel.className = 'kpix-proposal-form mt-3 text-danger';
                        proposalPendingDetailPanel.textContent = pendingRes.message || 'Không tải được chi tiết đề xuất chờ duyệt.';
                    }
                } else {
                    state.proposalPending = pendingRes.data || [];
                    renderPendingProposals();
                }
            }
        }

        async function submitProposal() {
            if (!(isManager || isAdmin)) return;
            const draft = buildProposalPayload();
            if (!draft.ok) {
                proposalFormHint.className = 'small mt-2 text-danger';
                proposalFormHint.textContent = draft.message;
                return;
            }

            const isEditing = !!state.proposalEditingId;
            const url = isEditing ? `/kpi/proposals/${state.proposalEditingId}` : '/kpi/proposals';
            const method = isEditing ? 'PUT' : 'POST';

            proposalFormHint.className = 'small mt-2 text-muted';
            proposalFormHint.textContent = isEditing ? 'Đang cập nhật đề xuất...' : 'Đang gửi đề xuất...';

            const res = await fetchJson(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(draft.payload)
            });

            proposalFormHint.className = `small mt-2 ${res.success ? 'text-success' : 'text-danger'}`;
            proposalFormHint.textContent = res.message || (res.success ? 'Gửi đề xuất thành công.' : 'Không thể gửi đề xuất.');

            if (!res.success) return;

            resetProposalForm();
            await loadProposalData();
        }

        async function reviewProposal(id, action, phanHoiAdmin) {
            if (!isAdmin) return false;

            const res = await fetchJson(`/kpi/proposals/${id}/review`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    action,
                    phanHoiAdmin: (phanHoiAdmin || '').trim() || null
                })
            });

            kpiCalcResult.className = `small mt-2 ${res.success ? 'text-success' : 'text-danger'}`;
            kpiCalcResult.textContent = res.message || (res.success ? 'Xử lý duyệt đề xuất thành công.' : 'Không thể xử lý đề xuất.');
            return !!res.success;
        }

        async function loadKpiCatalog() {
            kpiTableBody.innerHTML = '<tr><td colspan="7" class="text-muted">Đang tải danh muc KPI...</td></tr>';

            const query = new URLSearchParams({ page: '1', size: '200' });
            if (kpiKeyword.value.trim()) query.set('keyword', kpiKeyword.value.trim());
            if (kpiTypeFilter.value) query.set('maLoaiKpi', kpiTypeFilter.value);
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);

            const res = await fetchJson(`/kpi/catalog?${query.toString()}`);
            if (!res.success) {
                kpiTableBody.innerHTML = `<tr><td colspan="7" class="text-danger">${escapeHtml(res.message || 'Không tải được danh mục KPI')}</td></tr>`;
                return;
            }

            const data = res.data || {};
            state.kpis = data.items || [];
            fillProposalReferenceOptions();

            if (kpiDepartmentFilter.value) {
                const pbId = Number(kpiDepartmentFilter.value);
                const byDepartment = await Promise.all(state.kpis.map(async item => {
                    const q = new URLSearchParams();
                    if (kpiMonthFilter.value) q.set('thang', kpiMonthFilter.value);
                    if (kpiYearFilter.value) q.set('nam', kpiYearFilter.value);
                    q.set('maKpi', item.maKpi);
                    const pbRes = await fetchJson(`/kpi/phongban/${pbId}?${q.toString()}`);
                    return { item, ok: pbRes.success && (pbRes.data?.nhanViens || []).length > 0 };
                }));
                state.kpis = byDepartment.filter(x => x.ok).map(x => x.item);
            }

            kpiTotalWeight.textContent = Number(data.tongTrongSo || 0).toFixed(2);
            renderKpiTable();
            renderMiniDashboard();
            await loadDashboardSummary();
            await loadEmployeeKpiList();
            await loadTeamSummary();

            if (state.kpis.length) {
                await openKpiDetail(state.kpis[0].maKpi);
            }
        }

        function renderKpiTable() {
            if (!state.kpis.length) {
                kpiTableBody.innerHTML = '<tr><td colspan="7" class="text-muted">Không có KPI phù hợp bộ lọc.</td></tr>';
                return;
            }

            const monthLabel = kpiMonthFilter.value ? `tháng ${kpiMonthFilter.value}` : 'Tất cả tháng';
            const yearLabel = kpiYearFilter.value ? `năm ${kpiYearFilter.value}` : 'Tất cả năm';

            kpiTableBody.innerHTML = state.kpis.map(kpi => `
                <tr class="kpix-row" data-kpi-id="${kpi.maKpi}" title="Click để xem chi tiết KPI">
                    <td><i class="bi bi-bullseye text-primary"></i> ${escapeHtml(kpi.tenKpi || `KPI ${kpi.maKpi}`)}</td>
                    <td>${escapeHtml(kpi.moTa || '-')}</td>
                    <td><strong>${Number(kpi.trongSoGoc || kpi.trongSo || 0).toFixed(2)}%</strong></td>
                    <td>${escapeHtml(kpi.apDung || '-')}</td>
                    <td>${monthLabel} / ${yearLabel}</td>
                    <td>${renderStatusPill(kpi.trangThai)}</td>
                    <td>
                        <div class="d-flex gap-1">
                            <button class="btn btn-sm btn-light kpi-action-view" data-kpi-id="${kpi.maKpi}" type="button"><i class="bi bi-eye"></i></button>
                            ${canEdit ? `<button class="btn btn-sm ${getKpiStatusLabel(kpi.trangThai) === 'Active' ? 'btn-outline-warning' : 'btn-outline-success'} kpi-action-toggle" data-kpi-id="${kpi.maKpi}" data-kpi-status="${escapeHtml(kpi.trangThai || 'Active')}" type="button" title="${getKpiStatusLabel(kpi.trangThai) === 'Active' ? 'Tạm dừng' : 'Kích hoạt'}"><i class="bi ${getKpiStatusLabel(kpi.trangThai) === 'Active' ? 'bi-pause' : 'bi-play'}"></i></button>` : ''}
                            ${canEdit ? `<button class="btn btn-sm btn-outline-primary kpi-action-edit" data-kpi-id="${kpi.maKpi}" type="button"><i class="bi bi-pencil"></i></button>` : ''}
                            ${canDelete ? `<button class="btn btn-sm btn-outline-danger kpi-action-delete" data-kpi-id="${kpi.maKpi}" type="button"><i class="bi bi-trash"></i></button>` : ''}
                        </div>
                    </td>
                </tr>
            `).join('');

            bindKpiTableEvents();
        }

        function renderMiniDashboard() {
            const rows = state.kpis;
            if (!rows.length) {
                kpiAvgScore.textContent = '0';
                kpiMaxScore.textContent = '0';
                kpiMinScore.textContent = '0';
                kpiAchievedRate.textContent = '0%';
                return;
            }

            const scores = rows.map(x => Number(x.diemTrungBinh || 0));
            const avg = scores.reduce((s, x) => s + x, 0) / scores.length;
            const max = Math.max(...scores);
            const min = Math.min(...scores);
            const achieved = rows.filter(x => Number(x.diemTrungBinh || 0) >= 70).length;

            kpiAvgScore.textContent = avg.toFixed(2);
            kpiMaxScore.textContent = max.toFixed(2);
            kpiMinScore.textContent = min.toFixed(2);
            kpiAchievedRate.textContent = `${((achieved / rows.length) * 100).toFixed(1)}%`;
        }

        async function loadDashboardSummary() {
            const query = new URLSearchParams();
            if (kpiMonthFilter.value) query.set('thang', kpiMonthFilter.value);
            if (kpiYearFilter.value) query.set('nam', kpiYearFilter.value);
            if (kpiDepartmentFilter.value) query.set('maPhongBan', kpiDepartmentFilter.value);
            if (kpiTeamFilter.value) query.set('maNhom', kpiTeamFilter.value);

            const res = await fetchJson(`/kpi/dashboard-summary?${query.toString()}`);
            if (!res.success || !res.data) return;

            const data = res.data;
            kpiAvgScore.textContent = Number(data.kpiTrungBinh || 0).toFixed(1);
            kpiAchievedRate.textContent = `${data.soNhanVienDatKpi || 0} đạt KPI`;
            kpiMaxScore.textContent = `${data.soCongViecDungHan || 0} đúng hạn`;
            kpiMinScore.textContent = `${data.soCongViecTreHan || 0} trễ hạn`;
        }

        function renderEmployeeKpiRows() {
            if (!state.employeeKpis.length) {
                kpiEmployeeTableBody.innerHTML = '<tr><td colspan="5" class="text-muted">Không có dữ liệu KPI nhân viên theo bộ lọc.</td></tr>';
                return;
            }

            kpiEmployeeTableBody.innerHTML = state.employeeKpis.map(x => `
                <tr class="kpi-emp-row" data-emp-id="${x.maNhanVien}" style="cursor:pointer">
                    <td>${escapeHtml(x.hoTen || `NV ${x.maNhanVien}`)}</td>
                    <td>${escapeHtml(x.tenPhongBan || '-')}</td>
                    <td>${Number(x.diemKpi || 0).toFixed(2)}</td>
                    <td>${x.congViecHoanThanh || 0}/${x.tongCongViec || 0}</td>
                    <td>${x.congViecTreHan || 0}</td>
                </tr>
            `).join('');

            document.querySelectorAll('.kpi-emp-row').forEach(row => {
                row.addEventListener('click', () => {
                    const id = Number(row.getAttribute('data-emp-id'));
                    openEmployeeKpiDetail(id);
                });
            });

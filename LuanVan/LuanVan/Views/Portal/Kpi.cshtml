@section Scripts {
    <script>
        const role = '@role';
        const isManager = role === 'manager';
        const isAdmin = role === 'admin';
        const canCreate = role === 'admin' || role === 'manager';
        const canEdit = role === 'admin' || role === 'manager';
        const canDelete = role === 'admin' || role === 'manager';
        const canAssign = role === 'admin' || role === 'manager';

        const kpiKeyword = document.getElementById('kpiKeyword');
        const kpiDepartmentFilter = document.getElementById('kpiDepartmentFilter');
        const kpiTeamFilter = document.getElementById('kpiTeamFilter');
        const kpiMonthFilter = document.getElementById('kpiMonthFilter');
        const kpiYearFilter = document.getElementById('kpiYearFilter');
        const kpiTypeFilter = document.getElementById('kpiTypeFilter');
        const kpiLevelFilter = document.getElementById('kpiLevelFilter');
        const btnAddKpi = document.getElementById('btnAddKpi');
        const btnPreviewExportOverview = document.getElementById('btnPreviewExportOverview');
        const btnPreviewExportDetail = document.getElementById('btnPreviewExportDetail');
        const btnExportOverview = document.getElementById('btnExportOverview');
        const btnExportDetail = document.getElementById('btnExportDetail');
        const kpiCalcResult = document.getElementById('kpiCalcResult');
        const btnExportFromPreview = document.getElementById('btnExportFromPreview');
        const kpiExportPreviewMeta = document.getElementById('kpiExportPreviewMeta');
        const kpiExportPreviewHead = document.getElementById('kpiExportPreviewHead');
        const kpiExportPreviewBody = document.getElementById('kpiExportPreviewBody');

        const kpiTableBody = document.getElementById('kpiTableBody');
        const kpiTotalWeight = document.getElementById('kpiTotalWeight');

        const kpiAvgScore = document.getElementById('kpiAvgScore');
        const kpiMaxScore = document.getElementById('kpiMaxScore');
        const kpiMinScore = document.getElementById('kpiMinScore');
        const kpiAchievedRate = document.getElementById('kpiAchievedRate');
        const kpiEmployeeTableBody = document.getElementById('kpiEmployeeTableBody');
        const kpiEmployeeDetailPanel = document.getElementById('kpiEmployeeDetailPanel');
        const kpiEmployeeHistoryCanvas = document.getElementById('kpiEmployeeHistoryChart');
        const teamAvgKpi = document.getElementById('teamAvgKpi');
        const deptAvgKpi = document.getElementById('deptAvgKpi');
        const bestTeamName = document.getElementById('bestTeamName');
        const lowTeamName = document.getElementById('lowTeamName');
        const teamSummaryBody = document.getElementById('teamSummaryBody');
        const deptSummaryBody = document.getElementById('deptSummaryBody');

        const kpiDetailTitle = document.getElementById('kpiDetailTitle');
        const kpiDetailType = document.getElementById('kpiDetailType');
        const btnToggleKpiStatus = document.getElementById('btnToggleKpiStatus');
        const kpiInfoContent = document.getElementById('kpiInfoContent');
        const kpiWeightValidation = document.getElementById('kpiWeightValidation');

        const assignObjectType = document.getElementById('assignObjectType');
        const assignObjectId = document.getElementById('assignObjectId');
        const assignNote = document.getElementById('assignNote');
        const btnAssignObject = document.getElementById('btnAssignObject');
        const btnSaveAssignments = document.getElementById('btnSaveAssignments');
        const kpiAssignmentBody = document.getElementById('kpiAssignmentBody');
        const kpiResultBody = document.getElementById('kpiResultBody');
        const kpiAiInsight = document.getElementById('kpiAiInsight');

        const kpiFormModal = new bootstrap.Modal(document.getElementById('kpiFormModal'));
        const kpiExportPreviewModal = new bootstrap.Modal(document.getElementById('kpiExportPreviewModal'));
        const kpiFormTitle = document.getElementById('kpiFormTitle');
        const formKpiName = document.getElementById('formKpiName');
        const formKpiDesc = document.getElementById('formKpiDesc');
        const formKpiWeight = document.getElementById('formKpiWeight');
        const formKpiType = document.getElementById('formKpiType');
        const formKpiMonth = document.getElementById('formKpiMonth');
        const formKpiYear = document.getElementById('formKpiYear');
        const kpiFormResult = document.getElementById('kpiFormResult');
        const formKpiWeightPreview = document.getElementById('formKpiWeightPreview');
        const btnSaveKpi = document.getElementById('btnSaveKpi');

        const proposalType = document.getElementById('proposalType');
        const proposalKpiId = document.getElementById('proposalKpiId');
        const proposalLoaiKpi = document.getElementById('proposalLoaiKpi');
        const proposalTenKpi = document.getElementById('proposalTenKpi');
        const proposalTrongSo = document.getElementById('proposalTrongSo');
        const proposalTargetType = document.getElementById('proposalTargetType');
        const proposalTargetId = document.getElementById('proposalTargetId');
        const proposalFromDate = document.getElementById('proposalFromDate');
        const proposalToDate = document.getElementById('proposalToDate');
        const proposalMoTa = document.getElementById('proposalMoTa');
        const proposalLyDo = document.getElementById('proposalLyDo');
        const proposalGhiChu = document.getElementById('proposalGhiChu');
        const btnSubmitProposal = document.getElementById('btnSubmitProposal');
        const btnResetProposalForm = document.getElementById('btnResetProposalForm');
        const proposalFormHint = document.getElementById('proposalFormHint');
        const proposalMineBody = document.getElementById('proposalMineBody');
        const proposalMineDetailPanel = document.getElementById('proposalMineDetailPanel');
        const proposalPendingBody = document.getElementById('proposalPendingBody');
        const proposalPendingDetailPanel = document.getElementById('proposalPendingDetailPanel');

        const state = {
            kpis: [],
            selectedKpiId: null,
            editingKpiId: null,
            kpiDetail: null,
            kpiTypes: [],
            departments: [],
            teams: [],
            projects: [],
            employees: [],
            filteredTeams: [],
            scope: null,
            assignmentDraft: new Map(),
            trendChart: null,
            employeeChart: null,
            pieChart: null,
            employeeHistoryChart: null,
            employeeKpis: [],
            proposalEditingId: null,
            proposalMine: [],
            proposalPending: []
        };

        const escapeHtml = (value) => String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const getKpiStatusLabel = (status) => (status || 'Active') === 'Active' ? 'Active' : 'Inactive';

        const renderStatusPill = (status) => getKpiStatusLabel(status) === 'Active'
            ? '<span class="pill ok">Active</span>'
            : '<span class="pill">Inactive</span>';

        function updateToggleKpiStatusButton(status) {
            if (!btnToggleKpiStatus) return;

            const isActive = getKpiStatusLabel(status) === 'Active';
            btnToggleKpiStatus.className = isActive ? 'btn btn-sm btn-outline-warning' : 'btn btn-sm btn-outline-success';
            btnToggleKpiStatus.innerHTML = isActive
                ? '<i class="bi bi-pause-circle"></i> Tạm dừng'
                : '<i class="bi bi-play-circle"></i> Kích hoạt';
            btnToggleKpiStatus.title = isActive ? 'Tạm dừng KPI' : 'Kích hoạt KPI';
        }

        async function fetchJson(url, options) {
            try {
                const response = await fetch(url, options);
                const raw = await response.text();
                let payload = {};
                if (raw) {
                    try {
                        payload = JSON.parse(raw);
                    } catch {
                        payload = { message: raw.slice(0, 500) };
                    }
                }
                if (!response.ok) {
                    return {
                        success: false,
                        message: payload?.message || payload?.Message || payload?.errorMessage || payload?.ErrorMessage || `HTTP ${response.status}`
                    };
                }
                if (typeof payload.success === 'boolean') return payload;
                if (typeof payload.Success === 'boolean') {
                    return {
                        success: !!payload.Success,
                        data: payload.Data,
                        message: payload.Message
                    };
                }
                return { success: true, data: payload };
            } catch (error) {
                console.error('KPI API error', { url, options }, error);
                return { success: false, message: 'Không thể kết nối server.' };
            }
        }

        function rankBadge(score) {
            if (score >= 90) return '<span class="pill ok">Xuất sắc</span>';
            if (score >= 70) return '<span class="pill info">Tốt</span>';
            if (score >= 50) return '<span class="pill warning">Trung bình</span>';
                return '<span class="pill danger">Kém</span>';
        }

        function initDateFilters() {
            const now = new Date();
            const allMonth = document.createElement('option');
            allMonth.value = '';
            allMonth.textContent = 'Tất cả tháng';
            allMonth.selected = true;
            kpiMonthFilter.appendChild(allMonth);

            for (let m = 1; m <= 12; m++) {
                const op = document.createElement('option');
                op.value = String(m);
                op.textContent = `tháng ${m}`;
                kpiMonthFilter.appendChild(op);
            }

            for (let y = now.getFullYear() - 2; y <= now.getFullYear() + 1; y++) {
                const op = document.createElement('option');
                op.value = String(y);
                op.textContent = `năm ${y}`;
                if (y === now.getFullYear()) op.selected = true;
                kpiYearFilter.appendChild(op);
            }

            formKpiMonth.value = String(now.getMonth() + 1);
            formKpiYear.value = String(now.getFullYear());
        }

        async function loadReferences() {
            const [scopeRes, typeRes, deptRes, projectRes, empRes] = await Promise.all([
                fetchJson('/kpi/scope'),
                fetchJson('/kpi/types'),
                fetchJson('/phongban'),
                fetchJson('/duan?page=1&size=200'),
                fetchJson('/nhanvien?page=1&size=200')
            ]);

            state.scope = scopeRes.success ? (scopeRes.data || null) : null;
            state.kpiTypes = typeRes.success ? (typeRes.data || []) : [];
            state.departments = deptRes.success ? (deptRes.data || []) : [];
            state.teams = [];
            state.filteredTeams = [];
            state.projects = projectRes.success ? (projectRes.data?.items || []) : [];
            state.employees = empRes.success ? (empRes.data?.items || []) : [];

            if (state.scope?.roleKey === 'manager' && state.scope?.maPhongBan) {
                const scopeDept = Number(state.scope.maPhongBan);
                state.departments = state.departments.filter(d => Number(d.maPhongBan) === scopeDept);
                state.employees = state.employees.filter(e => Number(e.maPhongBan) === scopeDept);
            } else if (state.scope?.roleKey === 'employee' && state.scope?.maNhanVien) {
                const scopeEmp = Number(state.scope.maNhanVien);
                state.employees = state.employees.filter(e => Number(e.maNhanVien) === scopeEmp);
            }

            kpiTypeFilter.innerHTML = '<option value="">Tất cả loại KPI</option>' +
                state.kpiTypes.map(t => `<option value="${t.maLoaiKpi}">${escapeHtml(t.tenLoaiKpi || `Loai ${t.maLoaiKpi}`)}</option>`).join('');

            formKpiType.innerHTML = state.kpiTypes.map(t => `<option value="${t.maLoaiKpi}">${escapeHtml(t.tenLoaiKpi || `Loai ${t.maLoaiKpi}`)}</option>`).join('');

            kpiDepartmentFilter.innerHTML = '<option value="">Tất cả phòng ban</option>' +
                state.departments.map(d => `<option value="${d.maPhongBan}">${escapeHtml(d.tenPhongBan || `phòng ${d.maPhongBan}`)}</option>`).join('');

            if (state.scope?.roleKey === 'manager' && state.departments.length === 1) {
                kpiDepartmentFilter.value = String(state.departments[0].maPhongBan);
                kpiDepartmentFilter.setAttribute('disabled', 'disabled');
            }

            await refreshTeamFilterOptions();

            refillAssignmentObject();
            fillProposalReferenceOptions();
            refillProposalTargetOptions();
            syncProposalFormByType();
        }

        async function refreshTeamFilterOptions() {
            const query = new URLSearchParams();
            if (kpiDepartmentFilter.value) {
                query.set('maPhongBan', kpiDepartmentFilter.value);
            }

            const res = await fetchJson(`/kpi/team-options?${query.toString()}`);
            const teams = res.success ? (res.data || []) : [];
            state.filteredTeams = teams;
            state.teams = teams;

            const selected = kpiTeamFilter.value;
            kpiTeamFilter.innerHTML = '<option value="">Tất cả nhóm</option>' +
                teams.map(t => `<option value="${t.maNhom}">${escapeHtml(t.tenNhom || `Nhóm ${t.maNhom}`)}</option>`).join('');

            if (selected && teams.some(t => String(t.maNhom) === selected)) {
                kpiTeamFilter.value = selected;
            } else {
                kpiTeamFilter.value = '';
            }

            refillProposalTargetOptions();
        }

        function refillAssignmentObject() {
            const mode = assignObjectType.value;
            if (mode === 'department') {
                assignObjectId.innerHTML = '<option value="">chọn phòng ban</option>' +
                    state.departments.map(d => `<option value="${d.maPhongBan}">${escapeHtml(d.tenPhongBan || `phòng ${d.maPhongBan}`)}</option>`).join('');
                return;
            }

            if (mode === 'team') {
                assignObjectId.innerHTML = '<option value="">chọn nhóm</option>' +
                    state.teams.map(t => `<option value="${t.maNhom}">${escapeHtml(t.tenNhom || `Nhóm ${t.maNhom}`)}</option>`).join('');
                return;
            }

            if (mode === 'project') {
                assignObjectId.innerHTML = '<option value="">chọn dự án</option>' +
                    state.projects.map(p => `<option value="${p.maDuAn}">${escapeHtml(p.tenDuAn || `dự án ${p.maDuAn}`)}</option>`).join('');
                return;
            }

            assignObjectId.innerHTML = '<option value="">chọn nhân viên</option>' +
                state.employees.map(e => `<option value="${e.maNhanVien}">${escapeHtml(e.hoTen || `NV ${e.maNhanVien}`)}</option>`).join('');
        }

        function proposalStatusPill(status) {
            if (status === 'DaDuyet') return '<span class="pill ok">Đã duyệt</span>';
            if (status === 'TuChoi') return '<span class="pill danger">Từ chối</span>';
            if (status === 'CanChinhSua') return '<span class="pill warning">Cần chỉnh sửa</span>';
            return '<span class="pill info">Chờ duyệt</span>';
        }

        function resolveProposalTargetName(item) {
            if (!item) return '-';
            if (item.maNhanVienApDung) {
                const emp = state.employees.find(x => Number(x.maNhanVien) === Number(item.maNhanVienApDung));
                return emp?.hoTen || `Nhân viên #${item.maNhanVienApDung}`;
            }
            if (item.maNhomApDung) {
                const team = state.teams.find(x => Number(x.maNhom) === Number(item.maNhomApDung));
                return team?.tenNhom || `Nhóm #${item.maNhomApDung}`;
            }
            if (item.maPhongBanApDung) {
                const dept = state.departments.find(x => Number(x.maPhongBan) === Number(item.maPhongBanApDung));
                return dept?.tenPhongBan || `Phòng ban #${item.maPhongBanApDung}`;
            }
            if (item.maDuAnApDung) {
                const project = state.projects.find(x => Number(x.maDuAn) === Number(item.maDuAnApDung));
                return project?.tenDuAn || `Dự án #${item.maDuAnApDung}`;
            }
            return '-';
        }

        function fillProposalReferenceOptions() {
            if (!proposalKpiId || !proposalLoaiKpi) return;

            proposalKpiId.innerHTML = '<option value="">Chọn KPI</option>' +
                state.kpis.map(k => `<option value="${k.maKpi}">${escapeHtml(k.tenKpi || `KPI ${k.maKpi}`)}</option>`).join('');
            proposalLoaiKpi.innerHTML = '<option value="">Chọn loại KPI</option>' +
                state.kpiTypes.map(t => `<option value="${t.maLoaiKpi}">${escapeHtml(t.tenLoaiKpi || `Loai ${t.maLoaiKpi}`)}</option>`).join('');
        }

        function refillProposalTargetOptions() {
            if (!proposalTargetType || !proposalTargetId) return;

            const mode = proposalTargetType.value;
            if (mode === 'department') {
                proposalTargetId.innerHTML = '<option value="">Chọn phòng ban</option>' +
                    state.departments.map(d => `<option value="${d.maPhongBan}">${escapeHtml(d.tenPhongBan || `Phòng ${d.maPhongBan}`)}</option>`).join('');
                return;
            }

            if (mode === 'team') {
                proposalTargetId.innerHTML = '<option value="">Chọn nhóm</option>' +
                    state.teams.map(t => `<option value="${t.maNhom}">${escapeHtml(t.tenNhom || `Nhóm ${t.maNhom}`)}</option>`).join('');
                return;
            }

            if (mode === 'project') {
                proposalTargetId.innerHTML = '<option value="">Chọn dự án</option>' +
                    state.projects.map(p => `<option value="${p.maDuAn}">${escapeHtml(p.tenDuAn || `Dự án ${p.maDuAn}`)}</option>`).join('');
                return;
            }

            proposalTargetId.innerHTML = '<option value="">Chọn nhân viên</option>' +
                state.employees.map(e => `<option value="${e.maNhanVien}">${escapeHtml(e.hoTen || `NV ${e.maNhanVien}`)}</option>`).join('');
        }

        function syncProposalFormByType() {
            if (!proposalType) return;
            const type = proposalType.value;
            const isCreateNew = type === 'TaoMoiKPI';
            const needExistingKpi = type === 'ApDungKPI' || type === 'DieuChinhKPI' || type === 'HuyApDungKPI';

            if (proposalKpiId) proposalKpiId.disabled = !needExistingKpi;
            if (proposalLoaiKpi) proposalLoaiKpi.disabled = !isCreateNew;
            if (proposalTenKpi) proposalTenKpi.disabled = !isCreateNew;
        }

        function resetProposalForm() {
            state.proposalEditingId = null;
            if (proposalType) proposalType.value = 'TaoMoiKPI';
            if (proposalKpiId) proposalKpiId.value = '';
            if (proposalLoaiKpi) proposalLoaiKpi.value = '';
            if (proposalTenKpi) proposalTenKpi.value = '';
            if (proposalTrongSo) proposalTrongSo.value = '0';
            if (proposalTargetType) proposalTargetType.value = 'employee';
            refillProposalTargetOptions();
            if (proposalTargetId) proposalTargetId.value = '';
            if (proposalFromDate) proposalFromDate.value = '';
            if (proposalToDate) proposalToDate.value = '';
            if (proposalMoTa) proposalMoTa.value = '';
            if (proposalLyDo) proposalLyDo.value = '';
            if (proposalGhiChu) proposalGhiChu.value = '';
            if (btnSubmitProposal) btnSubmitProposal.textContent = 'Gửi đề xuất';
            if (proposalFormHint) {
                proposalFormHint.className = 'small mt-2 text-muted';
                proposalFormHint.textContent = 'Manager tạo đề xuất, Admin duyệt thì mới áp dụng vào KPI chính thức.';
            }
            syncProposalFormByType();
        }

        function patchProposalFormForEdit(item) {
            if (!item) return;
            state.proposalEditingId = item.maDeXuat;
            proposalType.value = item.loaiDeXuat || 'ApDungKPI';
            proposalKpiId.value = item.maKpi ? String(item.maKpi) : '';
            proposalLoaiKpi.value = item.maLoaiKpi ? String(item.maLoaiKpi) : '';
            proposalTenKpi.value = item.tenKpiDeXuat || '';
            proposalTrongSo.value = Number(item.trongSoDeXuat || 0).toFixed(2);
            proposalFromDate.value = item.tuNgay ? new Date(item.tuNgay).toISOString().slice(0, 10) : '';
            proposalToDate.value = item.denNgay ? new Date(item.denNgay).toISOString().slice(0, 10) : '';
            proposalMoTa.value = item.moTaKpiDeXuat || '';
            proposalLyDo.value = item.lyDo || '';
            proposalGhiChu.value = item.ghiChu || '';

            if (item.maNhomApDung) proposalTargetType.value = 'team';
            else if (item.maPhongBanApDung) proposalTargetType.value = 'department';
            else if (item.maDuAnApDung) proposalTargetType.value = 'project';
            else proposalTargetType.value = 'employee';
            refillProposalTargetOptions();
            proposalTargetId.value = String(item.maNhanVienApDung || item.maNhomApDung || item.maPhongBanApDung || item.maDuAnApDung || '');

            syncProposalFormByType();
            btnSubmitProposal.textContent = 'Cập nhật & gửi lại';
            proposalFormHint.className = 'small mt-2 text-primary';
            proposalFormHint.textContent = `Đang sửa đề xuất #${item.maDeXuat} (trạng thái CanChinhSua).`;
            document.getElementById('kpiProposalSection')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }

        function buildProposalPayload() {
            const type = proposalType.value;
            const targetMode = proposalTargetType.value;
            const targetId = Number(proposalTargetId.value || 0);
            const payload = {
                maKpi: proposalKpiId.value ? Number(proposalKpiId.value) : null,
                maLoaiKpi: proposalLoaiKpi.value ? Number(proposalLoaiKpi.value) : null,
                loaiDeXuat: type,
                maNhanVienApDung: null,
                maNhomApDung: null,
                maPhongBanApDung: null,
                maDuAnApDung: null,
                tuNgay: proposalFromDate.value,
                denNgay: proposalToDate.value || null,
                trongSoDeXuat: Number(proposalTrongSo.value || 0),
                tenKpiDeXuat: proposalTenKpi.value.trim() || null,
                moTaKpiDeXuat: proposalMoTa.value.trim() || null,
                lyDo: proposalLyDo.value.trim() || null,
                ghiChu: proposalGhiChu.value.trim() || null
            };

            if (!payload.tuNgay) return { ok: false, message: 'TU_NGAY là bắt buộc.' };
            if (!targetId) return { ok: false, message: 'Vui lòng chọn đối tượng áp dụng.' };
            if (payload.denNgay && payload.denNgay < payload.tuNgay) return { ok: false, message: 'ĐẾN NGÀY phải lớn hơn hoặc bằng TỪ NGÀY.' };

            if (targetMode === 'team') payload.maNhomApDung = targetId;
            else if (targetMode === 'department') payload.maPhongBanApDung = targetId;
            else if (targetMode === 'project') payload.maDuAnApDung = targetId;
            else payload.maNhanVienApDung = targetId;

            if (type === 'TaoMoiKPI') {
                if (!payload.maLoaiKpi) return { ok: false, message: 'Tạo mới KPI bắt buộc chọn Loại KPI.' };
                if (!payload.tenKpiDeXuat) return { ok: false, message: 'Tạo mới KPI bắt buộc nhập Tên KPI đề xuất.' };
                if (payload.trongSoDeXuat <= 0) return { ok: false, message: 'Tạo mới KPI yêu cầu trọng số > 0.' };
            }

            if (type === 'ApDungKPI' && !payload.maKpi) {
                return { ok: false, message: 'Áp dụng KPI bắt buộc chọn KPI hiện có.' };
            }

            if ((type === 'DieuChinhKPI' || type === 'HuyApDungKPI') && !payload.maKpi) {
                return { ok: false, message: 'Điều chỉnh/Hủy áp dụng KPI bắt buộc chọn KPI hiện có.' };
            }

            return { ok: true, payload };
        }


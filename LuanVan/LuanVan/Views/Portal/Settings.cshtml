        function renderKpiGrades() {
            if (!kpiGradeBody) return;
            if (!state.kpiGrades.length) {
                kpiGradeBody.innerHTML = '<tr><td colspan="6" class="text-muted">Chưa có dữ liệu xếp loại KPI.</td></tr>';
                return;
            }

            kpiGradeBody.innerHTML = state.kpiGrades.map(item => `
                <tr>
                    <td><code>${escapeHtml(item.code || '-')}</code></td>
                    <td>${escapeHtml(item.label || '-')}<div class="small text-muted">${escapeHtml(item.moTa || '')}</div></td>
                    <td>${Number(item.minScore ?? 0).toFixed(2)} - ${Number(item.maxScore ?? 0).toFixed(2)}</td>
                    <td><span class="badge" style="background:${escapeHtml(item.colorHex || '#64748B')}">${escapeHtml(item.colorHex || '#64748B')}</span></td>
                    <td>${item.isActive ? '<span class="text-success">Đang áp dụng</span>' : '<span class="text-muted">Ngưng áp dụng</span>'}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-primary me-1" data-action="edit-grade" data-id="${item.id}"><i class="bi bi-pencil"></i></button>
                        <button class="btn btn-sm btn-outline-${item.isActive ? 'warning' : 'success'}" data-action="toggle-grade" data-id="${item.id}" data-active="${item.isActive ? '1' : '0'}">${item.isActive ? 'Ngưng áp dụng' : 'Bật lại'}</button>
                    </td>
                </tr>
            `).join('');

            const scoreStep = 0.01;
            const grades = state.kpiGrades.filter(x => x.isActive).map(x => ({ min: Number(x.minScore || 0), max: Number(x.maxScore || 0) })).sort((a, b) => a.min - b.min);
            let cursor = 0;
            let covered = true;
            for (const row of grades) {
                if (row.min > cursor + scoreStep) { covered = false; break; }
                cursor = Math.max(cursor, row.max);
            }
            if (cursor < 100 - scoreStep) covered = false;
            if (kpiGradeWarning) {
                kpiGradeWarning.textContent = covered ? '' : 'Cảnh báo: cấu hình xếp loại chưa bao phủ toàn bộ dải điểm 0-100.';
            }
        }


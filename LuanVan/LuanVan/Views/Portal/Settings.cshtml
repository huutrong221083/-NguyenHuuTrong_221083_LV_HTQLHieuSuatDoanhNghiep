        async function loadPermissionClaimsForRole(roleId) {
            if (!roleId) {
                state.selectedPermissionClaims = new Set();
                renderPermissions();
                return;
            }

            setPermissionInfoMessage('Đang tải quyền claim theo vai trò...');
            const res = await fetchJson(`/system/roles/${encodeURIComponent(roleId)}/claims`);
            if (!res.success) {
                state.selectedPermissionClaims = new Set();
                renderPermissions();
                setPermissionInfoMessage(res.message || 'Không tải được claim của vai trò.', true);
                return;
            }

            const claims = (res.data?.permissionClaims || []).map(x => String(x));
            state.selectedPermissionClaims = new Set(claims);
            state.selectedPermissionRoleId = roleId;
            renderPermissions();

            const roleName = res.data?.roleName || getSelectedPermissionRole()?.name || '-';
            setPermissionInfoMessage(`Role ${roleName}: ${claims.length} permission claim.`);
        }

        function renderPermissions() {
            const selectedRole = getSelectedPermissionRole();
            if (!selectedRole) {
                permissionTableBody.innerHTML = '<tr><td colspan="5" class="text-muted">Chưa có role để cấu hình claim.</td></tr>';
                return;
            }

            permissionTableBody.innerHTML = state.permissionRows.map(row => `
                <tr>
                    <td>${escapeHtml(row.label)}</td>
                    ${permissionFields.map(field => {
                        const claimValue = toPermissionClaimValue(row, field);
                        const checked = state.selectedPermissionClaims.has(claimValue);
                        return `<td><input type="checkbox" data-claim="${claimValue}" ${checked ? 'checked' : ''} /></td>`;
                    }).join('')}
                </tr>
            `).join('');
        }

        function renderLogs() {

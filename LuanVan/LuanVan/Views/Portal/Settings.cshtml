@{
    var role = (ViewData["Role"]?.ToString() ?? "Admin").Trim().ToLowerInvariant();
    var canEditSettings = (ViewData["CanEditSettings"] as bool?) ?? false;
}

<section class="page-head settingsx-head">
    <div>
        <h2>Cài đặt hệ thống</h2>
        <p class="text-muted mb-0">Quản lý role, permission, KPI/AI parameter, bao mat và log hệ thống.</p>
    </div>
    <div class="badge role-badge">Role: @role.ToUpperInvariant()</div>
</section>

<nav class="crumb">Trang chủ / Cài đặt hệ thống</nav>

<section class="settingsx-shell mt-3">
    <aside class="settingsx-sidebar panel" id="settingsSidebar">
        <div class="settingsx-sidebar-top">
            <h5>Settings</h5>
            <button id="btnToggleSettingsSidebar" class="btn btn-sm btn-light"><i class="bi bi-layout-sidebar-inset"></i></button>
        </div>
        <nav id="settingsMenu" class="settingsx-menu">
            <button class="active" data-page="overview"><i class="bi bi-gear"></i><span>Tổng quan hệ thống</span></button>
            <button data-page="roles"><i class="bi bi-people"></i><span>Quản lý Role</span></button>
            <button data-page="permissions"><i class="bi bi-shield-lock"></i><span>Phân quyền</span></button>
            <button data-page="kpi"><i class="bi bi-bullseye"></i><span>Cấu hình KPI</span></button>
            <button data-page="ai"><i class="bi bi-robot"></i><span>Cấu hình AI</span></button>
            <button data-page="notifications"><i class="bi bi-bell"></i><span>Tùy chỉnh giao diện & thông báo</span></button>
            <button data-page="security"><i class="bi bi-shield-check"></i><span>Kiểm tra hệ thống</span></button>
            <button data-page="logs"><i class="bi bi-journal-text"></i><span>Log hệ thống</span></button>
        </nav>
    </aside>

    <main class="settingsx-main panel">
        <section id="page-overview" class="settingsx-page active">
            <header class="settingsx-page-head">
                <h4>Tổng quan hệ thống</h4>
            </header>
            <div id="settingsOverviewCards" class="settingsx-overview-grid"></div>
        </section>

        <section id="page-roles" class="settingsx-page">
            <header class="settingsx-page-head d-flex justify-content-between align-items-center gap-2">
                <h4 class="mb-0">Quản lý Role</h4>
                <button id="btnOpenRoleCreate" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> Thêm role</button>
            </header>
            <div class="table-responsive mt-2">
                <table class="table align-middle settingsx-table mb-0">
                    <thead>
                        <tr>
                            <th>Role</th>
                            <th>Mo ta</th>
                            <th>So user</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="settingsRoleBody">
                        <tr><td colspan="4" class="text-muted">Đang tải...</td></tr>
                    </tbody>
                </table>
            </div>
        </section>

        <section id="page-permissions" class="settingsx-page">
            <header class="settingsx-page-head">
                <h4>Phân quyền</h4>
                <small class="text-muted">Gán permission claim theo role và lưu trực tiếp vào AspNetRoleClaims.</small>
            </header>
            <div class="row g-2 align-items-end mt-1">
                <div class="col-lg-4 col-md-6">
                    <label class="form-label mb-1">Vai trò</label>
                    <select id="permissionRoleSelect" class="form-select form-select-sm"></select>
                </div>
                <div class="col-lg-8 col-md-6">
                    <div id="permissionClaimInfo" class="small text-muted"></div>
                </div>
            </div>
            <div class="table-responsive mt-2">
                <table class="table table-bordered settingsx-permission-table mb-0" id="permissionTable">
                    <thead>
                        <tr>
                            <th>Chuc nang</th>
                            <th>Xem</th>
                            <th>Thêm</th>
                            <th>Sửa</th>
                            <th>Xóa</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="settingsx-form-actions mt-2">
                <button id="btnSavePermissions" class="btn btn-primary btn-sm">Lưu</button>
                <button id="btnResetPermissions" class="btn btn-light btn-sm">Khôi phục mặc định</button>
            </div>
        </section>

        <section id="page-kpi" class="settingsx-page">
            <header class="settingsx-page-head">
                <h4>Cấu hình KPI</h4>
                <small class="text-muted">Xếp loại KPI và danh mục dùng chung (Độ khó / Độ ưu tiên / Loại KPI).</small>
            </header>

            <section class="panel mt-2">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                    <h6 class="mb-0">Xếp loại KPI</h6>
                    <button id="btnOpenKpiGradeCreate" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> Thêm mức xếp loại</button>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle settingsx-table mb-0">
                        <thead>
                            <tr>
                                <th>Mã</th>
                                <th>Tên</th>
                                <th>Khoảng điểm</th>
                                <th>Màu</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="kpiGradeBody">
                            <tr><td colspan="6" class="text-muted">Đang tải xếp loại KPI...</td></tr>
                        </tbody>
                    </table>
                </div>
                <p id="kpiGradeWarning" class="small text-warning mt-2 mb-0"></p>
            </section>

            <section class="panel mt-2">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                    <h6 class="mb-0">Danh mục dùng chung</h6>
                    <div class="d-flex align-items-center gap-2">
                        <select id="kpiMasterType" class="form-select form-select-sm" style="max-width:260px;">
                            <option value="dokho">Độ khó</option>
                            <option value="douutien">Độ ưu tiên</option>
                            <option value="loaikpi">Loại KPI</option>
                        </select>
                        <button id="btnOpenKpiMasterCreate" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> Thêm danh mục</button>
                    </div>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle settingsx-table mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Tên</th>
                                <th>Hệ số</th>
                                <th>Trạng thái</th>
                                <th class="text-end">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="kpiMasterBody">
                            <tr><td colspan="5" class="text-muted">Đang tải danh mục...</td></tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <section class="panel mt-2">
                <div class="d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div>
                        <h6 class="mb-1">Quản lý KPI chi tiết</h6>
                        <p class="text-muted mb-0">Các thao tác vận hành KPI (danh sách, gán đối tượng, kết quả, phân tích) được quản lý tập trung ở màn KPI riêng.</p>
                    </div>
                    <a class="btn btn-sm btn-outline-primary" href="/Portal/Kpi?role=@ViewBag.Role">
                        <i class="bi bi-box-arrow-up-right"></i> Đi đến Quản lý KPI
                    </a>
                </div>
            </section>
        </section>

        <section id="page-ai" class="settingsx-page">
            <header class="settingsx-page-head aix-head">
                <h4>🤖 CẤU HÌNH THAM SỐ AI</h4>
                <p class="text-muted mb-0">Tùy chỉnh hành vi và thuật toán AI phục vụ dự báo và đánh giá hiệu suất.</p>
            </header>

            <div class="aix-tab-nav" id="aiTabNav" role="tablist" aria-label="AI Config Tabs">
                <button class="active" data-ai-tab="general">1. Cấu hình chung</button>
                <button data-ai-tab="forecast">2. Dự báo tiến độ (Linear Regression)</button>
                <button data-ai-tab="performance">3. Đánh giá hiệu suất (Random Forest)</button>
                <button data-ai-tab="automation">4. Gợi ý &amp; Tự động hóa AI</button>
            </div>

            <div class="aix-tab-body">
                <section class="aix-tab-panel active" id="ai-tab-general">
                    <article class="aix-card">
                        <h6>🔹 Bật/Tắt AI</h6>
                        <div class="aix-row">
                            <label>Kích hoạt AI trong hệ thống</label>
                            <div class="form-check form-switch">
                                <input id="aiEnableSystem" class="form-check-input" type="checkbox" checked />
                            </div>
                        </div>
                        <div class="aix-check-grid">
                            <label class="form-check"><input id="aiApplyAll" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Áp dụng AI cho toàn bộ hệ thống</span></label>
                            <label class="form-check"><input id="aiApplyManager" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Chỉ áp dụng cho Manager</span></label>
                            <label class="form-check"><input id="aiApplyDepartment" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Áp dụng cho từng phòng ban</span></label>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Phạm vi dữ liệu AI sử dụng</h6>
                        <div class="aix-two-col">
                            <div>
                                <label class="form-label">Khoảng dữ liệu phân tích</label>
                                <select id="aiDataWindow" class="form-select form-select-sm">
                                    <option value="1">1 tháng gần nhất</option>
                                    <option value="3">3 tháng gần nhất</option>
                                    <option value="6" selected>6 tháng gần nhất</option>
                                    <option value="12">12 tháng gần nhất</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Số lượng dữ liệu tối thiểu</label>
                                <input id="aiMinRecords" type="number" class="form-control form-control-sm" min="30" max="50000" value="100" />
                            </div>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Tần suất chạy AI</h6>
                        <div class="aix-radio-grid">
                            <label class="form-check"><input class="form-check-input" type="radio" name="aiRunMode" value="realtime" /> <span class="form-check-label">Real-time</span></label>
                            <label class="form-check"><input class="form-check-input" type="radio" name="aiRunMode" value="daily" checked /> <span class="form-check-label">Mỗi ngày</span></label>
                            <label class="form-check"><input class="form-check-input" type="radio" name="aiRunMode" value="weekly" /> <span class="form-check-label">Mỗi tuần</span></label>
                            <label class="form-check"><input class="form-check-input" type="radio" name="aiRunMode" value="ondemand" /> <span class="form-check-label">Khi Admin yêu cầu</span></label>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Trọng số dữ liệu đầu vào</h6>
                        <div class="aix-slider-grid">
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiWeightCompletion" class="mb-0">Tốc độ hoàn thành công việc: <strong id="aiWeightCompletionValue">70%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiWeightCompletion" type="number" class="form-control text-end" min="0" max="100" step="1" value="70" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiWeightOverdue" class="mb-0">Số công việc trễ hạn: <strong id="aiWeightOverdueValue">50%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiWeightOverdue" type="number" class="form-control text-end" min="0" max="100" step="1" value="50" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiWeightKpi" class="mb-0">Điểm KPI: <strong id="aiWeightKpiValue">80%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiWeightKpi" type="number" class="form-control text-end" min="0" max="100" step="1" value="80" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiWeightDifficulty" class="mb-0">Độ khó công việc: <strong id="aiWeightDifficultyValue">60%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiWeightDifficulty" type="number" class="form-control text-end" min="0" max="100" step="1" value="60" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                        </div>
                    </article>
                </section>

                <section class="aix-tab-panel" id="ai-tab-forecast">
                    <article class="aix-card">
                        <h6>📈 Mô hình dự báo tiến độ</h6>
                        <div class="aix-two-col">
                            <div>
                                <label class="form-label">Mô hình sử dụng</label>
                                <select id="aiForecastModel" class="form-select form-select-sm">
                                    <option selected>Linear Regression</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Cảnh báo nếu xác suất trễ lớn hơn</label>
                                <div class="input-group input-group-sm">
                                    <input id="aiDelayThreshold" type="number" class="form-control" min="0" max="100" value="70" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Biến đầu vào</h6>
                        <div class="aix-check-grid">
                            <label class="form-check"><input id="aiFeatureCompletion" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">% hoàn thành công việc</span></label>
                            <label class="form-check"><input id="aiFeatureUsedTime" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Thời gian đã sử dụng</span></label>
                            <label class="form-check"><input id="aiFeatureRemainWork" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Khối lượng công việc còn lại</span></label>
                            <label class="form-check"><input id="aiFeatureDifficulty" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Độ khó công việc</span></label>
                        </div>
                        <p class="aix-legend mb-0">🟢 &lt; 50% | 🟡 50-70% | 🔴 &gt; 70%</p>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Hiển thị dự báo</h6>
                        <div class="aix-check-grid">
                            <label class="form-check"><input id="aiShowExpectedDate" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Hiển thị ngày hoàn thành dự kiến</span></label>
                            <label class="form-check"><input id="aiShowEarlyWarning" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Hiển thị cảnh báo sớm</span></label>
                            <label class="form-check"><input id="aiShowTrend" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Hiển thị xu hướng tiến độ (tăng/giảm)</span></label>
                        </div>
                    </article>
                </section>

                <section class="aix-tab-panel" id="ai-tab-performance">
                    <article class="aix-card">
                        <h6>🧠 Mô hình đánh giá hiệu suất</h6>
                        <div class="aix-model-grid">
                            <div>
                                <label class="form-label">Mô hình sử dụng</label>
                                <select id="aiPerformanceModel" class="form-select form-select-sm">
                                    <option selected>Random Forest</option>
                                </select>
                            </div>
                            <div>
                                <label class="form-label">Mức độ phân tích AI</label>
                                <select id="aiAnalysisLevel" class="form-select form-select-sm">
                                    <option value="fast">Nhanh</option>
                                    <option value="balanced" selected>Cân bằng</option>
                                    <option value="deep">Chuyên sâu</option>
                                </select>
                                <small class="text-muted">Hệ thống tự tối ưu tham số mô hình theo mức bạn chọn.</small>
                            </div>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Tiêu chí đánh giá</h6>
                        <div class="aix-check-grid">
                            <label class="form-check"><input id="aiCriteriaOnTime" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Hoàn thành đúng hạn</span></label>
                            <label class="form-check"><input id="aiCriteriaVolume" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Số lượng công việc</span></label>
                            <label class="form-check"><input id="aiCriteriaDifficulty" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Độ khó công việc</span></label>
                            <label class="form-check"><input id="aiCriteriaKpi" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Điểm KPI</span></label>
                            <label class="form-check"><input id="aiCriteriaFeedback" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Feedback từ Manager</span></label>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Trọng số đánh giá</h6>
                        <div class="aix-slider-grid">
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiEvalOnTime" class="mb-0">Đúng hạn: <strong id="aiEvalOnTimeValue">80%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiEvalOnTime" type="number" class="form-control text-end" min="0" max="100" step="1" value="80" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiEvalVolume" class="mb-0">Khối lượng: <strong id="aiEvalVolumeValue">60%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiEvalVolume" type="number" class="form-control text-end" min="0" max="100" step="1" value="60" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiEvalDifficulty" class="mb-0">Độ khó: <strong id="aiEvalDifficultyValue">70%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiEvalDifficulty" type="number" class="form-control text-end" min="0" max="100" step="1" value="70" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiEvalKpi" class="mb-0">KPI: <strong id="aiEvalKpiValue">90%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiEvalKpi" type="number" class="form-control text-end" min="0" max="100" step="1" value="90" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                            <div class="d-flex align-items-center justify-content-between gap-2 flex-wrap">
                                <label for="aiEvalFeedback" class="mb-0">Feedback: <strong id="aiEvalFeedbackValue">50%</strong></label>
                                <div class="input-group input-group-sm" style="max-width: 140px;">
                                    <input id="aiEvalFeedback" type="number" class="form-control text-end" min="0" max="100" step="1" value="50" />
                                    <span class="input-group-text">%</span>
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="aix-card">
                        <h6>🔹 Phân loại kết quả</h6>
                        <div class="aix-two-col">
                            <div>
                                <label class="form-label">Xuất kết quả</label>
                                <input id="aiResultClasses" class="form-control form-control-sm" value="Xuất sắc | Tốt | Trung bình | Kém" />
                            </div>
                            <div class="d-flex align-items-end">
                                <label class="form-check mb-1"><input id="aiAllowAdjustClass" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Cho phép Admin chỉnh ngưỡng phân loại</span></label>
                            </div>
                        </div>
                    </article>
                </section>

                <section class="aix-tab-panel" id="ai-tab-automation">
                    <article class="aix-card">
                        <h6>🤖 Gợi ý &amp; tự động hóa AI</h6>
                        <div class="aix-check-grid">
                            <label class="form-check"><input id="aiSuggestPeople" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Gợi ý người phù hợp cho công việc</span></label>
                            <label class="form-check"><input id="aiSuggestBySkillPerformance" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Dựa trên kỹ năng + lịch sử hiệu suất</span></label>
                            <label class="form-check"><input id="aiSuggestImprovePerformance" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Gợi ý cải thiện hiệu suất nhân viên</span></label>
                            <label class="form-check"><input id="aiSuggestRebalanceTask" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Gợi ý phân bổ lại công việc</span></label>
                            <label class="form-check"><input id="aiAutoLateAlert" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Tự động cảnh báo trễ hạn</span></label>
                            <label class="form-check"><input id="aiAutoSendNotification" class="form-check-input" type="checkbox" checked /> <span class="form-check-label">Tự động gửi thông báo</span></label>

        function applyAiSettingsToForm(ai) {
            const config = ai || defaultAi;

            document.getElementById('aiEnableSystem').checked = !!config.general.enabled;
            document.getElementById('aiApplyAll').checked = !!config.general.applyAll;
            document.getElementById('aiApplyManager').checked = !!config.general.applyManager;
            document.getElementById('aiApplyDepartment').checked = !!config.general.applyDepartment;
            document.getElementById('aiDataWindow').value = String(config.general.dataWindow);
            document.getElementById('aiMinRecords').value = Number(config.general.minRecords);
            setCheckedRadioValue('aiRunMode', config.general.runMode);

            setRangeValue('aiWeightCompletion', 'aiWeightCompletionValue', config.general.weights.completion);
            setRangeValue('aiWeightOverdue', 'aiWeightOverdueValue', config.general.weights.overdue);
            setRangeValue('aiWeightKpi', 'aiWeightKpiValue', config.general.weights.kpi);
            setRangeValue('aiWeightDifficulty', 'aiWeightDifficultyValue', config.general.weights.difficulty);

            document.getElementById('aiForecastModel').value = config.forecast.model;
            document.getElementById('aiDelayThreshold').value = Number(config.forecast.delayThreshold);
            document.getElementById('aiFeatureCompletion').checked = !!config.forecast.features.completion;
            document.getElementById('aiFeatureUsedTime').checked = !!config.forecast.features.usedTime;
            document.getElementById('aiFeatureRemainWork').checked = !!config.forecast.features.remainWork;
            document.getElementById('aiFeatureDifficulty').checked = !!config.forecast.features.difficulty;
            document.getElementById('aiShowExpectedDate').checked = !!config.forecast.display.expectedDate;
            document.getElementById('aiShowEarlyWarning').checked = !!config.forecast.display.earlyWarning;
            document.getElementById('aiShowTrend').checked = !!config.forecast.display.trend;

            document.getElementById('aiPerformanceModel').value = config.performance.model;
            const resolvedLevel = config.performance.analysisLevel
                || resolveAnalysisLevelFromHyperParams(config.performance.estimators, config.performance.maxDepth);
            document.getElementById('aiAnalysisLevel').value = resolvedLevel;
            document.getElementById('aiCriteriaOnTime').checked = !!config.performance.criteria.onTime;
            document.getElementById('aiCriteriaVolume').checked = !!config.performance.criteria.volume;
            document.getElementById('aiCriteriaDifficulty').checked = !!config.performance.criteria.difficulty;
            document.getElementById('aiCriteriaKpi').checked = !!config.performance.criteria.kpi;
            document.getElementById('aiCriteriaFeedback').checked = !!config.performance.criteria.feedback;

            setRangeValue('aiEvalOnTime', 'aiEvalOnTimeValue', config.performance.weights.onTime);
            setRangeValue('aiEvalVolume', 'aiEvalVolumeValue', config.performance.weights.volume);
            setRangeValue('aiEvalDifficulty', 'aiEvalDifficultyValue', config.performance.weights.difficulty);
            setRangeValue('aiEvalKpi', 'aiEvalKpiValue', config.performance.weights.kpi);
            setRangeValue('aiEvalFeedback', 'aiEvalFeedbackValue', config.performance.weights.feedback);

            document.getElementById('aiResultClasses').value = config.performance.resultClasses;
            document.getElementById('aiAllowAdjustClass').checked = !!config.performance.allowAdjustClass;

            document.getElementById('aiSuggestPeople').checked = !!config.automation.suggestPeople;
            document.getElementById('aiSuggestBySkillPerformance').checked = !!config.automation.suggestBySkillPerformance;

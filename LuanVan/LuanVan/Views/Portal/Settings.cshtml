        function buildLogApiQuery() {
            const params = new URLSearchParams({ page: '1', size: '300' });

            const action = (logSearch.value || '').trim();
            const target = (logObjectSearch?.value || '').trim();
            const from = logFromDate?.value;
            const to = logToDate?.value;

            if (action) params.set('hanhDong', action);
            if (target) params.set('doiTuong', target);
            if (from) params.set('from', from);
            if (to) params.set('to', to);

            return params.toString();
        }

        async function loadLogs(options = {}) {
            const { retryOnFail = true } = options;
            settingsLogBody.innerHTML = '<tr><td colspan="7" class="text-muted">Đang tải log...</td></tr>';
            const logsRes = await fetchJson(`/nhatkyhoatdong?${buildLogApiQuery()}`);
            if (!logsRes.success) {
                if (retryOnFail) {
                    await new Promise(resolve => setTimeout(resolve, 600));
                    return loadLogs({ retryOnFail: false });
                }

                state.logs = [];
                settingsLogBody.innerHTML = `<tr><td colspan="7" class="text-danger">${escapeHtml(logsRes.message || 'Không tải được log hệ thống.')}</td></tr>`;
                renderOverview();
                return;

        const escapeHtml = (value) => String(value ?? '')
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');

        const safeParse = (raw, fallback) => {
            try {
                return raw ? JSON.parse(raw) : fallback;
            } catch {
                return fallback;
            }
        };

        const formatDateTime = (value) => {
            if (!value) return '-';
            const d = new Date(value);
            return Number.isNaN(d.getTime()) ? '-' : d.toLocaleString('vi-VN');
        };

        const deepClone = (value) => JSON.parse(JSON.stringify(value));

        function getClientSetting(key) {
            return state.clientSettingsStore[key] ?? null;
        }

        function setClientSetting(key, jsonStringValue) {
            if (!canEditSettings) {
                return;
            }

            state.clientSettingsStore[key] = jsonStringValue;

            let payload;
            try {
                payload = JSON.parse(jsonStringValue);
            } catch {
                payload = jsonStringValue;
            }

            fetchJson(`/settings/ui/${encodeURIComponent(key)}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ settings: payload })
            });
        }

        function enforceReadOnlySettingsMode() {
            if (canEditSettings) return;

            const writeButtonIds = [
                'btnOpenRoleCreate',
                'btnSaveRole',
                'btnSavePermissions',
                'btnResetPermissions',
                'btnSaveAiSettings',
                'btnResetAiSettings',

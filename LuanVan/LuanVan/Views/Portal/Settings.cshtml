        function readPermissionTable() {
            const claims = [];
            permissionTableBody.querySelectorAll('input[type="checkbox"][data-claim]').forEach(input => {
                const claim = input.getAttribute('data-claim');
                if (!claim || !input.checked) {
                    return;
                }

                claims.push(claim);
            });

            return Array.from(new Set(claims));
        }

        function getDefaultPermissionTemplateByRole(roleName) {
            return defaultPermissionByRole[roleName] || {
                employees: { view: false, create: false, edit: false, delete: false },
                projects: { view: false, create: false, edit: false, delete: false },
                tasks: { view: false, create: false, edit: false, delete: false },
                reports: { view: false, create: false, edit: false, delete: false },
                settings: { view: false, create: false, edit: false, delete: false }
            };
        }

        function buildDefaultClaimsForRole(roleName) {
            const template = getDefaultPermissionTemplateByRole(roleName);
            const claims = [];
            state.permissionRows.forEach(row => {
                const rowTemplate = template[row.key] || {};
                permissionFields.forEach(field => {
                    if (rowTemplate[field]) {
                        claims.push(toPermissionClaimValue(row, field));
                    }
                });
            });
            return Array.from(new Set(claims));
        }


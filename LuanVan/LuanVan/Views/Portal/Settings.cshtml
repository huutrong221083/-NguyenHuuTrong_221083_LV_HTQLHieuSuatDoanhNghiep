        async function saveRole() {
            if (!canEditSettings) {
                roleFormResult.className = 'small text-danger';
                roleFormResult.textContent = 'Bạn chỉ có quyền xem Cài đặt hệ thống.';
                return;
            }

            const name = roleNameInput.value.trim();
            const desc = roleDescInput.value.trim();
            if (!name) {
                roleFormResult.className = 'small text-danger';
                roleFormResult.textContent = 'Tên role là bắt buộc.';
                return;
            }

            let res;
            if (!state.editingRoleId) {
                res = await fetchJson('/system/roles', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name })
                });
            } else {
                res = await fetchJson(`/system/roles/${encodeURIComponent(state.editingRoleId)}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ name })
                });
            }

            if (!res.success) {
                roleFormResult.className = 'small text-danger';
                roleFormResult.textContent = res.message || 'Lưu vai trò thất bại.';
                return;
            }

            state.roleDescMap[name] = desc;
            setClientSetting(STORAGE_KEY.roleDesc, JSON.stringify(state.roleDescMap));
            roleFormModal.hide();
            await loadOverview();
        }


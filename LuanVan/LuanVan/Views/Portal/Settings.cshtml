                const remainWork = Number(document.getElementById('aiTestRemainWork').value || 0);
                const difficulty = Number(document.getElementById('aiTestDifficulty').value || 1);

                const score = Math.max(0, Math.min(100,
                    (timeUsed * 0.38) + (remainWork * 0.3) + ((difficulty * 10) * 0.18) + ((100 - completion) * 0.14)
                ));

                let levelClass = 'alert-success';

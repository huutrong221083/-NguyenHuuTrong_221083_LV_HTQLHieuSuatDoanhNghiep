            await loadKpiGrades();
            await loadKpiMaster();
            await loadOverview();
            // Không tải log quá sớm ở init để tránh lỗi khởi động tạm thời.
            // Dữ liệu log sẽ được tải khi mở tab "Log hệ thống".
        })();

        if (window.bootstrap?.Tooltip) {
            document.querySelectorAll('[title]').forEach(el => new bootstrap.Tooltip(el));
        }
    </script>
}






        async function saveKpiGradeForm() {
            const code = (kpiGradeCodeInput.value || '').trim().toUpperCase();
            const label = (kpiGradeLabelInput.value || '').trim();
            const minScore = Number(kpiGradeMinScoreInput.value);
            const maxScore = Number(kpiGradeMaxScoreInput.value);
            const colorHex = (kpiGradeColorHexInput.value || '').trim();
            const sortOrder = Number(kpiGradeSortOrderInput.value || 0);
            const moTa = (kpiGradeMoTaInput.value || '').trim();
            const isActive = !!kpiGradeIsActiveInput.checked;

            if (!code || !label || Number.isNaN(minScore) || Number.isNaN(maxScore)) {
                kpiGradeFormResult.className = 'small mt-2 mb-0 text-danger';
                kpiGradeFormResult.textContent = 'Vui lòng nhập đầy đủ Mã, Tên mức, Điểm từ/Điểm đến.';
                return;
            }
            if (minScore > maxScore) {
                kpiGradeFormResult.className = 'small mt-2 mb-0 text-danger';
                kpiGradeFormResult.textContent = 'Điểm từ phải nhỏ hơn hoặc bằng Điểm đến.';
                return;
            }

            const payload = { code, label, moTa, minScore, maxScore, colorHex, sortOrder, isActive };
            const isEdit = Number.isInteger(state.editingKpiGradeId);
            const url = isEdit ? `/settings/kpi-grades/${encodeURIComponent(state.editingKpiGradeId)}` : '/settings/kpi-grades';
            const method = isEdit ? 'PUT' : 'POST';
            const res = await fetchJson(url, {
                method,
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            if (!res.success) {
                kpiGradeFormResult.className = 'small mt-2 mb-0 text-danger';
                kpiGradeFormResult.textContent = res.message || 'Không lưu được mức xếp loại KPI.';
                return;
            }

            kpiGradeFormModal.hide();
            await loadKpiGrades();
            alert(res.message || (isEdit ? 'Đã cập nhật mức xếp loại KPI.' : 'Đã thêm mức xếp loại KPI.'));
        }


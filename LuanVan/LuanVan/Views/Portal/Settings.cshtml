        async function fetchJson(url, options, apiName) {
            const label = apiName || url;
            try {
                const response = await fetch(url, options);
                const raw = await response.text();
                const contentType = response.headers.get('content-type') || '';
                const isJsonResponse = contentType.includes('application/json') || contentType.includes('application/problem+json');

                let payload = {};
                if (raw && isJsonResponse) {
                    payload = JSON.parse(raw);
                }

                if (!response.ok) {
                    const fallbackMessage = raw && !isJsonResponse
                        ? `API ${label} lỗi (${response.status}).`
                        : `API ${label} lỗi.`;

                    return {
                        success: false,
                        message: payload?.message || fallbackMessage,
                        statusCode: response.status
                    };
                }

                if (raw && !isJsonResponse) {
                    return { success: true, data: raw };
                }

                if (payload && typeof payload.success === 'boolean') return payload;
                return { success: true, data: payload };
            } catch (error) {
                console.error('[SETTINGSX]', label, error);
                return { success: false, message: `Không kết nối được API ${label}.` };
            }
        }


            const userKw = (logUserSearch.value || '').toLowerCase().trim();
            const objectKw = (logObjectSearch?.value || '').toLowerCase().trim();

            const filtered = state.logs.filter(x => {
                const action = (x.hanhDong || '').toLowerCase();
                const user = (x.hoTenNhanVien || '').toLowerCase();
                const obj = (x.doiTuong || '').toLowerCase();
                if (kw && !action.includes(kw)) return false;
                if (userKw && !user.includes(userKw)) return false;
                if (objectKw && !obj.includes(objectKw)) return false;
                return true;
            });

            if (!filtered.length) {
                settingsLogBody.innerHTML = '<tr><td colspan="7" class="text-muted">Không có log phù hợp.</td></tr>';
                return;
            }

            settingsLogBody.innerHTML = filtered.map(item => `
                <tr>
                    <td>${escapeHtml(item.hoTenNhanVien || `NV ${item.maNhanVien || '-'}`)}</td>
                    <td>${escapeHtml(item.hanhDong || '-')}</td>
                    <td>${escapeHtml(formatLogObject(item.doiTuong, item))}</td>
                    <td>${escapeHtml(formatLogStatus(item.trangThai))}</td>
                    <td>${formatDateTime(item.thoiGian)}</td>
                    <td>${escapeHtml(item.ip || '-')}</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-outline-secondary" data-action="log-detail" data-id="${item.maNhatKyHoatDong}">
                            <i class="bi bi-eye"></i>
                        </button>
                    </td>
                </tr>
            `).join('');
        }

        function formatLogStatus(status) {
            const s = String(status || '').trim().toUpperCase();
            if (!s) return '-';
            if (s === 'SUCCESS') return 'Thành công';
            if (s === 'FAILED' || s === 'FAIL' || s === 'ERROR') return 'Thất bại';
            if (s === 'WARNING' || s === 'WARN') return 'Cảnh báo';
            if (s === 'PENDING') return 'Đang chờ';
            return status;
        }

        function formatLogObject(rawObject, item) {
            const objectText = String(rawObject || '').trim();
            if (!objectText) return '-';

            if (objectText.startsWith('ACCOUNT:')) {
                const userName = readAuditPayload(item?.duLieuMoi)?.userName
                    || readAuditPayload(item?.duLieuCu)?.userName;
                return userName ? `Tài khoản: ${userName}` : 'Tài khoản';
            }
            if (objectText.startsWith('CONGVIEC:')) return 'Công việc';
            if (objectText.startsWith('KPI:')) return 'KPI';
            if (objectText === 'SYSTEM') return 'Hệ thống';
            return objectText;
        }

        function readAuditPayload(value) {
            if (!value) return null;
            if (typeof value === 'object') return value;
            try {
                return JSON.parse(value);
            } catch {
                return null;
            }
        }

        function normalizeAuditPayload(payload) {
            if (!payload || typeof payload !== 'object') return payload;

            const hiddenKeys = new Set([
                'password', 'pass', 'token', 'securityStamp', 'concurrencyStamp',
                'normalizedEmail', 'normalizedUserName'
            ]);

            const keyMap = {
                userName: 'Tài khoản',
                email: 'Email',
                role: 'Vai trò',
                roles: 'Danh sách vai trò',
                maNhanVien: 'Mã nhân viên',
                phone: 'Số điện thoại',
                isLocked: 'Trạng thái khóa',
                accessFailedCount: 'Số lần đăng nhập sai',
                passwordStatus: 'Trạng thái mật khẩu',
                actionSource: 'Nguồn thao tác',
                performedBy: 'Người thực hiện',
                changedAt: 'Thời điểm'
            };

            const result = {};
            Object.keys(payload).forEach(key => {
                if (hiddenKeys.has(key)) return;
                const label = keyMap[key] || key;
                let val = payload[key];
                if (key === 'isLocked') {
                    val = val ? 'Đang khóa' : 'Đang hoạt động';
                }
                result[label] = val;
            });
            return result;
        }

        function stringifyAuditJson(value) {
            if (!value) {
                return '-';
            }

            const payload = readAuditPayload(value);
            if (!payload) return String(value);
            return JSON.stringify(normalizeAuditPayload(payload), null, 2);
        }


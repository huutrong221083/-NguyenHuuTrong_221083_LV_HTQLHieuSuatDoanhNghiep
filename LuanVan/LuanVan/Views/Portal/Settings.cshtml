        async function initializeClientSettingsStore() {
            const keys = Object.values(STORAGE_KEY);
            await Promise.all(keys.map(async key => {
                const res = await fetchJson(`/settings/ui/${encodeURIComponent(key)}`);
                if (res.success && res.data != null) {
                    state.clientSettingsStore[key] = JSON.stringify(res.data);
                }
            }));
        }

        const objectTypeLabel = {
            nhanvien: 'Nhân viên',
            nhom: 'Nhóm',
            phongban: 'Phòng ban',
            duan: 'Dự án'
        };

        function getKpiStorage() {
            const saved = safeParse(getClientSetting(STORAGE_KEY.kpi), defaultKpi);
            return {
                definitions: Array.isArray(saved?.definitions) ? saved.definitions : deepClone(defaultKpi.definitions),
                objects: Array.isArray(saved?.objects) ? saved.objects : deepClone(defaultKpi.objects),
                assignments: typeof saved?.assignments === 'object' && saved.assignments
                    ? saved.assignments
                    : deepClone(defaultKpi.assignments)
            };
        }

        function saveKpiStorage() {
            setClientSetting(STORAGE_KEY.kpi, JSON.stringify(state.kpi));
        }

        async function loadKpiRuntimeData() {
            // Settings ưu tiên các API /settings/*.
            // Không gọi /kpi/* ở bước init để tránh làm hỏng toàn bộ trang khi module KPI backend đang lỗi.
            const catalogItems = [];
            const employeeItems = [];
            const teamItems = [];

            const definitions = catalogItems.map(item => {
                const maKpi = Number(item?.maKpi ?? 0);
                return {
                    id: `KPI-${maKpi}`,
                    code: `KPI-${maKpi}`,
                    name: item?.tenKpi || `KPI ${maKpi}`,
                    type: item?.tenLoaiKpi || 'Khác',
                    cycle: '-',
                    status: String(item?.trangThai || '').toLowerCase() === 'active' ? 'active' : 'paused',
                    owner: 'Hệ thống',
                    description: item?.moTa || '',
                    rawId: maKpi
                };
            });

            const employeeObjects = employeeItems.map(item => ({
                id: `EMP-${Number(item?.maNhanVien ?? 0)}`,
                name: item?.hoTen || `NV ${Number(item?.maNhanVien ?? 0)}`,
                type: 'nhanvien',
                department: item?.tenPhongBan || '-'
            }));

            const teamObjects = teamItems.map(item => ({
                id: `TEAM-${Number(item?.maNhom ?? 0)}`,
                name: item?.tenNhom || `Nhóm ${Number(item?.maNhom ?? 0)}`,
                type: 'nhom',
                department: '-'
            }));

            const objectsMap = new Map();
            [...employeeObjects, ...teamObjects].forEach(obj => objectsMap.set(obj.id, obj));
            const objects = Array.from(objectsMap.values());

            const existingAssignments = (state.kpi && typeof state.kpi.assignments === 'object' && state.kpi.assignments)
                ? state.kpi.assignments
                : {};
            const assignments = {};
            definitions.forEach(def => {
                assignments[def.id] = Array.isArray(existingAssignments[def.id]) ? existingAssignments[def.id] : [];
            });

            state.kpi = { definitions, objects, assignments };
            if (!state.selectedKpiId || !definitions.some(x => x.id === state.selectedKpiId)) {
                state.selectedKpiId = definitions[0]?.id || null;
            }
            saveKpiStorage();
        }

        function getSelectedKpi() {
            return state.kpi.definitions.find(x => x.id === state.selectedKpiId) || null;
        }

        function getAssignmentsByKpiId(kpiId) {
            if (!kpiId) return [];
            if (!Array.isArray(state.kpi.assignments[kpiId])) state.kpi.assignments[kpiId] = [];
            return state.kpi.assignments[kpiId];
        }

        function getObjectById(objectId) {
            return state.kpi.objects.find(x => x.id === objectId) || null;
        }

        function getTypeBadge(type) {
            const map = {
                nhanvien: 'kpix-type-employee',
                nhom: 'kpix-type-team',
                phongban: 'kpix-type-department',
                duan: 'kpix-type-project'
            };
            const css = map[type] || 'kpix-type-employee';
            return `<span class="kpix-type-badge ${css}">${escapeHtml(objectTypeLabel[type] || type || '-')}</span>`;
        }

        function resolveStatusLabel(status) {
            return status === 'paused' ? 'Tạm dừng' : 'Active';
        }

        function targetText(targetType, targetValue) {
            return targetType === 'percent' ? `>= ${targetValue}%` : `>= ${targetValue} điểm`;
        }

        function assignmentKey(item) {
            return `${item.objectId}|${item.fromDate}|${item.toDate}`;
        }

        function isDateOverlap(aFrom, aTo, bFrom, bTo) {
            if (!aFrom || !aTo || !bFrom || !bTo) return false;
            return aFrom <= bTo && bFrom <= aTo;
        }

        function setObjectTypeFilter(type) {
            state.selectedObjectType = type || 'all';
            const objectTypeFilter = document.getElementById('kpiObjectTypeFilter');
            if (objectTypeFilter) objectTypeFilter.value = state.selectedObjectType;
            document.querySelectorAll('#kpiObjectTypeTabs button[data-object-type]').forEach(btn => {
                btn.classList.toggle('active', btn.getAttribute('data-object-type') === state.selectedObjectType);
            });
            renderKpiAssignmentPanel();
        }

        function getFilteredKpiDefinitions() {
            const search = (document.getElementById('kpiSearchInput')?.value || '').toLowerCase().trim();
            const type = (document.getElementById('kpiTypeFilter')?.value || 'all').toLowerCase();

            return state.kpi.definitions.filter(item => {
                if (type !== 'all' && item.type !== type) return false;
                if (!search) return true;
                return item.name.toLowerCase().includes(search) || item.code.toLowerCase().includes(search);
            });
        }

        function getKpiWeightSummary(kpiId) {
            const total = getAssignmentsByKpiId(kpiId).reduce((sum, x) => sum + Number(x.weight || 0), 0);
            let level = 'ok';
            if (total > 100) level = 'danger';
            else if (total < 100) level = 'warning';
            return { total, level };
        }

        function refreshKpiWeightSummary() {
            const summaryEl = document.getElementById('kpiWeightSummary');
            const warningEl = document.getElementById('kpiAssignWarning');
            if (!summaryEl || !warningEl) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                summaryEl.className = 'kpix-weight-summary';
                summaryEl.textContent = 'Tổng trọng số: 0%';
                warningEl.className = 'small mb-0 mt-2 text-muted';
                warningEl.textContent = 'Chọn KPI để bắt đầu gán đối tượng.';
                return;
            }

            const { total, level } = getKpiWeightSummary(kpi.id);
            summaryEl.className = `kpix-weight-summary ${level}`;
            summaryEl.textContent = `Tổng trọng số: ${total}%`;

            warningEl.className = 'small mb-0 mt-2';
            if (level === 'danger') {
                warningEl.classList.add('text-danger');
                warningEl.textContent = 'Tổng trọng số vượt quá 100%. Vui lòng điều chỉnh lại.';
            } else if (level === 'warning') {
                warningEl.classList.add('text-warning');
                warningEl.textContent = 'Tổng trọng số chưa đạt 100%. KPI có thể chưa cân bằng.';
            } else {
                warningEl.classList.add('text-success');
                warningEl.textContent = 'Tổng trọng số đạt 100%.';
            }
        }

        function renderKpiList() {
            const body = document.getElementById('kpiListBody');
            if (!body) return;

            const rows = getFilteredKpiDefinitions();
            if (!rows.length) {
                body.innerHTML = '<tr><td colspan="5" class="text-muted">Không tìm thấy KPI phù hợp.</td></tr>';
                return;
            }

            body.innerHTML = rows.map(item => {
                const selected = item.id === state.selectedKpiId;
                const statusCss = item.status === 'paused' ? 'text-bg-warning' : 'text-bg-success';
                return `
                    <tr class="${selected ? 'kpix-selected-row' : ''}" data-kpi-id="${item.id}">
                        <td>${escapeHtml(item.code)}</td>
                        <td>${escapeHtml(item.name)}</td>
                        <td><span class="badge text-bg-light border">${escapeHtml(item.type)}</span></td>
                        <td>${escapeHtml(item.cycle || '-')}</td>
                        <td><span class="badge ${statusCss}">${escapeHtml(resolveStatusLabel(item.status))}</span></td>
                    </tr>
                `;
            }).join('');
        }

        function renderKpiInfoTab() {
            const panel = document.getElementById('kpiInfoGrid');
            if (!panel) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                panel.innerHTML = '<p class="text-muted mb-0">Chưa chọn KPI.</p>';
                return;
            }

            const assignedCount = getAssignmentsByKpiId(kpi.id).length;
            const summary = getKpiWeightSummary(kpi.id);

            panel.innerHTML = `
                <article class="kpix-info-card"><h6>Mã KPI</h6><p>${escapeHtml(kpi.code)}</p></article>
                <article class="kpix-info-card"><h6>Loại</h6><p>${escapeHtml(kpi.type)}</p></article>
                <article class="kpix-info-card"><h6>Chu kỳ</h6><p>${escapeHtml(kpi.cycle || '-')}</p></article>
                <article class="kpix-info-card"><h6>Chủ sở hữu</h6><p>${escapeHtml(kpi.owner || '-')}</p></article>
                <article class="kpix-info-card"><h6>Số đối tượng đã gán</h6><p>${assignedCount}</p></article>
                <article class="kpix-info-card"><h6>Tổng trọng số</h6><p>${summary.total}%</p></article>
                <article class="kpix-info-card kpix-span-2"><h6>Mô tả</h6><p>${escapeHtml(kpi.description || '-')}</p></article>
            `;
        }

        function getVisibleAvailableObjects() {
            const kpi = getSelectedKpi();
            if (!kpi) return [];

            const assignedIds = new Set(getAssignmentsByKpiId(kpi.id).map(x => x.objectId));
            const type = state.selectedObjectType;
            const kw = (document.getElementById('kpiAvailableSearch')?.value || '').toLowerCase().trim();

            return state.kpi.objects
                .filter(obj => !assignedIds.has(obj.id))
                .filter(obj => type === 'all' || obj.type === type)
                .filter(obj => !kw || obj.name.toLowerCase().includes(kw) || (obj.department || '').toLowerCase().includes(kw));
        }

        function getVisibleAssignedRows() {
            const kpi = getSelectedKpi();
            if (!kpi) return [];

            const kw = (document.getElementById('kpiAssignedSearch')?.value || '').toLowerCase().trim();
            const type = state.selectedObjectType;

            return getAssignmentsByKpiId(kpi.id)
                .map(item => ({ item, obj: getObjectById(item.objectId) }))
                .filter(({ obj }) => !!obj)
                .filter(({ obj }) => type === 'all' || obj.type === type)
                .filter(({ obj }) => !kw || obj.name.toLowerCase().includes(kw) || (obj.department || '').toLowerCase().includes(kw));
        }

        function renderKpiDualListTables() {
            const availableBody = document.getElementById('kpiAvailableBody');
            const assignedBody = document.getElementById('kpiAssignedPreviewBody');
            if (!availableBody || !assignedBody) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                availableBody.innerHTML = '<tr><td colspan="4" class="text-muted">Chọn KPI để xem đối tượng chưa gán.</td></tr>';
                assignedBody.innerHTML = '<tr><td colspan="4" class="text-muted">Chọn KPI để xem danh sách đã gán.</td></tr>';
                return;
            }

            const available = getVisibleAvailableObjects();
            const assigned = getVisibleAssignedRows();

            availableBody.innerHTML = available.length
                ? available.map(obj => `
                    <tr draggable="true" data-drag-id="${obj.id}" data-list="available">
                        <td><input type="checkbox" class="kpi-available-check" data-object-id="${obj.id}" ${state.selection.available.has(obj.id) ? 'checked' : ''} /></td>
                        <td>${escapeHtml(obj.name)}</td>
                        <td>${getTypeBadge(obj.type)}</td>
                        <td>${escapeHtml(obj.department || '-')}</td>
                    </tr>
                `).join('')
                : '<tr><td colspan="4" class="text-muted">Không còn đối tượng phù hợp.</td></tr>';

            assignedBody.innerHTML = assigned.length
                ? assigned.map(({ item, obj }) => `
                    <tr draggable="true" data-drag-id="${obj.id}" data-list="assigned">
                        <td><input type="checkbox" class="kpi-assigned-check" data-object-id="${obj.id}" ${state.selection.assigned.has(obj.id) ? 'checked' : ''} /></td>
                        <td>${escapeHtml(obj.name)}</td>
                        <td>${getTypeBadge(obj.type)}</td>
                        <td>${Number(item.weight || 0)}%</td>
                    </tr>
                `).join('')
                : '<tr><td colspan="4" class="text-muted">Chưa có đối tượng được gán.</td></tr>';
        }

        function detectDuplicateAssignments(kpiId) {
            const rows = getAssignmentsByKpiId(kpiId);
            const duplicateKeys = new Set();

            for (let i = 0; i < rows.length; i += 1) {
                for (let j = i + 1; j < rows.length; j += 1) {
                    if (rows[i].objectId !== rows[j].objectId) continue;
                    if (isDateOverlap(rows[i].fromDate, rows[i].toDate, rows[j].fromDate, rows[j].toDate)) {
                        duplicateKeys.add(assignmentKey(rows[i]));
                        duplicateKeys.add(assignmentKey(rows[j]));
                    }
                }
            }
            return duplicateKeys;
        }

        function renderKpiAssignedConfigTable() {
            const body = document.getElementById('kpiAssignedConfigBody');
            if (!body) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                body.innerHTML = '<tr><td colspan="7" class="text-muted">Chọn KPI để cấu hình gán.</td></tr>';
                refreshKpiWeightSummary();
                return;
            }

            const rows = getAssignmentsByKpiId(kpi.id).map(item => ({ item, obj: getObjectById(item.objectId) })).filter(x => !!x.obj);
            if (!rows.length) {
                body.innerHTML = '<tr><td colspan="7" class="text-muted">Chưa có đối tượng được gán KPI.</td></tr>';
                refreshKpiWeightSummary();
                return;
            }

            const duplicateKeys = detectDuplicateAssignments(kpi.id);
            body.innerHTML = rows.map(({ item, obj }) => {
                const targetType = item.targetType || 'score';
                const key = assignmentKey(item);
                const duplicateClass = duplicateKeys.has(key) ? 'kpix-duplicate-row' : '';
                return `
                    <tr class="${duplicateClass}">
                        <td>${escapeHtml(obj.name)}</td>
                        <td>${getTypeBadge(obj.type)}</td>
                        <td>
                            <div class="input-group input-group-sm" title="Trọng số là mức ảnh hưởng của KPI này">
                                <input type="number" class="form-control kpi-weight-input" min="0" max="100" value="${Number(item.weight || 0)}" data-object-id="${obj.id}" />
                                <span class="input-group-text">%</span>
                            </div>
                        </td>
                        <td>
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control kpi-target-input" min="0" value="${Number(item.targetValue || 0)}" data-object-id="${obj.id}" />
                                <select class="form-select kpi-target-type" data-object-id="${obj.id}">
                                    <option value="score" ${targetType === 'score' ? 'selected' : ''}>Số</option>
                                    <option value="percent" ${targetType === 'percent' ? 'selected' : ''}>%</option>
                                </select>
                            </div>
                        </td>
                        <td>
                            <div class="kpix-time-range">
                                <input type="date" class="form-control form-control-sm kpi-from-input" value="${escapeHtml(item.fromDate || '')}" data-object-id="${obj.id}" />
                                <input type="date" class="form-control form-control-sm kpi-to-input" value="${escapeHtml(item.toDate || '')}" data-object-id="${obj.id}" />
                            </div>
                        </td>
                        <td>
                            <select class="form-select form-select-sm kpi-status-input" data-object-id="${obj.id}">
                                <option value="active" ${item.status === 'active' ? 'selected' : ''}>Active</option>
                                <option value="paused" ${item.status === 'paused' ? 'selected' : ''}>Tạm dừng</option>
                            </select>
                        </td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-secondary" data-action="edit-assign" data-object-id="${obj.id}"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger" data-action="remove-assign" data-object-id="${obj.id}"><i class="bi bi-x-circle"></i></button>
                        </td>
                    </tr>
                `;
            }).join('');

            refreshKpiWeightSummary();
        }

        function renderKpiResultTab() {
            const grid = document.getElementById('kpiResultGrid');
            const body = document.getElementById('kpiResultBody');
            if (!grid || !body) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                grid.innerHTML = '';
                body.innerHTML = '<tr><td colspan="5" class="text-muted">Chọn KPI để xem kết quả.</td></tr>';
                return;
            }

            const rows = getAssignmentsByKpiId(kpi.id).map(item => ({ item, obj: getObjectById(item.objectId) })).filter(x => !!x.obj);
            const avg = rows.length ? Math.round(rows.reduce((sum, x) => sum + Number(x.item.progress || 0), 0) / rows.length) : 0;
            const activeCount = rows.filter(x => x.item.status === 'active').length;

            grid.innerHTML = `
                <article class="kpix-result-card"><h6>Đối tượng đã gán</h6><p>${rows.length}</p></article>
                <article class="kpix-result-card"><h6>Đang active</h6><p>${activeCount}</p></article>
                <article class="kpix-result-card"><h6>Tiến độ trung bình</h6><p>${avg}%</p></article>
            `;

            body.innerHTML = rows.length ? rows.map(({ item, obj }) => {
                const progress = Number(item.progress || 0);
                const level = progress >= 85 ? 'Tốt' : (progress >= 70 ? 'Cần theo dõi' : 'Rủi ro');
                return `
                    <tr>
                        <td>${escapeHtml(obj.name)}</td>
                        <td>${getTypeBadge(obj.type)}</td>
                        <td>${escapeHtml(targetText(item.targetType, item.targetValue))}</td>
                        <td>
                            <div class="progress" style="height: 8px;">
                                <div class="progress-bar" role="progressbar" style="width: ${progress}%;" aria-valuenow="${progress}" aria-valuemin="0" aria-valuemax="100"></div>
                            </div>
                            <small>${progress}%</small>
                        </td>
                        <td>${level}</td>
                    </tr>
                `;
            }).join('') : '<tr><td colspan="5" class="text-muted">Chưa có dữ liệu kết quả.</td></tr>';
        }

        function renderKpiAnalysisTab() {
            const shell = document.getElementById('kpiAnalysisShell');
            if (!shell) return;

            const kpi = getSelectedKpi();
            if (!kpi) {
                shell.innerHTML = '<p class="text-muted mb-0">Chọn KPI để xem phân tích.</p>';
                return;
            }

            const rows = getAssignmentsByKpiId(kpi.id);
            const duplicateCount = detectDuplicateAssignments(kpi.id).size;
            const weightSummary = getKpiWeightSummary(kpi.id);
            const riskCount = rows.filter(x => Number(x.progress || 0) < 70).length;

            shell.innerHTML = `
                <article class="kpix-analysis-card">
                    <h6>Kiểm soát nghiệp vụ</h6>
                    <ul class="mb-0">
                        <li>1 KPI -> nhiều đối tượng: <strong>Đang áp dụng (${rows.length})</strong></li>
                        <li>1 đối tượng -> nhiều KPI: <strong>Cho phép</strong></li>
                        <li>Tổng trọng số hiện tại: <strong>${weightSummary.total}%</strong></li>
                        <li>Cảnh báo trùng KPI cùng thời gian: <strong>${duplicateCount > 0 ? `${duplicateCount} mục` : 'Không có'}</strong></li>
                    </ul>
                </article>
                <article class="kpix-analysis-card">
                    <h6>Nhận định</h6>
                    <p class="mb-2">Có <strong>${riskCount}</strong> đối tượng có tiến độ dưới 70% cần theo dõi.</p>
                    <p class="mb-0">Gợi ý: ưu tiên điều chỉnh trọng số cho nhóm/phòng ban có tiến độ thấp để tránh dồn áp lực vào cá nhân.</p>
                </article>
            `;
        }

        function renderKpiAssignmentPanel() {
            renderKpiDualListTables();
            renderKpiAssignedConfigTable();
            renderKpiResultTab();
            renderKpiAnalysisTab();
        }

        function renderKpiDetail() {
            const title = document.getElementById('kpiDetailTitle');
            const subtitle = document.getElementById('kpiDetailSubtitle');
            const status = document.getElementById('kpiDetailStatus');

            const kpi = getSelectedKpi();
            if (!kpi) {
                if (title) title.textContent = 'Chọn KPI để xem chi tiết';
                if (subtitle) subtitle.textContent = 'Chi tiết KPI sẽ hiển thị ở đây.';
                if (status) {
                    status.className = 'badge text-bg-secondary';
                    status.textContent = 'Chưa chọn';
                }
                renderKpiInfoTab();
                renderKpiAssignmentPanel();
                return;
            }

            if (title) title.textContent = `${kpi.code} - ${kpi.name}`;
            if (subtitle) subtitle.textContent = `${kpi.description || 'Không có mô tả.'} | Chủ sở hữu: ${kpi.owner || '-'}`;
            if (status) {
                status.className = `badge ${kpi.status === 'paused' ? 'text-bg-warning' : 'text-bg-success'}`;
                status.textContent = resolveStatusLabel(kpi.status);
            }

            renderKpiInfoTab();
            renderKpiAssignmentPanel();
        }

        function addAssignmentsToCurrentKpi(objectIds, defaults = {}) {
            const kpi = getSelectedKpi();
            if (!kpi) return;

            const rows = getAssignmentsByKpiId(kpi.id);
            const fromDate = defaults.fromDate || new Date().toISOString().slice(0, 10);
            const toDate = defaults.toDate || fromDate;
            const targetType = defaults.targetType || 'score';
            const targetValue = Number(defaults.targetValue || 90);
            const weight = Number(defaults.weight || 10);
            const status = defaults.status || 'active';

            objectIds.forEach(objectId => {
                if (rows.some(x => x.objectId === objectId)) return;
                rows.push({
                    objectId,
                    weight,
                    targetType,
                    targetValue,
                    fromDate,
                    toDate,
                    period: `${fromDate} - ${toDate}`,
                    status,
                    progress: 0
                });
            });

            saveKpiStorage();
            state.selection.available.clear();
            renderKpiDetail();
            renderKpiList();
        }

        function removeAssignmentsFromCurrentKpi(objectIds) {
            const kpi = getSelectedKpi();
            if (!kpi) return;
            state.kpi.assignments[kpi.id] = getAssignmentsByKpiId(kpi.id).filter(x => !objectIds.includes(x.objectId));
            saveKpiStorage();
            state.selection.assigned.clear();
            renderKpiDetail();
            renderKpiList();
        }

        function openKpiAssignModal() {
            const kpi = getSelectedKpi();
            if (!kpi) {
                alert('Vui lòng chọn KPI trước khi gán.');
                return;
            }

            const modalEl = document.getElementById('kpiAssignModal');
            const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
            const select = document.getElementById('kpiAssignObjectSelect');
            const errorEl = document.getElementById('kpiAssignModalError');

            const available = getVisibleAvailableObjects();
            select.innerHTML = available.map(obj => `<option value="${obj.id}">${escapeHtml(obj.name)} - ${escapeHtml(objectTypeLabel[obj.type] || obj.type)}</option>`).join('');
            errorEl.textContent = '';
            modal.show();
        }

        function handleSaveKpiAssignmentModal() {
            const select = document.getElementById('kpiAssignObjectSelect');
            const weight = Number(document.getElementById('kpiAssignWeightInput').value || 0);
            const targetType = document.getElementById('kpiAssignTargetType').value;
            const targetValue = Number(document.getElementById('kpiAssignTargetValue').value || 0);
            const fromDate = document.getElementById('kpiAssignFromDate').value;
            const toDate = document.getElementById('kpiAssignToDate').value;
            const status = document.getElementById('kpiAssignStatus').value;
            const errorEl = document.getElementById('kpiAssignModalError');

            const selected = Array.from(select.selectedOptions).map(opt => opt.value);
            if (!selected.length) {
                errorEl.textContent = 'Chọn ít nhất 1 đối tượng để gán.';
                return;
            }
            if (!fromDate || !toDate || fromDate > toDate) {
                errorEl.textContent = 'Khoảng thời gian không hợp lệ.';
                return;
            }

            errorEl.textContent = '';
            addAssignmentsToCurrentKpi(selected, { weight, targetType, targetValue, fromDate, toDate, status });
            bootstrap.Modal.getOrCreateInstance(document.getElementById('kpiAssignModal')).hide();
        }

        function createNewKpi() {
            const nowId = `KPI-${Date.now()}`;
            const newKpi = {
                id: nowId,
                code: nowId,
                name: 'KPI mới',
                type: 'hiệu suất',
                cycle: 'Tháng',
                status: 'active',
                owner: 'Admin',
                description: 'KPI mới được tạo từ giao diện quản lý KPI.'
            };
            state.kpi.definitions.unshift(newKpi);
            state.kpi.assignments[nowId] = [];
            state.selectedKpiId = nowId;
            saveKpiStorage();
            renderKpiList();
            renderKpiDetail();
        }

        function bindKpiEvents() {
            const kpiListBody = document.getElementById('kpiListBody');
            const detailTabs = document.getElementById('kpiDetailTabs');
            const objectTypeFilter = document.getElementById('kpiObjectTypeFilter');
            const objectTypeTabs = document.getElementById('kpiObjectTypeTabs');
            const availableBody = document.getElementById('kpiAvailableBody');
            const assignedPreviewBody = document.getElementById('kpiAssignedPreviewBody');
            const assignedConfigBody = document.getElementById('kpiAssignedConfigBody');

            document.getElementById('kpiSearchInput')?.addEventListener('input', renderKpiList);
            document.getElementById('kpiTypeFilter')?.addEventListener('change', renderKpiList);
            document.getElementById('btnCreateKpi')?.addEventListener('click', createNewKpi);

            kpiListBody?.addEventListener('click', (e) => {
                const row = e.target.closest('tr[data-kpi-id]');
                if (!row) return;
                state.selectedKpiId = row.getAttribute('data-kpi-id');
                state.selection.available.clear();
                state.selection.assigned.clear();
                renderKpiList();
                renderKpiDetail();
            });

            detailTabs?.addEventListener('click', (e) => {
                const btn = e.target.closest('button[data-kpi-tab]');
                if (!btn) return;
                state.selectedKpiTab = btn.getAttribute('data-kpi-tab');
                detailTabs.querySelectorAll('button[data-kpi-tab]').forEach(x => x.classList.toggle('active', x === btn));
                document.querySelectorAll('.kpix-tab-panel').forEach(panel => panel.classList.remove('active'));
                document.getElementById(`kpi-tab-${state.selectedKpiTab}`)?.classList.add('active');
            });

            objectTypeFilter?.addEventListener('change', (e) => setObjectTypeFilter(e.target.value));
            objectTypeTabs?.addEventListener('click', (e) => {
                const btn = e.target.closest('button[data-object-type]');
                if (!btn) return;
                setObjectTypeFilter(btn.getAttribute('data-object-type'));
            });

            document.getElementById('kpiAvailableSearch')?.addEventListener('input', renderKpiDualListTables);
            document.getElementById('kpiAssignedSearch')?.addEventListener('input', renderKpiDualListTables);

            document.getElementById('kpiAvailableCheckAll')?.addEventListener('change', (e) => {
                const checked = e.target.checked;
                getVisibleAvailableObjects().forEach(obj => {
                    if (checked) state.selection.available.add(obj.id);
                    else state.selection.available.delete(obj.id);
                });
                renderKpiDualListTables();
            });

            document.getElementById('kpiAssignedCheckAll')?.addEventListener('change', (e) => {
                const checked = e.target.checked;
                getVisibleAssignedRows().forEach(({ obj }) => {
                    if (checked) state.selection.assigned.add(obj.id);
                    else state.selection.assigned.delete(obj.id);
                });
                renderKpiDualListTables();
            });

            availableBody?.addEventListener('change', (e) => {
                const input = e.target.closest('.kpi-available-check');
                if (!input) return;
                const objectId = input.getAttribute('data-object-id');
                if (input.checked) state.selection.available.add(objectId);
                else state.selection.available.delete(objectId);
            });

            assignedPreviewBody?.addEventListener('change', (e) => {
                const input = e.target.closest('.kpi-assigned-check');
                if (!input) return;
                const objectId = input.getAttribute('data-object-id');
                if (input.checked) state.selection.assigned.add(objectId);
                else state.selection.assigned.delete(objectId);
            });

            document.getElementById('btnAssignObjects')?.addEventListener('click', () => {
                const ids = Array.from(state.selection.available);
                if (!ids.length) {
                    alert('Chọn đối tượng chưa gán để thêm vào KPI.');
                    return;
                }
                addAssignmentsToCurrentKpi(ids);
            });

            document.getElementById('btnUnassignObjects')?.addEventListener('click', () => {
                const ids = Array.from(state.selection.assigned);
                if (!ids.length) {
                    alert('Chọn đối tượng đã gán để gỡ khỏi KPI.');
                    return;
                }
                removeAssignmentsFromCurrentKpi(ids);
            });

            document.getElementById('btnOpenKpiAssignModal')?.addEventListener('click', openKpiAssignModal);
            document.getElementById('btnSaveKpiAssignment')?.addEventListener('click', handleSaveKpiAssignmentModal);

            assignedConfigBody?.addEventListener('input', (e) => {
                const kpi = getSelectedKpi();
                if (!kpi) return;
                const objectId = e.target.getAttribute('data-object-id');
                if (!objectId) return;

                const row = getAssignmentsByKpiId(kpi.id).find(x => x.objectId === objectId);
                if (!row) return;

                if (e.target.classList.contains('kpi-weight-input')) row.weight = Number(e.target.value || 0);
                if (e.target.classList.contains('kpi-target-input')) row.targetValue = Number(e.target.value || 0);
                if (e.target.classList.contains('kpi-from-input')) row.fromDate = e.target.value;
                if (e.target.classList.contains('kpi-to-input')) row.toDate = e.target.value;
                if (e.target.classList.contains('kpi-target-type')) row.targetType = e.target.value;
                if (e.target.classList.contains('kpi-status-input')) row.status = e.target.value;

                row.period = `${row.fromDate || '-'} - ${row.toDate || '-'}`;
                saveKpiStorage();
                renderKpiAssignedConfigTable();
                renderKpiResultTab();
                renderKpiAnalysisTab();
            });

            assignedConfigBody?.addEventListener('click', (e) => {
                const removeButton = e.target.closest('button[data-action="remove-assign"]');
                if (removeButton) {
                    removeAssignmentsFromCurrentKpi([removeButton.getAttribute('data-object-id')]);
                    return;
                }

                const editButton = e.target.closest('button[data-action="edit-assign"]');
                if (editButton) {
                    const row = editButton.closest('tr');
                    row?.querySelector('.kpi-weight-input')?.focus();
                }
            });

            const availableDropZone = document.getElementById('kpiAvailableDropZone');
            const assignedDropZone = document.getElementById('kpiAssignedDropZone');

            function bindDragSource(host) {
                host?.addEventListener('dragstart', (e) => {
                    const row = e.target.closest('tr[data-drag-id]');
                    if (!row) return;
                    state.draggingObjectId = row.getAttribute('data-drag-id');
                    e.dataTransfer?.setData('text/plain', state.draggingObjectId);
                });
            }

            function bindDropTarget(host, targetList) {
                host?.addEventListener('dragover', (e) => {
                    e.preventDefault();
                    host.classList.add('kpix-drop-active');
                });
                host?.addEventListener('dragleave', () => host.classList.remove('kpix-drop-active'));
                host?.addEventListener('drop', (e) => {
                    e.preventDefault();
                    host.classList.remove('kpix-drop-active');
                    const objectId = e.dataTransfer?.getData('text/plain') || state.draggingObjectId;
                    if (!objectId) return;
                    if (targetList === 'assigned') addAssignmentsToCurrentKpi([objectId]);
                    if (targetList === 'available') removeAssignmentsFromCurrentKpi([objectId]);
                    state.draggingObjectId = null;
                });
            }

            bindDragSource(availableBody);
            bindDragSource(assignedPreviewBody);
            bindDropTarget(availableDropZone, 'available');
            bindDropTarget(assignedDropZone, 'assigned');
        }

        async function initKpiModule() {
            state.kpi = getKpiStorage();
            await loadKpiRuntimeData();
            state.selectedKpiId = state.kpi.definitions[0]?.id || null;
            state.selectedObjectType = 'all';
            renderKpiList();
            renderKpiDetail();
            bindKpiEvents();
        }

        function setRangeValue(inputId, valueId, value) {
            const input = document.getElementById(inputId);
            const label = document.getElementById(valueId);
            if (!input || !label) return;
            input.value = Number(value);
            label.textContent = `${Number(value)}%`;
        }

        function bindRangeLabel(inputId, valueId) {
            const input = document.getElementById(inputId);
            const label = document.getElementById(valueId);
            if (!input || !label) return;
            const sync = () => label.textContent = `${Number(input.value || 0)}%`;
            input.addEventListener('input', sync);
            sync();
        }

        function getCheckedRadioValue(name, fallback) {
            return document.querySelector(`input[name="${name}"]:checked`)?.value || fallback;
        }

        function setCheckedRadioValue(name, value) {
            const target = document.querySelector(`input[name="${name}"][value="${value}"]`)
                || document.querySelector(`input[name="${name}"]`);
            if (target) target.checked = true;
        }

        function getPerformancePresetByLevel(level) {
            const map = {
                fast: { estimators: 60, maxDepth: 6 },
                balanced: { estimators: 100, maxDepth: 10 },
                deep: { estimators: 180, maxDepth: 16 }
            };
            return map[level] || map.balanced;
        }

        function resolveAnalysisLevelFromHyperParams(estimators, maxDepth) {
            if (Number(estimators) >= 160 || Number(maxDepth) >= 14) return 'deep';
            if (Number(estimators) <= 70 || Number(maxDepth) <= 7) return 'fast';
            return 'balanced';
        }

        function getSuggestionTemplateByTone(tone) {
            const templates = {
                short: 'Nhân viên {Ten} có nguy cơ trễ hạn do {LyDo}. Đề xuất: {GiaiPhap}',
                detailed: 'Nhân viên {Ten} đang có nguy cơ trễ hạn vì {LyDo}. Mức độ ảnh hưởng: {MucDo}. Đề xuất hành động: {GiaiPhap}. Thời điểm cần theo dõi lại: {ThoiDiem}.',
                strong_warning: 'CẢNH BÁO: Nhân viên {Ten} có nguy cơ trễ hạn cao do {LyDo}. Cần xử lý ngay: {GiaiPhap}.'
            };
            return templates[tone] || templates.short;
        }

        function syncSuggestionTemplatePreview() {
            const tone = document.getElementById('aiSuggestionTone')?.value || 'short';
            const template = getSuggestionTemplateByTone(tone);
            const preview = document.getElementById('aiSuggestionTemplate');
            if (preview) preview.value = template;
        }

        function bindAiTabNavigation() {
            const tabNav = document.getElementById('aiTabNav');
            if (!tabNav) return;

            tabNav.addEventListener('click', (e) => {
                const button = e.target.closest('button[data-ai-tab]');
                if (!button) return;
                const tab = button.getAttribute('data-ai-tab');

                tabNav.querySelectorAll('button[data-ai-tab]').forEach(btn => {
                    btn.classList.toggle('active', btn === button);
                });

                document.querySelectorAll('.aix-tab-panel').forEach(panel => panel.classList.remove('active'));
                document.getElementById(`ai-tab-${tab}`)?.classList.add('active');
            });
        }


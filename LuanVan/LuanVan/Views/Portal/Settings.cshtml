                'btnSaveKpiMaster',
                'btnCreateKpi',
                'btnAssignObjects',
                'btnUnassignObjects',
                'btnOpenKpiAssignModal',
                'btnSaveKpiAssignment'
            ];

            writeButtonIds.forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                el.disabled = true;
                el.classList.add('disabled');
                el.title = 'Bạn chỉ có quyền xem Cài đặt hệ thống.';

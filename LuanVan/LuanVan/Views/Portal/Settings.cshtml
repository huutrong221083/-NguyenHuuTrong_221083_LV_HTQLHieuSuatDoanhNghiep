            document.getElementById('logDetailAction').textContent = item.hanhDong || '-';
            document.getElementById('logDetailObject').textContent = formatLogObject(item.doiTuong, item);
            document.getElementById('logDetailTime').textContent = formatDateTime(item.thoiGian);
            document.getElementById('logDetailStatus').textContent = formatLogStatus(item.trangThai);
            document.getElementById('logDetailIp').textContent = item.ip || '-';
            document.getElementById('logDetailOld').textContent = stringifyAuditJson(item.duLieuCu);

                    <div class="kpi-body">
                        <div class="kpi-label">${card.label}</div>
                        <div class="kpi-value">${card.value}</div>
                        <div class="kpi-change ${card.delta >= 0 ? 'up' : 'down'}">${card.delta >= 0 ? '+' : ''}${card.delta}% so với tháng trước</div>
                    </div>
                    ${renderSparklines(card.trend)}
                </article>
            `).join('');
        }

        function progressTone(progress) {
            if (progress >= 75) return 'good';
            if (progress >= 45) return 'warn';
            return 'bad';
        }

        function deadlineTag(daysLeft) {
            if (daysLeft <= 2) return '<span class="pill danger"><2 ngày</span>';
            if (daysLeft <= 5) return '<span class="pill warning">3-5 ngày</span>';
            return '<span class="pill ok">On track</span>';
        }

        function statusTag(status) {
            const normalized = (status || '').toLowerCase();
            if (normalized === 'done') return '<span class="pill ok">Hoàn thành</span>';
            if (normalized === 'doing') return '<span class="pill info">Đang thực hiện</span>';
            return '<span class="pill warning">Chưa bắt đầu</span>';
        }


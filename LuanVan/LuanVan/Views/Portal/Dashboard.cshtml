                return;
            }

            taskBody.innerHTML = tasks.map(task => `
                <tr class="task-row-clickable" data-task="${task.name}">
                    <td>
                        <div title="${task.aiHint}">${task.name}</div>
                    </td>
                    <td>${task.owner}</td>
                    <td>

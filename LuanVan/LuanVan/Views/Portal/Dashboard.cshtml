                        if (key.includes('gần') || key.includes('deadline')) return { cls: 'warning', icon: '⏰' };
                        if (key.includes('kpi') || key.includes('kém') || key.includes('thấp')) return { cls: 'amber', icon: '📊' };
                        if (key.includes('ai') || key.includes('dự đoán') || key.includes('gợi ý')) return { cls: 'deep-violet', icon: '🤖' };
                        return { cls: 'info', icon: 'ℹ️' };

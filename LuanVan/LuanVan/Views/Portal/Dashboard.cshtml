        }

        function mapAdminPayload(apiData) {
            const tongQuan = apiData.tongQuan || {};
            const month = dashMonth.value;
            const year = dashYear.value;
            const selectedDepartment = dashDepartment.value;
            const selectedTeam = dashTeam ? dashTeam.value : '';
            const selectedProject = dashProject ? dashProject.value : '';

            const filterDepartments = (apiData.filters && apiData.filters.departments) || (apiData.kpiTheoPhongBan || []).map(x => ({ id: x.maPhongBan, label: x.tenPhongBan || `phòng ${x.maPhongBan}` }));
            dashDepartment.innerHTML = '<option value="">Tất cả phòng ban</option>' + filterDepartments.map(x => `<option value="${x.id}">${x.label}</option>`).join('');
            dashDepartment.value = selectedDepartment || (apiData.filters && apiData.filters.selectedDepartmentId ? String(apiData.filters.selectedDepartmentId) : '');

            if (dashTeam) {
                const teams = (apiData.filters && apiData.filters.teams) || [];
                dashTeam.innerHTML = '<option value="">Tất cả nhóm</option>' + teams.map(x => `<option value="${x.id}">${x.label}</option>`).join('');
                dashTeam.value = selectedTeam || (apiData.filters && apiData.filters.selectedTeamId ? String(apiData.filters.selectedTeamId) : '');
            }
            if (dashProject) {
                const projects = (apiData.filters && apiData.filters.projects) || [];
                dashProject.innerHTML = '<option value="">Tất cả dự án</option>' + projects.map(x => `<option value="${x.id}">${x.label}</option>`).join('');
                dashProject.value = selectedProject || (apiData.filters && apiData.filters.selectedProjectId ? String(apiData.filters.selectedProjectId) : '');
            }
            updateDepartmentFilterStatus();

            const sourceCards = apiData.summaryCards || [];
            const cards = sourceCards.length > 0
                ? sourceCards.map((c, idx) => ({
                    label: c.label || c.key || 'Chỉ số',
                    value: c.value || '0',
                    icon: ['bi bi-people-fill', 'bi bi-kanban-fill', 'bi bi-list-task', 'bi bi-alarm-fill', 'bi bi-graph-up-arrow', 'bi bi-shield-exclamation'][idx] || 'bi bi-graph-up',
                    theme: ['theme-blue', 'theme-violet', 'theme-cyan', 'theme-red', 'theme-amber', 'theme-deep-violet'][idx] || 'theme-cyan',
                    delta: 0,
                    trend: [Number((c.value || '0').toString().replace('%', '').split(' ')[0]) || 0]
                }))
                : [
                    { label: 'Nhân sự quản lý', value: tongQuan.soNhanVien || 0, icon: 'bi bi-people-fill', theme: 'theme-blue', delta: 0, trend: [tongQuan.soNhanVien || 0] },
                    { label: 'Dự án đang chạy', value: tongQuan.soDuAnDangChay || 0, icon: 'bi bi-kanban-fill', theme: 'theme-violet', delta: 0, trend: [tongQuan.soDuAnDangChay || 0] },
                    { label: 'Công việc đang làm', value: tongQuan.soTaskDangLam || 0, icon: 'bi bi-list-task', theme: 'theme-cyan', delta: 0, trend: [tongQuan.soTaskDangLam || 0] },
                    { label: 'Công việc trễ hạn', value: tongQuan.soTaskTreHan || 0, icon: 'bi bi-alarm-fill', theme: 'theme-red', delta: 0, trend: [tongQuan.soTaskTreHan || 0] },
                    { label: 'KPI trung bình', value: `${Number(tongQuan.kpiTrungBinh || 0).toFixed(1)}%`, icon: 'bi bi-graph-up-arrow', theme: 'theme-amber', delta: 0, trend: [Number(tongQuan.kpiTrungBinh || 0)] }
                ];

            const barLabels = apiData.kpiTheoPhongBan.map(x => x.tenPhongBan || 'Chưa rõ');
            const barValues = apiData.kpiTheoPhongBan.map(x => x.kpi || 0);

            const lineLabels = ((apiData.kpiTrend && apiData.kpiTrend.labels) || (apiData.topNhanVien || []).map(x => x.hoTen || `NV ${x.maNhanVien}`));
            const lineValues = ((apiData.kpiTrend && apiData.kpiTrend.values) || (apiData.topNhanVien || []).map(x => x.kpi || 0));

            const tasks = (apiData.urgentTasks || apiData.taskTreHan || []).slice(0, 12).map(task => ({
                name: task.tenCongViec || task.tenTask || '(Không rõ task)',
                owner: task.nguoiPhuTrach || (task.nhanViens || []).join(', ') || '(Chưa gán)',
                deadline: task.deadline ? new Date(task.deadline).toLocaleDateString('vi-VN') : '-',
                daysLeft: task.deadline ? Math.ceil((new Date(task.deadline) - new Date()) / 86400000) : 99,
                progress: Number(task.tienDo || Math.max(0, 100 - ((task.soNgayTre || 0) * 12))),
                status: task.trangThai || (task.soNgayTre > 0 ? 'Quá hạn' : 'Đang thực hiện'),
                aiHint: task.priorityReason || 'Cần theo dõi xử lý'
            }));

            const aiEntries = (apiData.insights || []).map(x => ({
                type: x.type || 'info',
                icon: x.type === 'danger' ? '⛔' : (x.type === 'warning' ? '⚠️' : '💡'),
                title: x.title || 'Gợi ý hệ thống',
                content: x.content || ''
            }));

            const timeline = [
                ...((apiData.activityTimeline || []).map(x => ({
                    avatar: (x.actor || 'HT').slice(0, 2).toUpperCase(),
                    actor: x.actor || 'Hệ thống',
                    action: x.action || '',
                    time: x.time ? new Date(x.time).toLocaleString('vi-VN') : `${month}/${year}`
                })))
            ];

                    return {
                cards,
                bar: { labels: barLabels, values: barValues, label: 'KPI theo phòng ban' },
                line: { labels: lineLabels.length ? lineLabels : ['Không có dữ liệu'], values: lineValues.length ? lineValues : [0], label: 'KPI top nhân viên' },
                pie: apiData.taskStatusDistribution
                    ? {
                        labels: ['Chưa bắt đầu', 'Đang thực hiện', 'Chờ duyệt', 'Hoàn thành', 'Quá hạn'],
                        values: [
                            apiData.taskStatusDistribution.chuaBatDau || 0,
                            apiData.taskStatusDistribution.dangThucHien || 0,
                            apiData.taskStatusDistribution.choDuyet || 0,
                            apiData.taskStatusDistribution.hoanThanh || 0,
                            apiData.taskStatusDistribution.quaHan || 0
                        ]
                    }
                    : { labels: ['Hoàn thành', 'Đang thực hiện', 'Overdue'], values: [tongQuan.soTaskHoanThanh || 0, tongQuan.soTaskDangLam || 0, tongQuan.soTaskTreHan || 0] },
                    risk: {
                        labels: ['Mức rủi ro'],
                        values: [Number((apiData.risk && apiData.risk.score) || 0)],
                        label: (apiData.risk && apiData.risk.label) || 'Mức rủi ro'
                    },
                    employeeDist: {
                        labels: ['Hoàn thành', 'Đang thực hiện', 'Quá hạn', 'Chờ duyệt', 'Chưa bắt đầu', 'Tạm ngừng'],
                        values: apiData.taskStatusDistribution
                            ? [
                                apiData.taskStatusDistribution.hoanThanh || 0,
                                apiData.taskStatusDistribution.dangThucHien || 0,
                                apiData.taskStatusDistribution.quaHan || 0,
                                apiData.taskStatusDistribution.choDuyet || 0,
                                apiData.taskStatusDistribution.chuaBatDau || 0,
                                apiData.taskStatusDistribution.tamNgung || 0
                            ]
                            : [56, 24, 6, 12, 8, 0]
                    },
                    // topRisk removed
                tasks,
                aiEntries,
                timeline,
                attentionEmployees: apiData.attentionEmployees || [],
                teamWorkload: apiData.teamWorkload || [],
                pendingApprovals: apiData.pendingApprovals || null,
                projectHealth: apiData.projectHealth || [],
                insightSource: apiData.insightSource || 'fallback',
                ownerHeader: 'Nhân viên'
            };
        }

        function mapEmployeePayload(apiData) {
            const tongQuan = apiData.tongQuan || {};
            const ctx = apiData.nhanVienContext || {};
            const myName = ctx.hoTen || 'Tôi';
            const myDepartment = ctx.tenPhongBan || (ctx.maPhongBan ? `Phòng ${ctx.maPhongBan}` : 'Chưa phân phòng ban');
            const myTeams = Array.isArray(ctx.nhomThamGia) ? ctx.nhomThamGia : [];
            const myAlerts = Array.isArray(ctx.canhBaoCaNhan) ? ctx.canhBaoCaNhan : [];
            const myKpi = Number(ctx.kpiCaNhan || tongQuan.kpiTrungBinh || 0);
            const deptKpi = Number((apiData.kpiTheoPhongBan && apiData.kpiTheoPhongBan[0] && apiData.kpiTheoPhongBan[0].kpi) || myKpi);

            const cards = [
                { label: 'KPI cá nhân', value: `${myKpi.toFixed(1)}%`, icon: 'bi bi-person-check-fill', theme: 'theme-blue', delta: 0, trend: [myKpi] },
                { label: 'Phòng ban của tôi', value: myDepartment, icon: 'bi bi-building', theme: 'theme-violet', delta: 0, trend: [deptKpi] },
                { label: 'Nhóm đang tham gia', value: myTeams.length, icon: 'bi bi-people-fill', theme: 'theme-cyan', delta: 0, trend: [myTeams.length] },
                { label: 'Công việc đang làm', value: Number(tongQuan.soTaskDangLam || 0), icon: 'bi bi-list-task', theme: 'theme-amber', delta: 0, trend: [Number(tongQuan.soTaskDangLam || 0)] },
                { label: 'Công việc trễ hạn', value: Number(tongQuan.soTaskTreHan || 0), icon: 'bi bi-alarm-fill', theme: 'theme-red', delta: 0, trend: [Number(tongQuan.soTaskTreHan || 0)] },
                { label: 'Cảnh báo chưa đọc', value: Number(ctx.soCanhBaoChuaDoc || 0), icon: 'bi bi-bell-fill', theme: 'theme-deep-violet', delta: 0, trend: [Number(ctx.soCanhBaoChuaDoc || 0)] }
            ];

            const barLabels = ['KPI cá nhân', 'KPI phòng ban'];
            const barValues = [myKpi, deptKpi];

            const lineLabels = ['KPI cá nhân', 'Mục tiêu nội bộ', 'KPI phòng ban'];
            const lineValues = [myKpi, Math.max(75, myKpi), deptKpi];

            const tasks = (apiData.taskTreHan || []).slice(0, 6).map(task => ({
                name: task.tenTask || '(Không rõ task)',
                owner: myName,
                deadline: task.deadline ? new Date(task.deadline).toLocaleDateString('vi-VN') : '-',
                daysLeft: (task.soNgayTre || 0) > 0 ? 0 : 4,
                progress: (task.soNgayTre || 0) > 0 ? 35 : 75,
                status: (task.soNgayTre || 0) > 0 ? 'Đang thực hiện' : 'Đúng tiến độ',
                aiHint: (task.soNgayTre || 0) > 0
                    ? `Cảnh báo cá nhân: trễ hạn ${task.soNgayTre} ngày.`
                    : 'Cảnh báo cá nhân: cần theo dõi deadline gần nhất.'
            }));

            const aiEntries = myAlerts.length > 0
                ? myAlerts.slice(0, 3).map(item => ({
                    type: item.daDoc ? 'info' : 'warn',
                    icon: item.daDoc ? '🔔' : '⚠️',
                    title: item.loai || 'Cảnh báo cá nhân',
                    content: item.noiDung || 'Không có nội dung.'
                }))
                : [{ type: 'info', icon: '✅', title: 'Không có cảnh báo mới', content: 'Hiện chưa có cảnh báo cá nhân cần xử lý.' }];

            const timeline = [
                {
                    avatar: (myName || 'NV').slice(0, 2).toUpperCase(),
                    actor: myName,
                    action: `KPI cá nhân tháng này đạt ${myKpi.toFixed(1)}%.`,
                    time: 'Kỳ hiện tại'
                },
                {
                    avatar: 'PB',
                    actor: 'Phòng ban',
                    action: `Bạn đang tham gia: ${myDepartment}.`,
                    time: 'Hiện tại'
                },
                {
                    avatar: 'NH',
                    actor: 'Nhóm',
                    action: myTeams.length > 0
                        ? `Đang tham gia ${myTeams.length} nhóm: ${myTeams.join(', ')}.`
                        : 'Hiện chưa tham gia nhóm nào.',
                    time: 'Hiện tại'
                },
                ...myAlerts.slice(0, 2).map(item => ({
                    avatar: 'CB',
                    actor: item.loai || 'Cảnh báo',
                    action: item.noiDung || 'Không có nội dung.',
                    time: item.thoiGian ? new Date(item.thoiGian).toLocaleString('vi-VN') : 'Gần đây'
                }))
            ];

            return {
                cards,
                bar: { labels: barLabels, values: barValues, label: 'Đánh giá cá nhân / phòng ban' },
                line: { labels: lineLabels, values: lineValues, label: 'Hiệu suất cá nhân' },
                pie: {
                    labels: ['Task hoàn thành', 'Task đang làm', 'Task trễ hạn'],
                    values: [Number(tongQuan.soTaskHoanThanh || 0), Number(tongQuan.soTaskDangLam || 0), Number(tongQuan.soTaskTreHan || 0)]
                },
                risk: {
                    labels: ['Mức ổn định', 'Mức cảnh báo', 'Mức trễ hạn'],
                    values: [Math.max(0, 100 - Number(tongQuan.soTaskTreHan || 0) * 10), Number(ctx.soCanhBaoChuaDoc || 0) * 10, Number(tongQuan.soTaskTreHan || 0) * 12],
                    label: 'Rủi ro cá nhân (%)'
                },
                employeeDist: {
                    labels: ['Nhóm tham gia', 'Cảnh báo chưa đọc', 'Task trễ hạn', 'Task đang làm'],
                    values: [myTeams.length, Number(ctx.soCanhBaoChuaDoc || 0), Number(tongQuan.soTaskTreHan || 0), Number(tongQuan.soTaskDangLam || 0)]
                },
                tasks,
                aiEntries,
                timeline,
                ownerHeader: 'Cá nhân'
            };
        }

        function getDashboardQueryParams() {
            const now = new Date();
            const monthValue = dashMonth ? dashMonth.value : '';
            return {
                month: monthValue ? Number(monthValue) : null,
                year: dashYear ? Number(dashYear.value) : now.getFullYear(),
                department: dashDepartment ? dashDepartment.value : '',
                team: dashTeam ? dashTeam.value : '',
                project: dashProject ? dashProject.value : ''
            };
        }

        async function loadAdminFromApi() {
            const { month, year, department, team, project } = getDashboardQueryParams();

            const monthQuery = month ? `thang=${month}&` : '';
            const departmentQuery = department ? `&maPhongBan=${encodeURIComponent(department)}` : '';
            const teamQuery = team ? `&maNhom=${encodeURIComponent(team)}` : '';
            const projectQuery = project ? `&maDuAn=${encodeURIComponent(project)}` : '';
            const response = await fetch(`/dashboard?${monthQuery}nam=${year}&maKpi=1&top=5${departmentQuery}${teamQuery}${projectQuery}`);
            const rawText = await response.text();
            let payload = null;
            if (rawText && rawText.trim().length > 0) {
                try {
                    payload = JSON.parse(rawText);
                } catch {
                    if (!response.ok) {
                        throw new Error(`API dashboard trả lỗi ${response.status}.`);
                    }
                    throw new Error('Dữ liệu dashboard không hợp lệ.');
                }
            }

            if (!response.ok) {
                const serverMessage = payload && payload.message ? payload.message : `API dashboard trả lỗi ${response.status}.`;
                throw new Error(serverMessage);
            }

            if (!payload) {
                throw new Error('API dashboard không trả dữ liệu.');
            }

            if (!payload.success) {
                throw new Error(payload.message || 'Không tải được dữ liệu dashboard');
            }
            const isEmployeePayload = roleKey === 'employee' || payload.data.isPersonalDashboard === true;
            return isEmployeePayload ? mapEmployeePayload(payload.data) : mapAdminPayload(payload.data);
        }

        async function loadDashboardData() {
            return await loadAdminFromApi();
        }

        async function renderDashboard() {
            try {
                currentDashPayload = await loadDashboardData();

                if (isEmployeeDashboard) {
                    if (dashboardFilterBar) dashboardFilterBar.style.display = 'none';
                    renderEmployeeDashboard(currentDashPayload);
                    return;
                }

                if (taskOwnerHeader) {
                    taskOwnerHeader.textContent = currentDashPayload.ownerHeader;
                }

                if (dashboardFilterBar) dashboardFilterBar.style.display = '';
                if (dashboardMainGrid) dashboardMainGrid.style.display = '';
                if (dashboardBottomGrid) dashboardBottomGrid.style.display = '';
                if (employeeDashboardGrid) employeeDashboardGrid.style.display = 'none';

                barChartTitle.textContent = currentDashPayload.bar.label;
                lineChartTitle.textContent = currentDashPayload.line.label;
                if (insightPanelTitle) {
                    insightPanelTitle.textContent = currentDashPayload.insightSource === 'ai' ? 'Phân tích AI' : 'Gợi ý hệ thống';
                }

                renderKpiCards(currentDashPayload.cards);
                renderCharts(currentDashPayload);
                renderTaskTable(currentDashPayload.tasks);
                renderAiPanel(currentDashPayload.aiEntries);
                renderTimeline(currentDashPayload.timeline);
                renderAttentionEmployees(currentDashPayload.attentionEmployees);
                renderWorkload(currentDashPayload.teamWorkload);
                renderPendingApprovals(currentDashPayload.pendingApprovals);
                renderProjectHealth(currentDashPayload.projectHealth);
            } catch (error) {
                if (isEmployeeDashboard) {
                    if (employeeEvaluationContent) {
                        employeeEvaluationContent.innerHTML = `<div class="text-danger">Lỗi tải dữ liệu: ${error.message}</div>`;
                    }
                    if (employeeOrgContent) {
                        employeeOrgContent.innerHTML = '<div class="text-danger">Không thể tải dữ liệu phòng ban và nhóm.</div>';
                    }
                    if (employeeAlertContent) {
                        employeeAlertContent.innerHTML = '<div class="text-danger">Không thể tải cảnh báo cá nhân.</div>';
                    }
                    return;
                }

                if (kpiGrid) kpiGrid.innerHTML = '<article class="panel text-danger">Không thể tải dữ liệu dashboard. Vui lòng thử lại.</article>';
                if (taskBody) taskBody.innerHTML = `<tr><td colspan="5" class="text-danger">Lỗi tải dữ liệu: ${error.message}</td></tr>`;
                if (aiInsightList) aiInsightList.innerHTML = `<p class="text-danger mb-0">${error.message}</p>`;
                if (activityTimeline) activityTimeline.innerHTML = '<div class="timeline-item muted text-danger">Không tải được timeline.</div>';
                if (attentionEmployeeBody) attentionEmployeeBody.innerHTML = '<tr><td colspan="6" class="text-danger">Không tải được dữ liệu nhân sự cần chú ý.</td></tr>';
                if (workloadList) workloadList.innerHTML = '<div class="timeline-item muted text-danger">Không tải được dữ liệu workload.</div>';
                if (pendingApprovalGrid) pendingApprovalGrid.innerHTML = '<article class="panel text-danger">Không tải được pending approvals.</article>';
                if (projectHealthBody) projectHealthBody.innerHTML = '<tr><td colspan="6" class="text-danger">Không tải được dữ liệu tiến độ dự án.</td></tr>';
            }
        }

        if (dashMonth) {
            dashMonth.addEventListener('change', () => {
                updateDepartmentFilterStatus();
                renderDashboard();
            });
        }
        if (dashYear) {
            dashYear.addEventListener('change', () => {
                updateDepartmentFilterStatus();
                renderDashboard();
            });
        }
        if (dashDepartment) {
            dashDepartment.addEventListener('change', () => {
                updateDepartmentFilterStatus();
                renderDashboard();
            });
        }
        if (dashTeam) {
            dashTeam.addEventListener('change', () => {
                updateDepartmentFilterStatus();
                renderDashboard();
            });
        }
        if (dashProject) {
            dashProject.addEventListener('change', () => {
                updateDepartmentFilterStatus();
                renderDashboard();
            });
        }
        if (btnRefreshDash) {
            window.UiButtonLoading?.bind(btnRefreshDash, renderDashboard, { profile: 'reload' });
        }
        if (btnExportDash) {
            btnExportDash.addEventListener('click', () => {
                const { month, year, department, team, project } = getDashboardQueryParams();
                const params = new URLSearchParams({ nam: String(year), maKpi: '1', top: '5' });
                if (month) params.set('thang', String(month));
                if (department) params.set('maPhongBan', department);
                if (team) params.set('maNhom', team);
                if (project) params.set('maDuAn', project);

                const downloadAction = async () => {
                    try {
                        const res = await fetch(`/dashboard/export?${params.toString()}`, { method: 'GET', credentials: 'same-origin' });
                        if (!res.ok) {
                            const txt = await res.text();
                            window.UiToast?.error(txt || 'Lỗi khi xuất báo cáo');
                            return;
                        }

                        const blob = await res.blob();
                        const disposition = res.headers.get('content-disposition') || '';
                        let fileName = `dashboard_export_${new Date().toISOString().slice(0,19).replace(/[:T]/g, '_')}.xlsx`;
                        const match = /filename="?([^";]+)"?/.exec(disposition);
                        if (match) fileName = match[1];

                        const url = URL.createObjectURL(blob);
                        const a = document.createElement('a');
                        a.href = url;
                        a.download = fileName;
                        document.body.appendChild(a);
                        a.click();
                        a.remove();
                        URL.revokeObjectURL(url);

                        window.UiToast?.success('Tải xuống hoàn tất');
                    } catch (err) {
                        console.error(err);
                        window.UiToast?.error('Lỗi khi tải báo cáo');
                    }
                };

                if (window.UiButtonLoading?.run) {
                    window.UiButtonLoading.run(btnExportDash, downloadAction, { profile: 'export' });
                } else {
                    downloadAction();
                }
            });
        }

        initFilterOptions();
        renderDashboard();

        setInterval(() => {
            renderDashboard();
        }, 60000);
    </script>
}







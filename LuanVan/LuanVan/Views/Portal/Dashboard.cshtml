@section Scripts {
    <script>
        const role = '@role';
        const roleKey = '@roleKey';
        const isEmployeeDashboard = @isEmployeeDashboard.ToString().ToLowerInvariant();
        const charts = [];
        const commonScale = {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                y: {
                    beginAtZero: true,
                    max: 100,
                    ticks: { stepSize: 20 }
                }
            }
        };

        const kpiGrid = document.getElementById('dashboardKpiGrid');
        const dashboardFilterBar = document.getElementById('dashboardFilterBar');
        const dashboardMainGrid = document.getElementById('dashboardMainGrid');
        const dashboardBottomGrid = document.getElementById('dashboardBottomGrid');
        const employeeDashboardGrid = document.getElementById('employeeDashboardGrid');
        const employeeEvaluationContent = document.getElementById('employeeEvaluationContent');
        const employeeOrgContent = document.getElementById('employeeOrgContent');
        const employeeAlertContent = document.getElementById('employeeAlertContent');
        const taskBody = document.getElementById('deadlineTaskBody');
        const activityTimeline = document.getElementById('activityTimeline');
        const aiInsightList = document.getElementById('aiInsightList');
        const taskOwnerHeader = document.getElementById('taskOwnerHeader');
        const attentionEmployeeBody = document.getElementById('attentionEmployeeBody');
        const workloadList = document.getElementById('workloadList');
        const pendingApprovalGrid = document.getElementById('pendingApprovalGrid');
        const projectHealthBody = document.getElementById('projectHealthBody');
        const donutLegendGrid = document.getElementById('donutLegendGrid');

        const dashMonth = document.getElementById('dashMonth');
        const dashYear = document.getElementById('dashYear');
        const dashDepartment = document.getElementById('dashDepartment');
        const dashTeam = document.getElementById('dashTeam');
        const dashProject = document.getElementById('dashProject');
        const btnRefreshDash = document.getElementById('btnRefreshDash');
        const btnExportDash = document.getElementById('btnExportDash');
        const dashboardFilterStatus = document.getElementById('dashboardFilterStatus');

        const barChartTitle = document.getElementById('barChartTitle');
        const lineChartTitle = document.getElementById('lineChartTitle');
        const insightPanelTitle = document.getElementById('insightPanelTitle');

        let currentDashPayload = null;
        let employeeDonutChart = null;

        function destroyCharts() {
            while (charts.length > 0) {
                const chart = charts.pop();
                chart.destroy();
            }
            if (employeeDonutChart) {
                employeeDonutChart.destroy();
                employeeDonutChart = null;
            }
            if (donutLegendGrid) {
                donutLegendGrid.innerHTML = '';
            }
        }

        function renderDonutLegend(labels, colors) {
            if (!donutLegendGrid) return;
            const items = (labels || []).map((label, idx) => {
                const color = colors[idx] || '#9CA3AF';
                return `<span class="legend-item"><i class="legend-swatch" style="background:${color}"></i>${label}</span>`;
            });
            donutLegendGrid.innerHTML = items.join('');
        }

        function updateDepartmentFilterStatus() {
            if (!dashboardFilterStatus) return;
            const selectedOption = dashDepartment.selectedOptions && dashDepartment.selectedOptions.length > 0
                ? dashDepartment.selectedOptions[0]
                : null;
            const label = selectedOption ? selectedOption.textContent.trim() : 'Tất cả phòng ban';
            dashboardFilterStatus.textContent = `Đang xem: ${label}`;
        }

        function initFilterOptions() {
            if (isEmployeeDashboard) {
                return;
            }

            if (!dashMonth || !dashYear || !dashDepartment) {
                return;
            }

            const now = new Date();
            const allMonthOpt = document.createElement('option');
            allMonthOpt.value = '';
            allMonthOpt.textContent = 'Tất cả các tháng';
            dashMonth.appendChild(allMonthOpt);
            for (let m = 1; m <= 12; m++) {
                const opt = document.createElement('option');
                opt.value = String(m);
                opt.textContent = `tháng ${m}`;
                if (m === now.getMonth() + 1) opt.selected = true;
                dashMonth.appendChild(opt);
            }

            for (let y = now.getFullYear() - 2; y <= now.getFullYear() + 1; y++) {
                const opt = document.createElement('option');
                opt.value = String(y);
                opt.textContent = `năm ${y}`;
                if (y === now.getFullYear()) opt.selected = true;
                dashYear.appendChild(opt);
            }

            if (roleKey === 'employee') {
                dashDepartment.disabled = true;
            }

            updateDepartmentFilterStatus();
        }

        function renderSparklines(trend = []) {
            const maxValue = Math.max(...trend, 1);
            return `<div class="mini-sparkline">${trend.map(value => `<span style="height:${Math.max(3, Math.round((value / maxValue) * 24))}px"></span>`).join('')}</div>`;
        }

        function renderKpiCards(cards) {
            kpiGrid.innerHTML = cards.map(card => `
                <article class="kpi-card ${card.theme}">

                        const actionBtn = item.taskId || item.maTask ? `<a class="btn btn-sm btn-outline-primary employee-alert-action" data-action="openTask" data-id="${encodeURIComponent(item.taskId || item.maTask)}" href="${taskLink}">Xem task</a>` : `<a class="btn btn-sm btn-outline-secondary employee-alert-action" data-action="openDetail" href="/Portal/Notifications">Xem chi tiết</a>`;

            }

            const donutCtx = document.getElementById('employeeDonut');
            if (donutCtx && typeof Chart !== 'undefined') {
                const cardKpi = Array.isArray(cards) ? (cards.find(c => (c.label || '').toLowerCase().includes('kpi')) || cards[0]) : null;
                const kpiValue = cardKpi && typeof cardKpi.value === 'string' && cardKpi.value.includes('%') ? Number(cardKpi.value.replace('%', '')) : (cardKpi && Number(cardKpi.value)) || 0;
                try {
                    if (employeeDonutChart) {
                        employeeDonutChart.destroy();
                        employeeDonutChart = null;
                    }
                    if (typeof Chart.getChart === 'function') {
                        const existingDonut = Chart.getChart(donutCtx);
                        if (existingDonut) existingDonut.destroy();
                    }

                    employeeDonutChart = new Chart(donutCtx, {
                        type: 'doughnut',
                        data: { labels: ['Đã đạt', 'Còn lại'], datasets: [{ data: [Math.max(0, Math.min(100, kpiValue)), Math.max(0, 100 - Math.max(0, Math.min(100, kpiValue)))], backgroundColor: ['#10B981', '#E5E7EB'] }] },
                        options: { cutout: '75%', plugins: { legend: { display: false } } }
                    });
                } catch (e) { console.warn('donut render err', e); }
                const labelEl = document.getElementById('kpiProgressLabel');
                if (labelEl) labelEl.textContent = `KPI: ${kpiValue.toFixed(1)}%`;

                // KPI trend: try to detect previous period value from common fields and render a trend pill
                (function(){
                    const trendEl = document.getElementById('employeeKpiTrend');
                    const trendInline = document.getElementById('employeeKpiTrendInline');
                    const cardKpi = Array.isArray(cards) ? (cards.find(c => (c.label || '').toLowerCase().includes('kpi')) || cards[0]) : null;
                    let prevRaw = undefined;
                    if (cardKpi) prevRaw = cardKpi.previous ?? cardKpi.prev ?? cardKpi.previousValue ?? cardKpi.prevValue ?? cardKpi.previous_period ?? cardKpi.prev_period;
                    prevRaw = prevRaw ?? payload?.previousKpi ?? payload?.kpiPrevious ?? ctx.kpiCaNhanPrevious;
                    if (typeof prevRaw === 'string' && prevRaw.includes('%')) prevRaw = Number(prevRaw.replace('%', ''));
                    const prevVal = Number(prevRaw);

                    function renderTrend(el){
                        if (!el) return;
                        if (!isFinite(prevVal)){
                            el.textContent = 'Chưa có dữ liệu so sánh';
                            el.className = 'employee-kpi-trend';
                            return;
                        }
                        const delta = +(kpiValue - prevVal);
                        const abs = Math.abs(delta).toFixed(1);
                        const arrow = delta > 0 ? '<i class="bi bi-arrow-up-right"></i>' : (delta < 0 ? '<i class="bi bi-arrow-down-right"></i>' : '');
                        const verb = delta > 0 ? 'Tăng' : (delta < 0 ? 'Giảm' : 'Ổn định');
                        let cls = 'employee-kpi-trend';
                        if (delta > 0) cls += ' up';
                        else if (delta < 0) cls += (Math.abs(delta) >= 5 ? ' down' : ' warning');
                        const text = delta === 0 ? 'Ổn định so với kỳ trước' : `${arrow} ${verb} ${abs}% so với tháng trước`;
                        el.innerHTML = text;
                        el.className = cls;
                    }

                    renderTrend(trendEl);
                    renderTrend(trendInline);
                })();
            }

            const quickUpdateProgressBtn = document.getElementById('quickUpdateProgress');
            if (quickUpdateProgressBtn) {
                quickUpdateProgressBtn.onclick = () => window.location.href = '/Portal/Tasks?role=' + role;
            }

            const quickCreateReportBtn = document.getElementById('quickCreateReport');
            if (quickCreateReportBtn) {
                quickCreateReportBtn.onclick = () => window.location.href = '/Portal/CreateReport';
            }

        }

        function attachChartDrillDown(chart, title) {
            chart.canvas.onclick = function (evt) {
                const points = chart.getElementsAtEventForMode(evt, 'nearest', { intersect: true }, true);
                if (!points || points.length === 0) return;
                const idx = points[0].index;
                const label = chart.data.labels[idx];
                alert(`Drill-down: ${title} - ${label}`);
            };
        }


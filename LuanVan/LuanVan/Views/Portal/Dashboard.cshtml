                        <div>${deadlineTag(task.daysLeft)}</div>
                    </td>
                    <td>
                        <div class="progress" style="height:10px">
                            <div class="progress-bar ${progressTone(task.progress)}" role="progressbar" style="width:${task.progress}%"></div>
                        </div>
                        <small class="text-muted">${task.progress}%</small>
                    </td>
                    <td>${statusTag(task.status)}</td>

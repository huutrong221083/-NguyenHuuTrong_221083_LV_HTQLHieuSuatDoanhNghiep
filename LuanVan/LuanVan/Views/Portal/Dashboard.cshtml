@{
    var role = (ViewData["Role"]?.ToString() ?? "Admin").ToLowerInvariant();
    var roleKey = (ViewData["RoleKey"]?.ToString() ?? "admin").Trim().ToLowerInvariant();
    var isEmployeeDashboard = roleKey == "employee";
}


<style>
    .employee-dashboard-v3 {
        padding: 14px 16px 28px;
    }

    .employee-dashboard-grid-v3 {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(360px, .95fr);
        gap: 18px;
        align-items: start;
    }

    .employee-left-col,
    .employee-right-col {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .employee-panel {
        border: 1px solid #dbe3ef;
        border-radius: 18px;
        background: rgba(255, 255, 255, .97);
        padding: 16px;
        box-shadow: 0 8px 24px rgba(15, 23, 42, .045);
    }

    .employee-panel-head {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 14px;
    }

    .employee-panel-head h4 {
        margin: 0;
        color: #0f172a;
        font-size: 18px;
        font-weight: 800;
    }

    .employee-panel-head span {
        display: block;
        margin-top: 5px;
        color: #64748b;
        font-size: 13px;
    }

    .employee-summary-panel {
        border-color: #bfdbfe;
        background: linear-gradient(135deg, #f8fbff 0%, #ffffff 72%);
    }

    .employee-ai-panel {
        border-left: 5px solid #7c3aed;
        background: linear-gradient(135deg, #f5f3ff 0%, #ffffff 72%);
    }

    .employee-org-panel {
        background: linear-gradient(135deg, #f0fdfa 0%, #ffffff 72%);
        border-color: #ccfbf1;
    }

    .employee-alert-panel {
        min-height: 170px;
    }

    .employee-kpi-panel {
        background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
    }

    .employee-eval-hero {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 14px;
        padding: 18px;
        border-radius: 16px;
        border: 1px solid #bfdbfe;
        background: #fff;
    }

    .employee-eval-label,
    .employee-org-label {
        color: #64748b;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: .08em;
        text-transform: uppercase;
    }

    .employee-eval-value {
        margin-top: 4px;
        font-size: 38px;
        line-height: 1;
        font-weight: 900;
        color: #0f172a;
    }

    .employee-eval-note,
    .employee-org-note {
        margin-top: 8px;
        color: #64748b;
        font-size: 14px;
    }

    .employee-eval-badge {
        width: 58px;
        height: 58px;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #2563eb;
        background: #eff6ff;
        border: 1px solid #dbeafe;
        font-size: 28px;
    }

    .today-task-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .today-task-item {
        padding: 14px 16px;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        background: #fff;
        transition: .18s ease;
    }

    .today-task-item:hover {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(15, 23, 42, .06);
    }

    .task-name {
        color: #0f172a;
        font-weight: 800;
    }

    .employee-timeline {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .employee-timeline .timeline-item {
        display: flex;
        gap: 12px;
    }

    .employee-timeline .timeline-avatar {
        width: 40px;
        height: 40px;
        flex: 0 0 40px;
        border-radius: 14px;
        background: #eff6ff;
        color: #2563eb;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 800;
    }

    .employee-timeline .timeline-content strong {
        color: #0f172a;
        font-size: 15px;
    }

    .employee-org-meta {
        padding: 16px;
        border-radius: 16px;
        border: 1px solid #ccfbf1;
        background: rgba(240, 253, 250, .75);
    }

    .employee-org-value {
        margin-top: 4px;
        font-size: 23px;
        font-weight: 850;
        color: #0f766e;
    }

    .employee-org-subtitle {
        color: #64748b;
        font-size: 13px;
        margin: 14px 0 8px;
    }

    .employee-chip-wrap {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
    }

    .employee-chip {
        padding: 7px 11px;
        border-radius: 999px;
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #bfdbfe;
        font-size: 12px;
        font-weight: 700;
    }

    .ai-assistant ul {
        padding-left: 20px;
        margin-bottom: 0;
    }

    .ai-assistant li {
        margin-bottom: 9px;
        color: #475569;
        line-height: 1.5;
    }

    .employee-kpi-donut-wrap {
        display: flex;
        align-items: center;
        gap: 20px;
    }

    #employeeDonut {
        width: 130px !important;
        height: 130px !important;
    }

    .employee-kpi-label {
        font-size: 19px;
        font-weight: 800;
        color: #475569;
    }

    /* KPI trend pill */
    .employee-kpi-trend {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 10px;
        padding: 6px 10px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
    }

    .employee-kpi-trend.up {
        background: #dcfce7;
        color: #15803d;
    }

    .employee-kpi-trend.down {
        background: #fee2e2;
        color: #dc2626;
    }

    .employee-kpi-trend.warning {
        background: #fef3c7;
        color: #d97706;
    }

    .employee-alert-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .employee-alert-item {
        padding: 12px;
        border-radius: 14px;
        border: 1px solid #e2e8f0;
        background: #fff;
    }

    .employee-alert-item.unread {
        border-color: #fed7aa;
        background: #fff7ed;
    }

    .aix-alert-head {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        align-items: center;
    }

    .employee-alert-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f1f5f9;
    }

    .aix-alert-name {
        color: #0f172a;
        font-weight: 800;
        font-size: 14px;
    }

    .aix-alert-meta,
    .employee-alert-item .desc {
        color: #64748b;
        font-size: 12px;
    }

    .employee-alert-item .desc {
        margin-top: 8px;
    }

    .employee-quick-actions {
        display: grid;
        grid-template-columns: 1fr;
        gap: 10px;
    }

    .employee-quick-actions .btn {
        height: 38px;
        border-radius: 12px;
        font-weight: 700;
    }

    @@media (max-width: 1200px) {
        .employee-dashboard-grid-v3 {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 768px) {
        .employee-dashboard-v3 {
            padding: 10px;
        }

        .employee-kpi-donut-wrap {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>


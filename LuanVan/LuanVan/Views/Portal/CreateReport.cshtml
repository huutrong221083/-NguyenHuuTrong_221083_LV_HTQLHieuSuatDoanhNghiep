<script>
    const currentRoleKey = '@roleKey';
    let allTaskPool = [];
    const searchParams = new URLSearchParams(window.location.search);
    const requestedReportRequestId = Number(searchParams.get('requestId') || 0);
    const isManualCreateMode = searchParams.get('manual') === '1';
    const escapeHtml = (str) => String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');

    async function requestJson(url, options = {}) {
        try {
            const res = await fetch(url, options);
            if (!res.ok) return { success: false, status: res.status };
            return await res.json();
        } catch (error) {
            console.error('Fetch error:', error);
            return { success: false, message: error?.message || 'Lỗi kết nối' };
        }
    }

    function getPayload(resp) {
        return resp?.data ?? resp?.Data ?? resp ?? null;
    }

    function extractArray(resp) {
        const data = getPayload(resp);
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.items)) return data.items;
        return [];
    }

    function formatDate(dateStr) {
        if (!dateStr) return 'Không xác định';
        const date = new Date(dateStr);
        return date.toLocaleDateString('vi-VN');
    }

    function formatMonthYear(item) {
        if (!item) return '--';
        const month = String(item.thang || item.Thang || '').padStart(2, '0');
        const year = item.nam || item.Nam || '';
        return `${month}/${year}`;
    }

    function formatTrend(value) {
        if (value === null || value === undefined || Number.isNaN(value)) return '--';
        const sign = value > 0 ? '+' : '';
        return `${sign}${value.toFixed(1)}%`;
    }

    function getSelectedRecipientName() {
        const select = document.getElementById('reportRecipient');
        return select?.selectedOptions?.[0]?.textContent?.trim() || '';
    }

    function getSelectedRecipientUserId() {
        const select = document.getElementById('reportRecipient');
        return select?.value?.trim() || '';
    }

    function getDateRangeFromPeriod(periodKey) {
        const now = new Date();
        const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
        const toIso = (d) => d.toISOString().slice(0, 10);
        let from = today;
        let to = today;

        switch (String(periodKey || 'this_month')) {
            case 'today':
                break;
            case 'this_week': {
                const day = (today.getDay() + 6) % 7;
                from = new Date(today);
                from.setDate(today.getDate() - day);
                to = new Date(from);
                to.setDate(from.getDate() + 6);
                break;
            }
            case 'this_month':
                from = new Date(today.getFullYear(), today.getMonth(), 1);
                to = new Date(today.getFullYear(), today.getMonth() + 1, 0);
                break;
            case 'this_quarter': {
                const q = Math.floor(today.getMonth() / 3);
                from = new Date(today.getFullYear(), q * 3, 1);
                to = new Date(today.getFullYear(), q * 3 + 3, 0);
                break;
            }
            case 'this_year':
                from = new Date(today.getFullYear(), 0, 1);
                to = new Date(today.getFullYear(), 11, 31);
                break;
            default:
                break;
        }

        return { fromDate: toIso(from), toDate: toIso(to) };
    }

    function getReportPayload() {
        const selectedItems = Array.from(document.querySelectorAll('input[name="workItems"]:checked'))
            .map(cb => parseInt(cb.value));
        const periodRange = getDateRangeFromPeriod(document.getElementById('reportPeriod')?.value);

        return {
            maYeuCau: parseInt(window.selectedRequestId || 0) || 0,
            tenBaoCao: document.getElementById('reportTitle').value.trim(),
            loaiBaoCao: document.getElementById('reportType').value.trim(),
            ngayBatDau: periodRange.fromDate,
            ngayKetThuc: periodRange.toDate,
            congViecDuocChon: selectedItems,
            nguoiNhanUserId: getSelectedRecipientUserId(),
            nguoiNhanBaoCao: getSelectedRecipientName(),
            noiDung: collectReportContent(),
            taiLieu: collectAttachments()
        };
    }

    function renderPreviewContent() {
        const payload = getReportPayload();
        const selectedTasks = Array.from(document.querySelectorAll('input[name="workItems"]:checked'))
            .map(cb => {
                const task = Array.from(document.querySelectorAll('#workItemsList .work-item')).find(item => item.querySelector('input[type="checkbox"]')?.value === cb.value);
                return task ? task.querySelector('.work-item-name')?.textContent?.trim() : '';
            })
            .filter(Boolean);

        const request = (window.reportRequests || []).find(x => Number(x.maYeuCau || x.MaYeuCau) === Number(payload.maYeuCau));
        const requestLabel = request ? `${request.tieuDe || request.TieuDe || 'Yêu cầu báo cáo'}${request.nguoiYeuCau || request.NguoiYeuCau ? ` - ${request.nguoiYeuCau || request.NguoiYeuCau}` : ''}` : 'Báo cáo tự nguyện';

        document.getElementById('reportPreviewTitle').textContent = payload.tenBaoCao || 'Xem trước báo cáo';
        document.getElementById('reportPreviewContent').innerHTML = `
            <div class="preview-section">
                <h4>Thông tin chung</h4>
                <div class="preview-meta">
                    <div class="preview-meta-item"><strong>Tiêu đề</strong>${escapeHtml(payload.tenBaoCao || '--')}</div>
                    <div class="preview-meta-item"><strong>Loại báo cáo</strong>${escapeHtml(payload.loaiBaoCao || '--')}</div>
                    <div class="preview-meta-item"><strong>Từ ngày</strong>${escapeHtml(payload.ngayBatDau || '--')}</div>
                    <div class="preview-meta-item"><strong>Đến ngày</strong>${escapeHtml(payload.ngayKetThuc || '--')}</div>
                    <div class="preview-meta-item"><strong>Người nhận</strong>${escapeHtml(payload.nguoiNhanBaoCao || '--')}</div>
                    <div class="preview-meta-item"><strong>Nguồn yêu cầu</strong>${escapeHtml(requestLabel)}</div>
                </div>
            </div>
            <div class="preview-section">
                <h4>Nội dung chi tiết</h4>
                <p><strong>Đã hoàn thành:</strong><br>${escapeHtml(JSON.parse(payload.noiDung || '{}').completed || '')}</p>
                <p><strong>Đang thực hiện:</strong><br>${escapeHtml(JSON.parse(payload.noiDung || '{}').ongoing || '')}</p>
                <p><strong>Khó khăn / Vướng mắc:</strong><br>${escapeHtml(JSON.parse(payload.noiDung || '{}').challenges || '')}</p>
                <p><strong>Đề xuất hỗ trợ:</strong><br>${escapeHtml(JSON.parse(payload.noiDung || '{}').support || '')}</p>
            </div>
            <div class="preview-section">
                <h4>Công việc liên quan</h4>
                <div class="preview-task-list">
                    ${selectedTasks.length ? selectedTasks.map(task => `<div class="preview-task-item">${escapeHtml(task)}</div>`).join('') : '<div class="preview-task-item">Chưa chọn công việc nào</div>'}
                </div>
            </div>
            <div class="preview-section">
                <h4>Tệp đính kèm</h4>
                <div class="preview-task-list">
                    ${payload.taiLieu.length ? payload.taiLieu.map(file => `<div class="preview-task-item">${escapeHtml(file)}</div>`).join('') : '<div class="preview-task-item">Không có tệp đính kèm</div>'}
                </div>
            </div>
        `;
    }

    function updateSidebarProgress() {
        const title = document.getElementById('reportTitle').value.trim();
        const type = document.getElementById('reportType').value.trim();
        const completed = document.getElementById('completedWork').value.trim();
        const ongoing = document.getElementById('ongoingWork').value.trim();
        const challenges = document.getElementById('challenges').value.trim();
        const support = document.getElementById('suggestions').value.trim();
        const selectedTasks = document.querySelectorAll('input[name="workItems"]:checked').length;
        const totalTasks = document.querySelectorAll('input[name="workItems"]').length;
        const attachmentCount = document.querySelectorAll('#attachmentList .attachment-item').length;

        const progress1 = title && type ? 100 : (title || type ? 50 : 0);
        const progress2 = [completed, ongoing, challenges, support].filter(Boolean).length * 25;
        const progress3 = totalTasks > 0 ? Math.round((selectedTasks / totalTasks) * 100) : 0;
        const progress4 = Math.min(attachmentCount * 25, 100);

        document.getElementById('progress1').textContent = `${progress1}%`;
        document.getElementById('progressFill1').style.width = `${progress1}%`;
        document.getElementById('progress2').textContent = `${progress2}%`;
        document.getElementById('progressFill2').style.width = `${progress2}%`;
        document.getElementById('progress3').textContent = `${progress3}%`;
        document.getElementById('progressFill3').style.width = `${progress3}%`;
        document.getElementById('progress4').textContent = `${progress4}%`;
        document.getElementById('progressFill4').style.width = `${progress4}%`;
    }

    function renderPersonalKpi(kpi) {
        const container = document.getElementById('kpiGrid');

        if (!kpi) {
            container.innerHTML = `
                <div class="kpi-card">
                    <div class="kpi-card-label">Chưa có KPI</div>
                    <div class="kpi-card-value">--</div>
                    <div class="kpi-card-progress"><div class="kpi-card-progress" style="width: 0%"></div></div>
                </div>
            `;
            return;
        }

        const score = Number(kpi.diemHienTai ?? kpi.DiemHienTai ?? 0);
        const classification = kpi.xepLoai || kpi.XepLoai || 'Chưa có dữ liệu';
        const trend = kpi.xuHuongPhanTram ?? kpi.XuHuongPhanTram;

        container.innerHTML = `
            <div class="kpi-card">
                <div class="kpi-card-label">Điểm KPI hiện tại</div>
                <div class="kpi-card-value">${score.toFixed(1)}</div>
                <div class="kpi-card-progress"><div class="kpi-card-progress" style="width: ${Math.min(score, 100)}%"></div></div>
            </div>
            <div class="kpi-card">
                <div class="kpi-card-label">Xếp loại</div>
                <div class="kpi-card-value" style="font-size: 18px;">${escapeHtml(classification)}</div>
                <div class="kpi-card-progress"><div class="kpi-card-progress" style="width: ${score >= 90 ? 100 : score >= 80 ? 85 : score >= 65 ? 70 : score >= 50 ? 50 : 25}%"></div></div>
            </div>
            <div class="kpi-card">
                <div class="kpi-card-label">Xu hướng</div>
                <div class="kpi-card-value" style="font-size: 18px;">${formatTrend(trend)}</div>
                <div class="kpi-card-progress"><div class="kpi-card-progress" style="width: ${trend > 0 ? 85 : trend < 0 ? 35 : 55}%"></div></div>
            </div>
        `;
    }

    async function loadRecentReports() {
        const container = document.getElementById('historyList');
        if (!container) return;

        try {
            const res = await requestJson('/api/baocao/list?LoaiBaoCao=personal&PageNumber=1&PageSize=5');
            const data = getPayload(res);
            
            if (!data || !data.items || data.items.length === 0) {
                container.innerHTML = '<div style="color: var(--text-muted); text-align: center; padding: 12px; font-size: 12px;">Chưa có báo cáo nào</div>';
                return;
            }

            container.innerHTML = data.items.map(report => {
                const ngayTao = new Date(report.ngayTao || report.NgayTao);
                const tenBaoCao = report.tenBaoCao || report.TenBaoCao || 'Báo cáo không tên';
                const loaiBaoCao = report.loaiBaoCao || report.LoaiBaoCao || 'Cá nhân';
                const trangThai = report.trangThai || report.TrangThai || 'Nháp';
                
                return `
                    <div class="history-item">
                        <div class="history-item-date">${tenBaoCao}</div>
                        <div class="history-item-status">
                            ${ngayTao.toLocaleDateString('vi-VN')} • 
                            <span style="color: ${trangThai === 'Đã gửi' ? '#10b981' : '#f59e0b'}">${trangThai}</span>
                        </div>
                    </div>
                `;
            }).join('');
        } catch (error) {
            console.error('Error loading recent reports:', error);
            container.innerHTML = '<div style="color: var(--text-muted); text-align: center; padding: 12px; font-size: 12px;">Không thể tải báo cáo gần đây</div>';
        }
    }

    function registerStaticEvents() {
        const byId = (id) => document.getElementById(id);

        byId('btnAiAssistant')?.addEventListener('click', aiAssist);
        byId('btnSaveDraft')?.addEventListener('click', saveDraft);
        byId('btnPreview')?.addEventListener('click', showPreview);
        byId('btnSendReport')?.addEventListener('click', submitReport);
        byId('btnSubmit')?.addEventListener('click', submitReport);
        byId('btnCancel')?.addEventListener('click', () => window.history.back());
        byId('btnExportPdf')?.addEventListener('click', exportPdf);
        byId('btnExportExcel')?.addEventListener('click', exportExcel);
        byId('btnClosePreview')?.addEventListener('click', closePreview);
        byId('btnPreviewExportPdf')?.addEventListener('click', exportPdf);
        byId('btnPreviewExportExcel')?.addEventListener('click', exportExcel);
        byId('reportPreviewModal')?.addEventListener('click', (e) => {
            if (e.target.id === 'reportPreviewModal') closePreview();
        });

        const uploadArea = byId('attachmentUploadArea');
        if (uploadArea) {
            uploadArea.addEventListener('click', () => byId('attachmentFileInput')?.click());
            uploadArea.addEventListener('dragover', (e) => e.preventDefault());
            uploadArea.addEventListener('drop', handleAttachmentDrop);
        }

        ['reportTitle', 'reportType', 'reportPeriod', 'completedWork', 'ongoingWork', 'challenges', 'suggestions'].forEach(id => {
            const element = byId(id);
            if (element) {
                element.addEventListener('input', updateSidebarProgress);
                element.addEventListener('change', updateSidebarProgress);
            }
        });

        byId('taskSourceType')?.addEventListener('change', applyTaskSourceFilter);
        byId('projectFilterSelect')?.addEventListener('change', applyTaskSourceFilter);
        byId('taskKeywordFilter')?.addEventListener('input', applyTaskSourceFilter);
    }

    async function init() {
        registerStaticEvents();

        try {
            const res = await requestJson('/api/report/load-page');
            const data = getPayload(res);
            
            if (!data) {
                console.error('Failed to load page data');
                alert('Không tải được dữ liệu ban đầu của trang báo cáo. Bạn vẫn có thể nhập và gửi báo cáo thủ công.');
                return;
            }

            allTaskPool = data.myTasks || [];
            renderProjectFilterOptions(allTaskPool);
            applyTaskSourceFilter();

            // Render manager list
            populateRecipients(data.managers || []);

            // Render report requests
            renderReportRequests(data.myRequests || []);

            // Render personal KPI sidebar
            renderPersonalKpi(data.personalKpi || data.PersonalKpi || null);

            // Load recent reports into sidebar
            await loadRecentReports();

            // Keep requests available for quick selection/fill
            window.reportRequests = data.myRequests || [];

            if (isManualCreateMode && currentRoleKey === 'admin') {
                const requestCard = document.getElementById('requestNotificationCard');
                if (requestCard) requestCard.style.display = 'none';
            }

            if (requestedReportRequestId > 0) {
                selectRequest(requestedReportRequestId);
            }

            document.querySelectorAll('input[name="workItems"]').forEach(input => {
                input.addEventListener('change', updateSidebarProgress);
            });
        } catch (err) {
            console.error('Error initializing page:', err);
            alert('Không thể khởi tạo trang báo cáo. Vui lòng tải lại trang hoặc đăng nhập lại.');
        }
    }

    async function parseApiResponse(response) {
        const raw = await response.text();
        if (!raw) return { success: response.ok, status: response.status };

        try {
            return JSON.parse(raw);
        } catch {
            return {
                success: false,
                status: response.status,
                message: raw.length > 300 ? raw.slice(0, 300) + '...' : raw
            };
        }
    }

    function renderReportRequests(requests) {
        const container = document.getElementById('requestList');
        if (!requests.length) {
            container.innerHTML = '<div class="request-item-empty"><p>Chưa có yêu cầu báo cáo nào. Bạn có thể tạo báo cáo tự nguyện.</p></div>';
            document.getElementById('requestCountBadge').textContent = '0';
            return;
        }

        const count = requests.length;
        document.getElementById('requestCountBadge').textContent = count;

        container.innerHTML = requests.map(r => `
            <div class="request-item">
                <div class="request-item-header">
                    <div>
                        <h4>${escapeHtml(r.tieuDe || 'Yêu cầu báo cáo')}</h4>
                        <p>${escapeHtml(r.moTa || '')}</p>
                        <p style="margin-top: 4px;">Người yêu cầu: ${escapeHtml(r.nguoiYeuCau || r.NguoiYeuCau || 'Không xác định')}</p>
                    </div>
                    <span class="request-priority ${r.priority || 'normal'}">${getPriorityLabel(r.priority)}</span>
                </div>
                <div class="request-item-footer">
                    <span class="request-deadline">Hạn: ${formatDate(r.hanChot)}</span>
                    <div class="request-actions">
                        <button class="btn-small" onclick="selectRequest(${r.maYeuCau})">Chọn yêu cầu này</button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    function getPriorityLabel(priority) {
        const labels = {
            'low': '🟢 Thường',
            'normal': '🟡 Bình thường',
            'high': '🔴 Cao',
            'urgent': '🔥 Gấp'
        };
        return labels[priority] || priority || 'Bình thường';
    }

    function selectRequest(maYeuCau) {
        window.selectedRequestId = maYeuCau;
        const request = (window.reportRequests || []).find(x => Number(x.maYeuCau || x.MaYeuCau) === Number(maYeuCau));

        if (request) {
            const titleInput = document.getElementById('reportTitle');
            const typeSelect = document.getElementById('reportType');
            const periodSelect = document.getElementById('reportPeriod');

            if (!titleInput.value) {
                titleInput.value = request.tieuDe || request.TieuDe || '';
            }

            if (!typeSelect.value) {
                const priority = String(request.priority || request.Priority || '').toLowerCase();
                if (priority === 'urgent') typeSelect.value = 'urgent';
                else if (priority === 'high') typeSelect.value = 'weekly';
                else typeSelect.value = 'work';
            }

            if (periodSelect && !periodSelect.value) {
                periodSelect.value = 'this_month';
            }
        }

        updateStatusBadge('Đang soạn');
        updateSidebarProgress();
        alert(`Đã chọn yêu cầu #${maYeuCau}. Báo cáo sẽ được gửi để phản hồi yêu cầu này.`);
    }

    function renderWorkItems(tasks) {
        const container = document.getElementById('workItemsList');
        if (!tasks.length) {
            container.innerHTML = '<p style="color: var(--text-muted); text-align: center; padding: 24px;">Chưa có công việc nào</p>';
            updateSidebarProgress();
            return;
        }

        container.innerHTML = tasks.map(t => `
            <div class="work-item">
                <input type="checkbox" name="workItems" value="${t.maCongViec || t.MaCongViec || 0}" />
                <div class="work-item-info">
                    <p class="work-item-name">${escapeHtml(t.tenCongViec || t.TenCongViec || '')}</p>
                    <div class="work-item-details">
                        <span>${escapeHtml(t.tenDuAn || t.TenDuAn || '-')}</span>
                    </div>
                </div>
                <div class="work-item-progress">
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: ${(t.tienDoPhanTram || t.TienDoPhanTram || 0)}%"></div>
                    </div>
                    <span style="font-size: 11px; color: var(--text-muted);">${(t.tienDoPhanTram || t.TienDoPhanTram || 0)}%</span>
                </div>
                <div class="work-item-status ${(t.tenTrangThai || t.TenTrangThai || '').includes('Hoàn') ? 'status-completed' : 'status-ontime'}">
                    ${escapeHtml(t.tenTrangThai || t.TenTrangThai || 'Đang làm')}
                </div>
            </div>
        `).join('');

        updateSidebarProgress();
    }

    function populateRecipients(emps) {
        const select = document.getElementById('reportRecipient');
        if (!select) return;

        const emptyText = currentRoleKey === 'manager'
            ? '-- Chọn admin nhận báo cáo --'
            : '-- Chọn người nhận --';

        if (!emps || !emps.length) {
            select.innerHTML = `<option value="">${emptyText}</option>`;
            return;
        }

        const html = emps.map(e => `
            <option value="${escapeHtml(e.aspNetUserId || e.AspNetUserId || '')}">${escapeHtml(e.hoTen || e.HoTen || '')}</option>
        `).join('');
        select.innerHTML = `<option value="">${emptyText}</option>${html}`;

        updateSidebarProgress();
    }

    function renderProjectFilterOptions(tasks) {
        const select = document.getElementById('projectFilterSelect');
        if (!select) return;

        const projectMap = new Map();
        for (const t of tasks || []) {
            const maDuAn = t.maDuAn ?? t.MaDuAn;
            const tenDuAn = (t.tenDuAn ?? t.TenDuAn ?? '').trim();
            if (!maDuAn || !tenDuAn) continue;
            if (!projectMap.has(String(maDuAn))) {
                projectMap.set(String(maDuAn), tenDuAn);
            }
        }

        const options = ['<option value="">-- Chọn dự án --</option>'];
        for (const [id, name] of projectMap.entries()) {
            options.push(`<option value="${escapeHtml(id)}">${escapeHtml(name)}</option>`);
        }
        select.innerHTML = options.join('');
    }

    function applyTaskSourceFilter() {
        const sourceType = document.getElementById('taskSourceType')?.value || 'task';
        const projectWrap = document.getElementById('projectFilterWrap');
        const selectedProject = document.getElementById('projectFilterSelect')?.value || '';
        const keyword = (document.getElementById('taskKeywordFilter')?.value || '').trim().toLowerCase();

        if (projectWrap) {
            projectWrap.style.display = sourceType === 'project' ? 'block' : 'none';
        }

        let filtered = allTaskPool || [];
        if (sourceType === 'project') {
            filtered = selectedProject
                ? filtered.filter(t => String(t.maDuAn ?? t.MaDuAn ?? '') === String(selectedProject))
                : [];
        }

        if (keyword) {
            filtered = filtered.filter(t => String(t.tenCongViec ?? t.TenCongViec ?? '').toLowerCase().includes(keyword));
        }

        renderWorkItems(filtered);
    }

    function handleAttachmentDrop(e) {
        e.preventDefault();
        const files = e.dataTransfer.files;
        addAttachments(files);
    }

    function addAttachments(files) {
        const list = document.getElementById('attachmentList');
        Array.from(files).forEach(file => {
            const item = document.createElement('div');
            item.className = 'attachment-item';
            item.innerHTML = `
                <i class="bi bi-file"></i>
                <div class="attachment-item-name">${escapeHtml(file.name)}</div>
                <div class="attachment-item-size">${(file.size / 1024).toFixed(1)} KB</div>
                <button class="attachment-item-remove" type="button" title="Xóa">×</button>
            `;
            item.querySelector('.attachment-item-remove').addEventListener('click', () => item.remove());
            list.appendChild(item);
        });

        updateSidebarProgress();
    }

    async function aiAssist() {
        alert('Tính năng AI sẽ được phát triển');
    }

    async function saveDraft() {
        const payload = getReportPayload();

        if (!payload.tenBaoCao || !payload.loaiBaoCao || !payload.nguoiNhanUserId) {
            alert('Vui lòng điền tiêu đề, loại báo cáo và người nhận báo cáo');
            return;
        }

        const request = {
            ...payload,
            noiDung: collectReportContent()
        };

        try {
            const res = await fetch('/api/report/save-draft', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(request)
            });
            const result = await parseApiResponse(res);
            if (result.success) {
                updateStatusBadge('Nháp');
                updateSidebarProgress();
                alert('✓ Lưu nháp báo cáo thành công');
            } else {
                alert('✗ Lỗi: ' + (result.message || result.Message || 'Không lưu được nháp'));
            }
        } catch (err) {
            alert('✗ Lỗi khi lưu nháp: ' + err.message);
        }
    }

    function openPreview() {
        renderPreviewContent();
        document.getElementById('reportPreviewModal').classList.add('open');
        document.getElementById('reportPreviewModal').setAttribute('aria-hidden', 'false');
    }

    function closePreview() {
        document.getElementById('reportPreviewModal').classList.remove('open');
        document.getElementById('reportPreviewModal').setAttribute('aria-hidden', 'true');
    }

    async function showPreview() {
        openPreview();
    }

    async function submitReport() {
        const payload = getReportPayload();

        if (!payload.tenBaoCao || !payload.loaiBaoCao || !payload.nguoiNhanUserId) {
            alert('Vui lòng nhập Tên báo cáo, Loại báo cáo và Người nhận báo cáo');
            return;
        }

        const request = {
            ...payload,
            maYeuCau: payload.maYeuCau,
            noiDung: collectReportContent()
        };

        try {
            const res = await fetch('/api/report/submit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(request)
            });
            const result = await parseApiResponse(res);
            if (result.success) {
                updateStatusBadge('Đã gửi');
                updateSidebarProgress();
                alert('✓ Báo cáo đã được gửi thành công');
                setTimeout(() => window.location.href = '/Portal', 2000);
            } else {
                alert('✗ Lỗi: ' + (result?.message || result?.Message || `HTTP ${res.status}`));
            }
        } catch (err) {
            alert('✗ Lỗi khi gửi báo cáo: ' + err.message);
        }
    }

    function collectReportContent() {
        const content = {
            completed: document.getElementById('completedWork').value || '',
            ongoing: document.getElementById('ongoingWork').value || '',
            challenges: document.getElementById('challenges').value || '',
            support: document.getElementById('suggestions').value || '',
            recipientName: getSelectedRecipientName() || ''
        };
        return JSON.stringify(content);
    }

    function collectAttachments() {
        const items = document.querySelectorAll('#attachmentList .attachment-item');
        return Array.from(items).map(item => item.querySelector('.attachment-item-name').textContent);
    }

    function updateStatusBadge(status) {
        const badge = document.getElementById('statusBadge');
        badge.textContent = status;
        badge.className = 'status-badge ' + (status === 'Nháp' ? 'draft' : status === 'Đã gửi' ? 'sent' : status === 'Đang soạn' ? 'unsent' : 'processing');
    }

    async function downloadReportFile(url, fileName) {
        const payload = getReportPayload();
        const response = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                ...payload,
                noiDung: collectReportContent()
            })
        });

        if (!response.ok) {
            const errorText = await response.text();
            throw new Error(errorText || 'Không thể xuất file');
        }

        const blob = await response.blob();
        const downloadUrl = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = fileName;
        document.body.appendChild(link);
        link.click();
        link.remove();
        window.URL.revokeObjectURL(downloadUrl);
    }

    async function exportPdf() {
        try {
            await downloadReportFile('/api/report/export-pdf', `${(document.getElementById('reportTitle').value || 'BaoCao').replace(/[^\w\d_-]+/g, '_')}.pdf`);
        } catch (err) {
            alert('✗ Lỗi khi xuất PDF: ' + err.message);
        }
    }

    async function exportExcel() {
        try {
            await downloadReportFile('/api/report/export-excel', `${(document.getElementById('reportTitle').value || 'BaoCao').replace(/[^\w\d_-]+/g, '_')}.xlsx`);
        } catch (err) {
            alert('✗ Lỗi khi xuất Excel: ' + err.message);
        }
    }

    init();
</script>

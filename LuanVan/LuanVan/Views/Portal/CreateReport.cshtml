    function renderProjectFilterOptions(tasks) {
        const select = document.getElementById('projectFilterSelect');
        const basicSelect = document.getElementById('projectFilterSelectBasic');
        if (!select && !basicSelect) return;

        const projectMap = new Map();
        for (const t of tasks || []) {
            const maDuAn = t.maDuAn ?? t.MaDuAn;
            const tenDuAn = (t.tenDuAn ?? t.TenDuAn ?? '').trim();
            if (!maDuAn || !tenDuAn) continue;
            if (!projectMap.has(String(maDuAn))) {
                projectMap.set(String(maDuAn), tenDuAn);
            }
        }

        const options = ['<option value="">-- Chọn dự án --</option>'];
        const basicOptions = ['<option value="">-- Tất cả dự án --</option>'];
        for (const [id, name] of projectMap.entries()) {
            options.push(`<option value="${escapeHtml(id)}">${escapeHtml(name)}</option>`);
            basicOptions.push(`<option value="${escapeHtml(id)}">${escapeHtml(name)}</option>`);
        }
        if (select) select.innerHTML = options.join('');
        if (basicSelect) basicSelect.innerHTML = basicOptions.join('');
    }

    function resolveTaskDeadline(task) {
        const raw = task.hanHoanThanh ?? task.HanHoanThanh ?? task.deadline ?? task.Deadline ?? task.ngayKetThucDuKien ?? task.NgayKetThucDuKien ?? null;
        if (!raw) return null;
        const parsed = new Date(raw);
        return Number.isNaN(parsed.getTime()) ? null : parsed;
    }

    function isTaskCompleted(task) {
        const status = String(task.tenTrangThai ?? task.TenTrangThai ?? '').toLowerCase();
        return status.includes('hoàn') || status.includes('xong') || status.includes('complete');
    }

    function isTaskOverdue(task) {
        if (isTaskCompleted(task)) return false;
        const deadline = resolveTaskDeadline(task);
        if (!deadline) return false;
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        deadline.setHours(0, 0, 0, 0);
        return deadline < today;
    }

    function applyTaskSourceFilter() {
        const sourceType = document.getElementById('taskSourceType')?.value || 'task';
        const projectWrap = document.getElementById('projectFilterWrap');
        const selectedProject = document.getElementById('projectFilterSelectBasic')?.value
            || document.getElementById('projectFilterSelect')?.value
            || '';
        const keyword = (document.getElementById('taskKeywordFilter')?.value || '').trim().toLowerCase();

        if (projectWrap) {
            projectWrap.style.display = sourceType === 'project' ? 'block' : 'none';
        }

        let filtered = allTaskPool || [];
        if (selectedProject) {
            filtered = filtered.filter(t => String(t.maDuAn ?? t.MaDuAn ?? '') === String(selectedProject));
        }

        if (keyword) {
            filtered = filtered.filter(t => String(t.tenCongViec ?? t.TenCongViec ?? '').toLowerCase().includes(keyword));
        }

        if (currentTaskFilter === 'done') {
            filtered = filtered.filter(isTaskCompleted);
        } else if (currentTaskFilter === 'doing') {
            filtered = filtered.filter(t => !isTaskCompleted(t));
        } else if (currentTaskFilter === 'overdue') {
            filtered = filtered.filter(isTaskOverdue);
        }

        renderWorkItems(filtered);
    }

    async function saveDraft() {
        const payload = getReportPayload();

        if (!payload.tenBaoCao || !payload.loaiBaoCao) {
            alert('Vui lòng điền tiêu đề và loại báo cáo');
            return;
        }

        if (isRecipientRequiredForAction('save') && !payload.nguoiNhanUserId) {
            alert('Vui lòng chọn người nhận báo cáo');
            return;
        }

        const request = {
            ...payload,
            noiDung: collectReportContent()
        };

        try {
            const res = await fetch('/api/report/save-draft', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(request)
            });
            const result = await parseApiResponse(res);
            if (result.success) {
                updateStatusBadge('Nháp');
                updateSidebarProgress();
                alert('✓ Lưu nháp báo cáo thành công');
            } else {
                alert('✗ Lỗi: ' + (result.message || result.Message || 'Không lưu được nháp'));
            }
        } catch (err) {
            alert('✗ Lỗi khi lưu nháp: ' + err.message);
        }
    }


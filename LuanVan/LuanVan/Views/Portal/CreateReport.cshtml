<script>
    const currentRoleKey = '@roleKey';
    let allTaskPool = [];
    let currentTaskFilter = 'all';
    const searchParams = new URLSearchParams(window.location.search);
    const requestedReportRequestId = Number(searchParams.get('requestId') || 0);
    const isManualCreateMode = searchParams.get('manual') === '1';
    const escapeHtml = (str) => String(str || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#039;');

    async function requestJson(url, options = {}) {
        try {
            const res = await fetch(url, options);
            if (!res.ok) return { success: false, status: res.status };
            return await res.json();
        } catch (error) {
            console.error('Fetch error:', error);
            return { success: false, message: error?.message || 'Lỗi kết nối' };
        }
    }

    function getPayload(resp) {
        return resp?.data ?? resp?.Data ?? resp ?? null;
    }

    function extractArray(resp) {
        const data = getPayload(resp);
        if (!data) return [];
        if (Array.isArray(data)) return data;
        if (Array.isArray(data.items)) return data.items;
        return [];
    }

    function formatDate(dateStr) {
        if (!dateStr) return 'Không xác định';
        const date = new Date(dateStr);
        return date.toLocaleDateString('vi-VN');
    }

    function formatMonthYear(item) {
        if (!item) return '--';
        const month = String(item.thang || item.Thang || '').padStart(2, '0');
        const year = item.nam || item.Nam || '';
        return `${month}/${year}`;
    }

    function formatTrend(value) {
        if (value === null || value === undefined || Number.isNaN(value)) return '--';
        const sign = value > 0 ? '+' : '';
        return `${sign}${value.toFixed(1)}%`;
    }

    function toVietnameseReportType(type) {
        const normalized = String(type || '').trim().toLowerCase();
        const map = {
            all: 'Báo cáo tổng hợp',
            daily: 'Báo cáo ngày',
            weekly: 'Báo cáo tuần',
            monthly: 'Báo cáo tháng',
            kpi: 'Báo cáo KPI',
            project: 'Báo cáo dự án',
            work: 'Báo cáo công việc',
            urgent: 'Báo cáo đột xuất'
        };
        return map[normalized] || (type || 'Chưa chọn');
    }

    function isAdminAllReport() {
        const type = (document.getElementById('reportType')?.value || '').trim().toLowerCase();
        return currentRoleKey === 'admin' && type === 'all';
    }

    function isRecipientRequiredForAction(action) {
        if (action === 'submit') return true;
        if ((action === 'save' || action === 'export') && isAdminAllReport()) return false;
        return true;
    }

    function updateRecipientUiState() {
        const label = document.getElementById('reportRecipientLabel');

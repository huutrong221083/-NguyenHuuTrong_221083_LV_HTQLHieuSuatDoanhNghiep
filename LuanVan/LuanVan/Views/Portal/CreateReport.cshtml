@{
    var roleKey = (ViewData["RoleKey"]?.ToString() ?? "employee").Trim().ToLowerInvariant();
}

<style>
    /* ===== CREATE REPORT MAIN STYLES ===== */
    :root {
        --primary: #0066cc;
        --primary-light: #e6f2ff;
        --success: #10b981;
        --warning: #f59e0b;
        --danger: #ef4444;
        --bg-white: #ffffff;
        --bg-light: #f8fafc;
        --border-color: #e2e8f0;
        --text-dark: #1e293b;
        --text-muted: #64748b;
        --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
        --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }

    .create-report-container {
        display: flex;
        gap: 24px;
        padding-bottom: 40px;
    }

    .compact-mode .create-report-container {
        display: block;
        gap: 0;
        padding-bottom: 20px;
    }

    /* ===== PAGE HEADER ===== */
    .report-header {
        padding: 32px 24px;
        background: linear-gradient(135deg, var(--primary-light) 0%, #fff 100%);
        border-bottom: 2px solid var(--border-color);
        margin-bottom: 24px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .compact-mode .report-header {
        padding: 20px 20px 14px;
        margin-bottom: 14px;
    }

    .report-header-content h1 {
        font-size: 32px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 8px 0;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .report-header-content h1 i {
        font-size: 36px;
        color: var(--primary);
    }

    .report-header-content p {
        color: var(--text-muted);
        font-size: 14px;
        margin: 0;
    }

    .compact-mode .report-header-content p {
        font-size: 13px;
    }

    .report-header-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .btn-report {
        padding: 10px 20px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
        text-decoration: none;
    }

    .btn-draft {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        color: var(--text-dark);
    }

    .btn-draft:hover {
        background: #eef2ff;
        border-color: var(--primary);
    }

    .btn-preview {
        background: transparent;
        border: 2px solid var(--primary);
        color: var(--primary);
    }

    .btn-preview:hover {
        background: var(--primary-light);
    }

    .btn-history {
        background: #0f172a;
        color: #ffffff;
    }

    .btn-history:hover {
        background: #1e293b;
        color: #ffffff;
    }

    .btn-send {
        background: var(--success);
        color: white;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-send:hover {
        background: #059669;
        box-shadow: 0 6px 16px rgba(16, 185, 129, 0.4);
    }

    .status-badge {
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        background: var(--bg-light);
        color: var(--text-dark);
        border: 1px solid var(--border-color);
    }

    .status-badge.draft { background: #fef3c7; color: #92400e; border-color: #fbbf24; }
    .status-badge.unsent { background: #dbeafe; color: #1e40af; border-color: #60a5fa; }
    .status-badge.sent { background: #dcfce7; color: #15803d; border-color: #4ade80; }
    .status-badge.overdue { background: #fee2e2; color: #991b1b; border-color: #fca5a5; }

    /* ===== REQUEST NOTIFICATION SECTION ===== */
    .request-notification-card {
        background: var(--bg-white);
        border: 2px solid var(--warning);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 24px;
        box-shadow: 0 4px 12px rgba(245, 158, 11, 0.15);
    }

    .request-notification-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
    }

    .request-notification-header i {
        font-size: 24px;
        color: var(--warning);
    }

    .request-notification-header h3 {
        margin: 0;
        font-size: 16px;
        font-weight: 700;
        color: var(--text-dark);
    }

    .request-count {
        margin-left: auto;
        background: var(--warning);
        color: white;
        padding: 6px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 700;
    }

    .request-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 16px;
    }

    .request-item {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        border-radius: 10px;
        padding: 16px;
        border-left: 4px solid var(--warning);
    }

    .request-item-header {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        margin-bottom: 12px;
    }

    .requester-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: linear-gradient(135deg, var(--primary), #667eea);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 14px;
    }

    .request-meta h4 {
        margin: 0 0 4px 0;
        font-size: 14px;
        font-weight: 700;
        color: var(--text-dark);
    }

    .request-meta p {
        margin: 0;
        font-size: 12px;
        color: var(--text-muted);
    }

    .request-item-content {
        margin-bottom: 12px;
    }

    .request-item-content p {
        margin: 0 0 8px 0;
        font-size: 13px;
        color: var(--text-dark);
        font-weight: 500;
    }

    .request-item-deadline {
        display: inline-block;
        background: #fee2e2;
        color: #991b1b;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .request-item-priority {
        display: inline-block;
        margin-left: 8px;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .priority-high { background: #fee2e2; color: #991b1b; }
    .priority-medium { background: #fef3c7; color: #92400e; }
    .priority-low { background: #dbeafe; color: #1e40af; }

    .request-item-actions {
        display: flex;
        gap: 8px;
        margin-top: 12px;
    }

    .request-item-actions button {
        flex: 1;
        padding: 6px 10px;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        background: var(--bg-white);
        color: var(--text-dark);
        font-size: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
    }

    .request-item-actions button:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .request-item-empty {
        color: var(--text-muted);
        text-align: center;
        padding: 24px;
        font-size: 13px;
    }

    /* ===== MAIN FORM AREA ===== */
    .report-form-wrapper {
        flex: 1;
    }

    .form-section {
        background: var(--bg-white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: var(--shadow-sm);
    }

    .compact-mode .form-section {
        padding: 18px;
        margin-bottom: 14px;
    }

    .compact-mode .request-notification-card {
        padding: 14px;
        margin-bottom: 14px;
    }

    .compact-mode .request-list {
        grid-template-columns: 1fr;
        gap: 10px;
        max-height: 280px;
        overflow-y: auto;
        padding-right: 4px;
    }

    .compact-mode .report-sidebar,
    .compact-mode .ai-assistant-card,
    .compact-mode .attachment-section,
    .compact-mode #btnPreview,
    .compact-mode .report-preview-modal {
        display: none !important;
    }

    .form-section-title {
        font-size: 16px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 20px 0;
        padding-bottom: 12px;
        border-bottom: 2px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-section-title i {
        color: var(--primary);
        font-size: 18px;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group:last-child {
        margin-bottom: 0;
    }

    .form-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-label.required::after {
        content: " *";
        color: var(--danger);
    }

    .form-control,
    .form-select,
    .form-textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-size: 13px;
        font-family: inherit;
        background: var(--bg-white);
        color: var(--text-dark);
        transition: all 0.2s;
    }

    .form-control:focus,
    .form-select:focus,
    .form-textarea:focus {
        outline: none;
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(0, 102, 204, 0.1);
    }

    .form-row {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
    }

    .form-row.full {
        grid-template-columns: 1fr;
    }

    .form-textarea {
        resize: vertical;
        min-height: 100px;
    }

    /* ===== WORK ITEMS SELECTION ===== */
    .work-items-container {
        margin-top: 16px;
        max-height: 400px;
        overflow-y: auto;
    }

    .work-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 8px;
        background: var(--bg-light);
        cursor: pointer;
        transition: all 0.2s;
    }

    .work-item:hover {
        background: var(--primary-light);
        border-color: var(--primary);
    }

    .work-item input[type="checkbox"] {
        width: 18px;
        height: 18px;
        cursor: pointer;
    }

    .work-item-info {
        flex: 1;
    }

    .work-item-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text-dark);
        margin: 0 0 4px 0;
    }

    .work-item-details {
        display: flex;
        gap: 12px;
        font-size: 12px;
        color: var(--text-muted);
    }

    .work-item-progress {
        width: 60px;
    }

    .progress-bar {
        height: 6px;
        background: var(--border-color);
        border-radius: 3px;
        overflow: hidden;
        margin-bottom: 4px;
    }

    .progress-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--primary), #667eea);
        border-radius: 3px;
    }

    .work-item-status {
        padding: 4px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }

    .status-ontime { background: #dcfce7; color: #15803d; }
    .status-delayed { background: #fee2e2; color: #991b1b; }
    .status-completed { background: #dbeafe; color: #1e40af; }

    /* ===== RICH TEXT EDITOR ===== */
    .editor-toolbar {
        display: flex;
        gap: 8px;
        padding: 12px;
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        border-bottom: none;
        border-radius: 8px 8px 0 0;
        flex-wrap: wrap;
    }

    .editor-toolbar button {
        padding: 6px 10px;
        border: 1px solid var(--border-color);
        background: var(--bg-white);
        color: var(--text-dark);
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
        transition: all 0.2s;
    }

    .editor-toolbar button:hover {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
    }

    .editor-content {
        min-height: 200px;
        padding: 12px;
        border: 1px solid var(--border-color);
        border-radius: 0 0 8px 8px;
        background: var(--bg-white);
        font-size: 13px;
    }

    /* ===== KPI SECTION ===== */
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 16px;
        margin-top: 16px;
    }

    .kpi-card {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 16px;
        text-align: center;
    }

    .kpi-card-label {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 8px;
    }

    .kpi-card-value {
        font-size: 28px;
        font-weight: 700;
        color: var(--primary);
        margin-bottom: 8px;
    }

    .kpi-card-progress {
        height: 6px;
        background: var(--border-color);
        border-radius: 3px;
        overflow: hidden;
    }

    .kpi-status {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 8px;
    }

    /* ===== AI ASSISTANT SECTION ===== */
    .ai-assistant-card {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border-radius: 12px;
        padding: 24px;
        margin-bottom: 24px;
        box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    }

    .ai-assistant-card h3 {
        margin: 0 0 12px 0;
        font-size: 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .ai-assistant-card p {
        margin: 0 0 16px 0;
        font-size: 13px;
        opacity: 0.95;
    }

    .btn-ai {
        background: white;
        color: #667eea;
        padding: 10px 20px;
        border: none;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn-ai:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
    }

    /* ===== ATTACHMENT SECTION ===== */
    .attachment-upload {
        border: 2px dashed var(--border-color);
        border-radius: 8px;
        padding: 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
    }

    .attachment-upload:hover {
        border-color: var(--primary);
        background: var(--primary-light);
    }

    .attachment-upload i {
        font-size: 28px;
        color: var(--primary);
        margin-bottom: 8px;
        display: block;
    }

    .attachment-upload p {
        margin: 0 0 8px 0;
        font-size: 13px;
        font-weight: 600;
        color: var(--text-dark);
    }

    .attachment-upload span {
        font-size: 12px;
        color: var(--text-muted);
    }

    .attachment-list {
        margin-top: 16px;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 12px;
    }

    .attachment-item {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 12px;
        text-align: center;
        position: relative;
    }

    .attachment-item i {
        font-size: 20px;
        color: var(--primary);
        display: block;
        margin-bottom: 8px;
    }

    .attachment-item-name {
        font-size: 12px;
        color: var(--text-dark);
        font-weight: 600;
        word-break: break-word;
        margin-bottom: 4px;
    }

    .attachment-item-size {
        font-size: 11px;
        color: var(--text-muted);
    }

    .attachment-item-remove {
        position: absolute;
        top: 4px;
        right: 4px;
        background: var(--danger);
        color: white;
        border: none;
        border-radius: 50%;
        width: 20px;
        height: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        font-size: 12px;
        opacity: 0;
        transition: opacity 0.2s;
    }

    .attachment-item:hover .attachment-item-remove {
        opacity: 1;
    }

    /* ===== SIDEBAR ===== */
    .report-sidebar {
        width: 300px;
    }

    /* Responsive media queries removed - desktop-first approach */

    .sidebar-card {
        background: var(--bg-white);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 20px;
        margin-bottom: 20px;
        box-shadow: var(--shadow-sm);
    }

    .sidebar-card-title {
        font-size: 14px;
        font-weight: 700;
        color: var(--text-dark);
        margin: 0 0 16px 0;
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .sidebar-card-title i {
        color: var(--primary);
    }

    .progress-item {
        margin-bottom: 16px;
    }

    .progress-item:last-child {
        margin-bottom: 0;
    }

    .progress-item-label {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 6px;
    }

    .progress-item-bar {
        height: 8px;
        background: var(--border-color);
        border-radius: 4px;
        overflow: hidden;
    }

    .progress-item-fill {
        height: 100%;
        background: linear-gradient(90deg, var(--primary), #667eea);
        border-radius: 4px;
    }

    .countdown {
        background: linear-gradient(135deg, #f59e0b, #f97316);
        color: white;
        padding: 16px;
        border-radius: 8px;
        text-align: center;
    }

    .countdown-label {
        font-size: 12px;
        font-weight: 600;
        opacity: 0.9;
        margin-bottom: 6px;
    }

    .countdown-time {
        font-size: 20px;
        font-weight: 700;
    }

    .history-item {
        padding: 12px;
        border: 1px solid var(--border-color);
        border-radius: 6px;
        margin-bottom: 8px;
    }

    .history-item-date {
        font-size: 12px;
        font-weight: 700;
        color: var(--text-dark);
    }

    .history-item-status {
        font-size: 11px;
        color: var(--text-muted);
        margin-top: 4px;
    }

    /* ===== ACTION BUTTONS ===== */
    .form-actions {
        display: flex;
        gap: 12px;
        margin-top: 32px;
        padding-top: 24px;
        border-top: 1px solid var(--border-color);
    }

    .btn-action {
        padding: 12px 24px;
        border-radius: 8px;
        border: none;
        font-weight: 600;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
    }

    .btn-action.primary {
        background: var(--success);
        color: white;
        flex: 1;
    }

    .btn-action.primary:hover {
        background: #059669;
        box-shadow: 0 4px 12px rgba(16, 185, 129, 0.3);
    }

    .btn-action.secondary {
        background: var(--bg-light);
        border: 1px solid var(--border-color);
        color: var(--text-dark);
    }

    .btn-action.secondary:hover {
        background: #eef2ff;
    }

    /* ===== RESPONSIVE ===== */
    /* Responsive media queries removed - desktop-first approach */

    /* ===== PREVIEW MODAL ===== */
    .report-preview-modal {
        position: fixed;
        inset: 0;
        display: none;
        align-items: center;
        justify-content: center;
        background: rgba(15, 23, 42, 0.72);
        z-index: 3000;
        padding: 24px;
        backdrop-filter: blur(6px);
    }

    .report-preview-modal.open {
        display: flex;
    }

    .report-preview-dialog {
        width: min(1080px, 100%);
        max-height: 92vh;
        background: white;
        border-radius: 20px;
        box-shadow: 0 30px 80px rgba(15, 23, 42, 0.35);
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .report-preview-header {
        padding: 20px 24px;
        background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
        color: white;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
    }

    .report-preview-title {
        margin: 0;
        font-size: 20px;
        font-weight: 700;
    }

    .report-preview-body {
        padding: 24px;
        overflow: auto;
        background: #f8fafc;
    }

    .report-preview-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
    }

    .report-preview-content {
        background: white;
        border: 1px solid var(--border-color);
        border-radius: 16px;
        padding: 24px;
    }

    .preview-section {
        margin-bottom: 18px;
        padding-bottom: 18px;
        border-bottom: 1px solid #e5e7eb;
    }

    .preview-section:last-child {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: 0;
    }

    .preview-section h4 {
        margin: 0 0 10px 0;
        font-size: 15px;
        color: var(--text-dark);
    }

    .preview-meta {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .preview-meta-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 12px;
        font-size: 13px;
    }

    .preview-meta-item strong {
        display: block;
        margin-bottom: 4px;
        color: var(--text-dark);
    }

    .preview-task-list {
        display: grid;
        gap: 8px;
    }

    .preview-task-item {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 10px 12px;
        font-size: 13px;
    }

    @@media print {
        .report-preview-modal,
        .report-header,
        .form-actions,
        .report-sidebar,
        .ai-assistant-card,
        .request-notification-card {
            display: none !important;
        }

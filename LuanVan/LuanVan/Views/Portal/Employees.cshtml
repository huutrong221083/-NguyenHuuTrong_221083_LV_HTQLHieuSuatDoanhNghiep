            const escapeHtml = (value) => String(value ?? '')
                .replaceAll('&', '&amp;')
                .replaceAll('<', '&lt;')
                .replaceAll('>', '&gt;')
                .replaceAll('"', '&quot;')
                .replaceAll("'", '&#39;');

            const toDateInput = (value) => {
                if (!value) return '';
                const d = new Date(value);
                if (Number.isNaN(d.getTime())) return '';
                return d.toISOString().slice(0, 10);
            };

            const avatarText = (fullName) => {
                const words = String(fullName || 'NV').trim().split(' ').filter(Boolean);
                return (words[0]?.[0] || 'N') + (words[words.length - 1]?.[0] || 'V');
            };

            const toTime = (value) => {
                if (!value) return Number.NaN;
                const d = new Date(value);
                return Number.isNaN(d.getTime()) ? Number.NaN : d.getTime();
            };

            const levelMeta = (value) => {
                const v = Number(value || 1);
                if (v <= 1) return { text: 'Beginner', css: 'lv-beginner' };
                if (v === 2) return { text: 'Intermediate', css: 'lv-intermediate' };
                if (v === 3) return { text: 'Advanced', css: 'lv-advanced' };
                return { text: 'Expert', css: 'lv-expert' };
            };

            const kpiMeta = (value) => {
                const v = Number(value || 0);
                if (v >= 80) return { css: 'kpi-high', label: 'Tốt' };
                if (v >= 50) return { css: 'kpi-mid', label: 'Cần theo dõi' };
                return { css: 'kpi-low', label: 'Cần cải thiện' };
            };

            const getEmployeeStatus = (value) => {
                if (Number(value) === 1) return { text: 'Đang làm việc', css: 'dot-active' };
                if (Number(value) === 2) return { text: 'Tạm nghỉ', css: 'dot-pause' };
                return { text: 'Nghỉ việc', css: 'dot-inactive' };
            };


                `;
            }

            async function loadNhanVien() {
                employeeBody.innerHTML = '<tr><td colspan="8" class="text-muted">Đang tải dữ liệu...</td></tr>';

                const query = new URLSearchParams({ page: String(state.page), size: String(state.size) });
                if (keywordInput.value.trim()) query.set('keyword', keywordInput.value.trim());
                if (phongBanSelect.value) query.set('phongban', phongBanSelect.value);
                if (chucVuSelect.value) query.set('chucvu', chucVuSelect.value);
                const statusQuery = normalizeStatusFilter(trangThaiSelect.value);
                if (statusQuery) query.set('trangthai', statusQuery);
                const [sortBy, sortDir] = String(sortBySelect.value || 'name:asc').split(':');
                query.set('sortBy', sortBy || 'name');
                query.set('sortDir', sortDir || 'asc');

                const result = await fetchJson(`/nhanvien?${query.toString()}`);
                if (!result.success) {
                    employeeBody.innerHTML = `<tr><td colspan="8" class="text-danger">${escapeHtml(result.message || 'Không tải được dữ liệu')}</td></tr>`;
                    return;
                }

                let items = result.data?.items || [];
                state.totalItems = result.data?.totalItems || items.length;
                state.totalPages = Math.max(1, result.data?.totalPages || 1);

                // Batch-load KPI scores for the current page using dedicated scores endpoint
                const ids = items.map(i => i.maNhanVien).filter(Boolean).join(',');
                const kpiMap = new Map();
                if (ids) {
                    const kpiListRes = await fetchJson(`/kpi/scores?ids=${encodeURIComponent(ids)}`);
                    if (kpiListRes.success) {
                        const obj = kpiListRes.data?.items || kpiListRes.data || {};
                        for (const [key, val] of Object.entries(obj)) {
                            const id = Number(key);
                            const score = Number(val || 0);
                            if (!Number.isNaN(id)) kpiMap.set(id, score);
                        }
                    }
                }

                const details = await Promise.all(items.map(async (item) => {
                    const detailRes = await fetchJson(`/nhanvien/${item.maNhanVien}`);
                    const kpiCached = kpiMap.has(item.maNhanVien) ? { avg: kpiMap.get(item.maNhanVien), latest: kpiMap.get(item.maNhanVien), history: [] } : await loadEmployeeKpi(item.maNhanVien);

                    return {
                        id: item.maNhanVien,
                        detail: detailRes.success ? detailRes.data : null,
                        kpi: kpiCached
                    };
                }));

                state.employeeDetailMap = new Map(details.map(x => [x.id, x.detail]));
                for (const row of details) {
                    state.employeeKpiMap.set(row.id, row.kpi || { avg: 0, latest: 0, history: [] });
                }

                items = applyAdvancedClientFilters(items);
                renderMiniDashboard(items);

                if (items.length === 0) {
                    employeeBody.innerHTML = '<tr><td colspan="8" class="text-muted">Không có nhân viên phù hợp.</td></tr>';
                    employeeSummary.textContent = `Tổng số nhân viên: ${state.totalItems}`;
                    pageInfo.textContent = `${state.page}/${state.totalPages}`;
                    renderSkillAnalysis([]);
                    return;
                }

                employeeBody.innerHTML = items.map(item => {
                    const detail = state.employeeDetailMap.get(item.maNhanVien);
                    const chucVu = item.tenChucVu || detail?.tenChucVu || '-';
                    const kpi = state.employeeKpiMap.get(item.maNhanVien)?.latest || 0;

                    return `
                        <tr data-row-id="${item.maNhanVien}" class="hr-row-clickable">
                            <td>${renderAvatar(item)}</td>
                            <td>
                                <button class="btn btn-link p-0 hr-name-link" data-open-drawer="${item.maNhanVien}" type="button">${escapeHtml(item.hoTen || '-')}</button>
                                <div class="small text-muted">${escapeHtml(item.email || '-')}</div>
                            </td>
                            <td>${escapeHtml(item.tenPhongBan || '-')}</td>
                            <td>${roleBadge(chucVu)}</td>
                            <td>${renderKpiProgress(kpi)}</td>
                            <td>${renderSkillPreviewTags(detail)}</td>
                            <td>${statusBadge(item.trangThai)}</td>
                            <td class="text-end">
                                ${role !== 'employee' ? `<button class="btn btn-sm btn-outline-warning" title="Yêu cầu báo cáo" onclick="window.requestEmployeeReport(${item.maNhanVien}, '${escapeHtml(item.hoTen || 'Nhân viên')}')"><i class="bi bi-send"></i></button>` : ''}
                                <button class="btn btn-sm btn-light" title="Xem chi tiết" onclick="window.openEmployeeDrawer(${item.maNhanVien})"><i class="bi bi-eye"></i></button>
                                <button class="btn btn-sm btn-outline-primary" title="Sửa" onclick="window.openEditEmployee(${item.maNhanVien})"><i class="bi bi-pencil"></i></button>
                                ${role !== 'employee' ? (Number(item.trangThai) === 1
                                    ? `<button class="btn btn-sm btn-outline-warning" title="Chuyển sang nghỉ việc" onclick="window.toggleEmployeeStatus(${item.maNhanVien}, ${Number(item.trangThai || 0)})"><i class="bi bi-person-dash"></i></button>`
                                    : `<button class="btn btn-sm btn-outline-success" title="Kích hoạt nhân viên" onclick="window.toggleEmployeeStatus(${item.maNhanVien}, ${Number(item.trangThai || 0)})"><i class="bi bi-person-check"></i></button>`)
                                : ''}
                                ${role === 'admin' ? `<button class="btn btn-sm btn-outline-danger" title="Xóa" onclick="window.deleteEmployee(${item.maNhanVien})"><i class="bi bi-trash"></i></button>` : ''}
                            </td>
                        </tr>
                    `;
                }).join('');

                employeeSummary.textContent = `Hiển thị ${items.length}/${state.totalItems} nhân viên`;
                pageInfo.textContent = `${state.page}/${state.totalPages}`;
                state.items = items;
                renderSkillAnalysis(items);
            }

            function setCatalogMessage(text, css = 'text-muted') {
                catalogSkillMessage.className = `small ${css}`;
                catalogSkillMessage.textContent = text || '';
            }

            function normalizeSkillName(value) {
                return String(value || '').trim().toLowerCase();
            }

            function isDuplicateSkillName(name, exceptId = null) {
                const key = normalizeSkillName(name);
                if (!key) return false;
                return state.skillCatalog.some(s => normalizeSkillName(s.tenKyNang) === key && Number(s.maKyNang) !== Number(exceptId));
            }

            function showInlineCatalogForm() {
                state.catalogInlineMode = 'add';
                state.editingCatalogSkillId = null;
                catalogInlineForm.classList.remove('d-none');
                inlineCatalogSkillName.value = '';
                inlineCatalogSkillDesc.value = '';
                setCatalogMessage('');
                inlineCatalogSkillName.focus();
                renderCatalogSkillTable();
            }

            function hideInlineCatalogForm() {
                state.catalogInlineMode = null;
                catalogInlineForm.classList.add('d-none');
                inlineCatalogSkillName.value = '';
                inlineCatalogSkillDesc.value = '';
                setCatalogMessage('');
            }

            function renderCatalogSkillTable() {
                const keyword = (catalogSkillKeyword.value || '').trim().toLowerCase();
                const rows = [...state.skillCatalog]
                    .sort((a, b) => String(a.tenKyNang || '').localeCompare(String(b.tenKyNang || ''), 'vi', { sensitivity: 'base' }))
                    .filter(s => {
                        if (!keyword) return true;
                        const name = (s.tenKyNang || '').toLowerCase();
                        const desc = (s.moTa || '').toLowerCase();
                        return name.includes(keyword) || desc.includes(keyword);
                    });

                if (!rows.length) {
                    catalogSkillBody.innerHTML = '<tr><td colspan="3" class="text-muted">Không có kỹ năng phù hợp.</td></tr>';
                    return;
                }

                catalogSkillBody.innerHTML = rows.map(s => {
                    const isEditing = state.catalogInlineMode === 'edit-row' && Number(state.editingCatalogSkillId) === Number(s.maKyNang);
                    const isFresh = Number(state.recentCatalogSkillId) === Number(s.maKyNang);

                    if (isEditing) {
                        return `
                            <tr class="hr-catalog-row-edit">
                                <td><input id="editCatalogName-${s.maKyNang}" class="form-control form-control-sm" value="${escapeHtml(s.tenKyNang || '')}" /></td>
                                <td><input id="editCatalogDesc-${s.maKyNang}" class="form-control form-control-sm" value="${escapeHtml(s.moTa || '')}" /></td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-primary" onclick="window.saveInlineCatalogEdit(${s.maKyNang})">Lưu</button>
                                    <button class="btn btn-sm btn-light" onclick="window.cancelInlineCatalogEdit()">Hủy</button>
                                </td>
                            </tr>
                        `;
                    }

                    return `
                        <tr class="${isFresh ? 'hr-fresh-skill' : ''}">
                            <td>${escapeHtml(s.tenKyNang || '')}</td>
                            <td>${escapeHtml(s.moTa || '-')}</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary" title="Sửa" onclick="window.openEditCatalogSkill(${s.maKyNang})"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" title="Xóa" onclick="window.deleteCatalogSkill(${s.maKyNang})"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    `;
                }).join('');
            }

            function renderSkillAnalysis(items = []) {
                const detailMap = new Map(items.map(item => [item.maNhanVien, state.employeeDetailMap.get(item.maNhanVien)]));
                const details = [...detailMap.values()].filter(Boolean);
                if (!details.length) {
                    popularSkillName.textContent = '--';
                    popularSkillCount.textContent = 'Chưa có dữ liệu';
                    popularSkillBars.textContent = '--';
                    missingSkillAlert.textContent = 'Chưa có dữ liệu';
                    missingSkillList.textContent = 'Chưa có dữ liệu';
                    topKpiEmployees.textContent = 'Chưa có dữ liệu';
                    return;
                }

                const freq = new Map();
                for (const d of details) {
                    for (const s of d.skills || []) {
                        const key = s.maKyNang;
                        if (!freq.has(key)) {
                            freq.set(key, { count: 0, tenKyNang: s.tenKyNang || '' });
                        }
                        freq.get(key).count += 1;
                    }
                }

                if (!freq.size) {
                    popularSkillName.textContent = 'Chưa có kỹ năng';
                    popularSkillCount.textContent = 'Chưa có dữ liệu';
                    popularSkillBars.textContent = '--';
                    missingSkillAlert.textContent = 'Chưa có dữ liệu';
                    missingSkillList.textContent = 'Chưa có dữ liệu';
                    topKpiEmployees.textContent = 'Chưa có dữ liệu';
                    return;
                }

                const sortedSkill = [...freq.entries()].sort((a, b) => b[1].count - a[1].count);
                const topEntry = sortedSkill[0];
                const topSkillId = topEntry[0];
                const top = topEntry[1];

                popularSkillName.textContent = top.tenKyNang;
                popularSkillCount.textContent = `${top.count} nhân viên đang sở hữu`;
                const maxSkillCount = sortedSkill[0][1].count || 1;
                popularSkillBars.innerHTML = sortedSkill.slice(0, 5).map(([, value]) => {
                    const width = Math.max(8, Math.round((value.count / maxSkillCount) * 100));
                    return `
                        <div class="hr-skill-bar-item" title="${escapeHtml(value.tenKyNang)}: ${value.count}">
                            <span>${escapeHtml(value.tenKyNang)}</span>
                            <div class="hr-skill-bar-track"><div class="hr-skill-bar-fill" style="width:${width}%"></div></div>
                        </div>
                    `;
                }).join('');

                const missing = details
                    .filter(d => d.trangThai === 1)
                    .filter(d => !(d.skills || []).some(s => s.maKyNang === topSkillId))
                    .slice(0, 6)
                    .map(d => d.hoTen || `NV ${d.maNhanVien}`);

                const missingByDepartment = new Map();
                for (const d of details.filter(x => x.trangThai === 1)) {
                    const hasTopSkill = (d.skills || []).some(s => s.maKyNang === topSkillId);
                    if (hasTopSkill) continue;

                    const deptName = d.tenPhongBan || `Phòng ${d.maPhongBan || '-'}`;
                    if (!missingByDepartment.has(deptName)) missingByDepartment.set(deptName, 0);
                    missingByDepartment.set(deptName, missingByDepartment.get(deptName) + 1);
                }

                const severeDept = [...missingByDepartment.entries()].sort((a, b) => b[1] - a[1])[0];
                if (!severeDept) {
                    missingSkillAlert.innerHTML = `<span class="text-success">Không có cảnh báo thiếu kỹ năng trong bộ lọc hiện tại.</span>`;
                } else {
                    missingSkillAlert.textContent = `${severeDept[0]} thiếu ${severeDept[1]} nhân viên có kỹ năng ${top.tenKyNang}.`;
                }

                if (!missing.length) {
                    missingSkillList.innerHTML = `<span class="text-success">Tất cả nhân viên đang có ${escapeHtml(top.tenKyNang)}.</span>`;
                } else {
                    missingSkillList.innerHTML = missing.map(x => `<span class="hr-missing-item">${escapeHtml(x)}</span>`).join('');
                }

                const topKpis = items
                    .map(item => ({
                        name: item.hoTen || `NV ${item.maNhanVien}`,
                        score: Number(state.employeeKpiMap.get(item.maNhanVien)?.latest || 0)
                    }))
                    .sort((a, b) => b.score - a.score)
                    .slice(0, 5);

                if (!topKpis.length) {
                    topKpiEmployees.innerHTML = '<span class="text-muted">Chưa có dữ liệu KPI.</span>';
                } else {
                    topKpiEmployees.innerHTML = topKpis.map((x, idx) => `
                        <div class="hr-top-kpi-item">
                            <span class="hr-top-rank">#${idx + 1}</span>
                            <span class="hr-top-name">${escapeHtml(x.name)}</span>
                            <span class="hr-top-score">${x.score.toFixed(0)}%</span>
                        </div>
                    `).join('');
                }
            }

            function renderHistoryTab(detail) {
                const rows = detail?.lichSuHoatDong || detail?.LichSuHoatDong || [];
                if (!rows.length) {
                    historyBody.innerHTML = '<tr><td colspan="2" class="text-muted">Chưa có nhật ký hoạt động</td></tr>';
                    return;
                }

                historyBody.innerHTML = rows.map(item => `
                    <tr>
                        <td>${item.thoiGian ? new Date(item.thoiGian).toLocaleString('vi-VN') : '-'}</td>
                        <td>${escapeHtml(item.hanhDong || item.HanhDong || '-')}</td>
                    </tr>
                `).join('');
            }

            function renderSkillsTab(detail) {
                const rows = detail?.skills || [];
                const keyword = (skillKeyword.value || '').trim().toLowerCase();
                const filtered = rows.filter(s => !keyword || (s.tenKyNang || '').toLowerCase().includes(keyword));

                if (!rows.length) {
                    currentSkillTags.innerHTML = '<span class="text-muted">Nhân viên chưa có kỹ năng.</span>';
                } else {
                    currentSkillTags.innerHTML = rows.map(skill => {
                        const lv = levelMeta(skill.capDo);
                        return `<span class="hr-skill-tag ${lv.css}" title="${lv.text}">${escapeHtml(skill.tenKyNang || '')}</span>`;
                    }).join('');
                }

                if (!filtered.length) {
                    skillBody.innerHTML = '<tr><td colspan="4" class="text-muted">Không có kỹ năng phù hợp.</td></tr>';
                } else {
                    skillBody.innerHTML = filtered.map(skill => {
                        const lv = levelMeta(skill.capDo);
                        return `
                            <tr>
                                <td>${escapeHtml(skill.tenKyNang || '')}</td>
                                <td><span class="hr-level-badge ${lv.css}">${lv.text}</span></td>
                                <td>${Number(skill.soDuAnDaDung || 0)} nam</td>
                                <td class="text-end">
                                    <button class="btn btn-sm btn-outline-primary" onclick="window.openEditEmployeeSkill(${skill.maKyNang})"><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-sm btn-outline-danger" onclick="window.removeSkill(${state.selectedEmployeeId}, ${skill.maKyNang})"><i class="bi bi-trash"></i></button>
                                </td>
                            </tr>
                        `;
                    }).join('');
                }

                renderAiSuggestion(detail);
            }

            function renderAiSuggestion(detail) {
                if (!detail) {
                    aiSkillSuggestion.textContent = 'Chọn nhân viên để xem gợi ý kỹ năng AI.';
                    return;
                }

                const currentSkillIds = new Set((detail.skills || []).map(s => s.maKyNang));
                const sameDepartment = [...state.employeeDetailMap.values()]
                    .filter(Boolean)
                    .filter(x => x.maPhongBan === detail.maPhongBan);

                const freq = new Map();
                for (const emp of sameDepartment) {
                    for (const s of emp.skills || []) {
                        if (!freq.has(s.maKyNang)) {
                            freq.set(s.maKyNang, { tenKyNang: s.tenKyNang || '', count: 0 });
                        }
                        freq.get(s.maKyNang).count += 1;
                    }
                }

                const suggest = [...freq.entries()]
                    .filter(([id]) => !currentSkillIds.has(id))
                    .map(([, value]) => value)
                    .sort((a, b) => b.count - a.count)
                    .slice(0, 3);

                if (!suggest.length) {
                    aiSkillSuggestion.innerHTML = '<strong>AI Suggestion:</strong> Hồ sơ kỹ năng đã khá đầy đủ cho vị trí hiện tại.';
                    return;
                }

                const text = suggest.map(s => s.tenKyNang).filter(Boolean).join(', ');
                aiSkillSuggestion.innerHTML = `<strong>AI Suggestion:</strong> Nên học thêm ${escapeHtml(text)} để tăng năng lực liên phòng ban.`;
            }

            async function openEmployeeDrawer(id) {
                state.selectedEmployeeId = id;
                employeeDrawer.show();

                await ensureAccountMapLoaded();

                const result = await fetchJson(`/nhanvien/${id}`);
                if (!result.success) return;
                const data = result.data;
                state.selectedEmployeeDetail = data;
                renderAccountOptions(id, data.aspNetUserId || null);

                detailHoTen.value = data.hoTen || '';
                detailNgaySinh.value = toDateInput(data.ngaySinh);
                detailGioiTinh.value = data.gioiTinh || '';
                detailSdt.value = data.sdt || '';
                detailEmail.value = data.email || '';
                detailDiaChi.value = data.diaChi || '';
                detailPhongBan.value = data.maPhongBan || '';
                detailChucVu.value = data.maChucVu || '';
                const maPhongBanPhu = Number(data.phoMaPhongBan || 0);
                const phongBanPhu = maPhongBanPhu > 0
                    ? state.departments.find(x => Number(x.maPhongBan) === maPhongBanPhu)
                    : null;
                detailPhongBanPhuText.value = phongBanPhu?.tenPhongBan || '';
                detailAspNetUserId.value = data.aspNetUserId || '';
                detailCccd.value = data.cccd || '';
                detailNgayVaoLam.value = toDateInput(data.ngayVaoLam);

                renderSkillsTab(data);
                renderHistoryTab(data);
                await renderKpiTab(id);
                await renderTasksTab(id);

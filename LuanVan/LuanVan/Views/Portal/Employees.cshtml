@{
    var currentRole = (ViewData["Role"]?.ToString() ?? "Admin").Trim().ToLowerInvariant();
}

<!-- Breadcrumb removed -->

@if (currentRole == "employee")
{
    <section class="panel mt-3">
        <h4>Không có quyền truy cập</h4>
        <p class="text-muted mb-0">Vai trò Employee không được phép truy cập module Quản lý nhân sự.</p>
    </section>
}
else
{
    <section class="panel mt-3 hr-panel-modern">
        <div class="hr-toolbar mb-3">
            <div class="hr-toolbar-left">
                <div class="input-group hr-search-box">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="keyword" class="form-control" placeholder="Tìm kiếm nhân viên..." />
                </div>
                <select id="phongBan" class="form-select">
                    <option value="">Phòng ban</option>
                </select>
                <select id="chucVu" class="form-select">
                    <option value="">Chức vụ</option>
                </select>
                <select id="trangThai" class="form-select">
                    <option value="">Trạng thái</option>
                    <option value="1">Đang làm việc</option>
                    <option value="0">Nghỉ việc</option>
                </select>
                <select id="sortBy" class="form-select">
                    <option value="name:asc">Tên A-Z</option>
                    <option value="name:desc">Tên Z-A</option>
                    <option value="department:asc">Phòng ban A-Z</option>
                    <option value="department:desc">Phòng ban Z-A</option>
                </select>
                <div class="dropdown">
                    <button id="btnAdvancedFilter" class="btn btn-outline-primary dropdown-toggle" data-bs-toggle="dropdown" data-bs-auto-close="outside" type="button">
                        <i class="bi bi-funnel"></i> Bộ lọc nâng cao
                    </button>
                    <div class="dropdown-menu p-3 hr-advanced-filter">
                        <label class="form-label form-label-sm">Kỹ năng</label>
                        <select id="skillFilter" class="form-select form-select-sm mb-2">
                            <option value="">Tất cả kỹ năng</option>
                        </select>

                        <label class="form-label form-label-sm">Mức KPI</label>
                        <select id="kpiBandFilter" class="form-select form-select-sm mb-2">
                            <option value="">Tất cả</option>
                            <option value="high">>= 80</option>
                            <option value="mid">50 - 79</option>
                            <option value="low">&lt; 50</option>
                        </select>

                        <label class="form-label form-label-sm">Kinh nghiệm tối thiểu (năm)</label>
                        <input id="experienceFilter" class="form-control form-control-sm mb-2" type="number" min="0" max="50" placeholder="VD: 2" />

                        <label class="form-label form-label-sm">Ngày vào làm từ</label>
                        <input id="joinDateFrom" class="form-control form-control-sm mb-2" type="date" />

                        <label class="form-label form-label-sm">Ngày vào làm đến</label>
                        <input id="joinDateTo" class="form-control form-control-sm mb-2" type="date" />

                        <div class="d-flex gap-2">
                            <button id="btnApplyAdvancedFilter" class="btn btn-primary btn-sm flex-grow-1" type="button">Áp dụng</button>
                            <button id="btnResetAdvancedFilter" class="btn btn-light btn-sm" type="button">Reset</button>
                        </div>
                    </div>
                </div>
                <button id="btnSearch" class="btn btn-outline-secondary"><i class="bi bi-arrow-repeat"></i> Làm mới</button>
            </div>
            <div class="hr-toolbar-right">
                <button id="btnAddEmployee" class="btn btn-primary btn-hr-add"><i class="bi bi-plus-circle"></i> Thêm nhân viên</button>
                <button id="btnExport" class="btn btn-success"><i class="bi bi-file-earmark-arrow-down"></i> Xuất</button>
                <button id="btnOpenChucVuManager" class="btn btn-outline-secondary"><i class="bi bi-diagram-3"></i> Chức vụ</button>
                <button id="btnOpenCatalogManager" class="btn btn-outline-dark"><i class="bi bi-gear"></i> Danh mục kỹ năng</button>
            </div>
        </div>

        <div class="hr-kpi-mini-grid mb-3">
            <article class="hr-kpi-mini-card total">
                <div class="hr-kpi-mini-icon"><i class="bi bi-people"></i></div>
                <div>
                    <p class="hr-kpi-mini-label">Tổng nhân sự</p>
                    <div id="kpiTotalEmployees" class="hr-kpi-mini-value">0</div>
                </div>
            </article>
            <article class="hr-kpi-mini-card active">
                <div class="hr-kpi-mini-icon"><i class="bi bi-check2-circle"></i></div>
                <div>
                    <p class="hr-kpi-mini-label">Đang làm việc</p>
                    <div id="kpiActiveEmployees" class="hr-kpi-mini-value">0</div>
                </div>
            </article>
            <article class="hr-kpi-mini-card inactive">
                <div class="hr-kpi-mini-icon"><i class="bi bi-x-circle"></i></div>
                <div>
                    <p class="hr-kpi-mini-label">Nghỉ việc / Tạm nghỉ</p>
                    <div id="kpiInactiveEmployees" class="hr-kpi-mini-value">0</div>
                </div>
            </article>
            <article class="hr-kpi-mini-card avg">
                <div class="hr-kpi-mini-icon"><i class="bi bi-star"></i></div>
                <div>
                    <p class="hr-kpi-mini-label">KPI trung bình</p>
                    <div id="kpiAverage" class="hr-kpi-mini-value">0%</div>
                </div>
            </article>
        </div>

        <div class="table-responsive mt-2">
            <table class="table table-hover align-middle hr-table">
                <thead>
                    <tr>
                        <th>Avatar</th>
                        <th>Họ tên</th>
                        <th>Phòng ban</th>
                        <th>Chức vụ</th>
                        <th>KPI</th>
                        <th>Kỹ năng</th>
                        <th>Trạng thái</th>
                        <th class="text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="employeeBody">
                    <tr><td colspan="8" class="text-muted">Đang tải dữ liệu...</td></tr>
                </tbody>
            </table>
        </div>

        <div class="hr-footer">
            <small id="employeeSummary" class="text-muted"></small>
            <div class="d-flex align-items-center gap-2">
                <label class="text-muted">Số dòng:</label>
                <select id="pageSize" class="form-select form-select-sm hr-pagesize">
                    <option value="10" selected>10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
                <button id="btnPrevPage" class="btn btn-sm btn-light">Trước</button>
                <span id="pageInfo" class="text-muted">1/1</span>
                <button id="btnNextPage" class="btn btn-sm btn-light">Sau</button>
            </div>
        </div>
    </section>

    <section class="panel mt-3 hr-analysis-panel">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
            <h4 class="mb-0">Phân tích năng lực</h4>
            <small class="text-muted">AI gợi ý dựa trên dữ liệu kỹ năng hiện có</small>
        </div>
        <div class="hr-analysis-grid">
            <article class="hr-analysis-card">
                <h6>Skill phổ biến nhất</h6>
                <div id="popularSkillName" class="hr-analysis-value">--</div>
                <p id="popularSkillCount" class="text-muted mb-0">Chưa có dữ liệu</p>
                <div id="popularSkillBars" class="hr-skill-bars text-muted">--</div>
            </article>
            <article class="hr-analysis-card">
                <h6>Cảnh báo thiếu kỹ năng</h6>
                <div id="missingSkillAlert" class="hr-alert-line text-muted">Chưa có dữ liệu</div>
                <div id="missingSkillList" class="hr-analysis-list text-muted mt-2">Chưa có dữ liệu</div>
            </article>
            <article class="hr-analysis-card">
                <h6>Nhân viên nổi bật (Top KPI)</h6>
                <div id="topKpiEmployees" class="hr-top-kpi-list text-muted">Chưa có dữ liệu</div>
            </article>
        </div>
    </section>

    <div class="offcanvas offcanvas-end hr-drawer" tabindex="-1" id="employeeDrawer" aria-labelledby="employeeDrawerLabel">
        <div class="offcanvas-header">
            <h5 id="employeeDrawerLabel" class="offcanvas-title">Chi tiết nhân viên</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="nav nav-tabs" id="employeeDetailTabs" role="tablist">
                <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tabPersonal" type="button">Thông tin</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabTasks" type="button">Công việc</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabKpi" type="button">KPI</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabSkills" type="button">Kỹ năng</button></li>
                <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tabHistory" type="button">Lịch sử</button></li>
            </ul>

            <div class="tab-content pt-3">
                <div class="tab-pane fade show active" id="tabPersonal">
                    <form id="personalForm" class="row g-2">
                        <div class="col-12"><label class="form-label">Họ tên</label><input id="detailHoTen" class="form-control" placeholder="Nhập họ tên" required /></div>
                        <div class="col-6"><label class="form-label">Ngày sinh</label><input id="detailNgaySinh" type="date" class="form-control" required /></div>
                        <div class="col-6"><label class="form-label">Giới tính</label><select id="detailGioiTinh" class="form-select"><option value="">Chọn</option><option value="Nam">Nam</option><option value="Nữ">Nữ</option></select></div>
                        <div class="col-6"><label class="form-label">SDT</label><input id="detailSdt" class="form-control" placeholder="Nhập số điện thoại" inputmode="numeric" pattern="[0-9]{10}" minlength="10" maxlength="10" required /></div>
                        <div class="col-6"><label class="form-label">Email</label><input id="detailEmail" type="email" class="form-control" required /></div>
                        <div class="col-12"><label class="form-label">Địa chỉ</label><input id="detailDiaChi" class="form-control" placeholder="Nhập địa chỉ" /></div>
                        <div class="col-6"><label class="form-label">Phòng ban</label><select id="detailPhongBan" class="form-select" required></select></div>
                        <div class="col-6"><label class="form-label">Chức vụ</label><select id="detailChucVu" class="form-select" required></select></div>
                        <div class="col-6"><label class="form-label">Phòng ban phụ (nếu có)</label><input id="detailPhongBanPhuText" class="form-control" readonly /></div>
                        <div class="col-6"><label class="form-label">Tài khoản liên kết</label><select id="detailAspNetUserId" class="form-select"><option value="">Không liên kết</option></select></div>
                        <div class="col-6"><label class="form-label">CCCD (không sửa)</label><input id="detailCccd" class="form-control" disabled /></div>
                        <div class="col-6"><label class="form-label">Ngày vào làm</label><input id="detailNgayVaoLam" type="date" class="form-control" required /></div>
                        <div class="col-12 d-flex justify-content-end"><button type="button" id="btnSavePersonal" class="btn btn-primary btn-sm">Lưu thay đổi</button></div>
                    </form>
                </div>

                <div class="tab-pane fade" id="tabTasks">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Tên công việc</th><th>Dự án</th><th>Deadline</th><th>Tiến độ</th><th>Trạng thái</th></tr></thead>
                            <tbody id="taskBody"><tr><td colspan="5" class="text-muted">Chưa có dữ liệu công việc</td></tr></tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="tabKpi">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Tháng/Năm</th><th>Điểm</th><th>Xếp loại</th></tr></thead>
                            <tbody id="kpiBody"><tr><td colspan="3" class="text-muted">Chưa có dữ liệu KPI</td></tr></tbody>
                        </table>
                    </div>
                </div>

                <div class="tab-pane fade" id="tabSkills">
                    <div class="hr-skill-section mb-3">
                        <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap mb-2">
                            <h6 class="mb-0">Kỹ năng hiện có</h6>
                            <div class="d-flex gap-2">
                                <input id="skillKeyword" class="form-control form-control-sm" placeholder="Search skill nhanh..." />
                                <button type="button" id="btnOpenAddSkill" class="btn btn-primary btn-sm"><i class="bi bi-plus-circle"></i> Thêm kỹ năng</button>
                            </div>
                        </div>
                        <div id="currentSkillTags" class="hr-skill-tag-wrap mb-2"></div>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle">
                                <thead><tr><th>Tên kỹ năng</th><th>Mức độ</th><th>Kinh nghiệm</th><th class="text-end">Thao tác</th></tr></thead>
                                <tbody id="skillBody"><tr><td colspan="4" class="text-muted">Chưa có dữ liệu</td></tr></tbody>
                            </table>
                        </div>
                    </div>
                    <div class="hr-ai-suggestion" id="aiSkillSuggestion">Chọn nhân viên để xem gợi ý kỹ năng AI.</div>
                </div>

                <div class="tab-pane fade" id="tabHistory">
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead><tr><th>Thời gian</th><th>Hành động</th></tr></thead>
                            <tbody id="historyBody"><tr><td colspan="2" class="text-muted">Chưa có nhật ký hoạt động</td></tr></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="employeeFormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="employeeModalTitle">Thêm nhân viên</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="employeeForm" class="row g-3">
                        <div class="col-md-6"><label class="form-label">Họ tên</label><input id="formHoTen" class="form-control" placeholder="Nhập họ tên" required /></div>
                        <div class="col-md-6"><label class="form-label">CCCD</label><input id="formCccd" class="form-control" inputmode="numeric" pattern="[0-9]{12}" minlength="12" maxlength="12" required /></div>
                        <div class="col-md-6"><label class="form-label">Ngày sinh</label><input id="formNgaySinh" type="date" class="form-control" required /></div>
                        <div class="col-md-6"><label class="form-label">Giới tính</label><select id="formGioiTinh" class="form-select"><option value="">Chọn</option><option value="Nam">Nam</option><option value="Nữ">Nữ</option></select></div>
                        <div class="col-md-6"><label class="form-label">SDT</label><input id="formSdt" class="form-control" placeholder="Nhập số điện thoại" inputmode="numeric" pattern="[0-9]{10}" minlength="10" maxlength="10" required /></div>
                        <div class="col-md-6"><label class="form-label">Email</label><input id="formEmail" type="email" class="form-control" required /></div>
                        <div class="col-md-6"><label class="form-label">Ngày vào làm</label><input id="formNgayVaoLam" type="date" class="form-control" required /></div>
                        <div class="col-md-6"><label class="form-label">Địa chỉ</label><input id="formDiaChi" class="form-control" placeholder="Nhập địa chỉ" /></div>
                        <div class="col-md-6"><label class="form-label">Phòng ban</label><select id="formPhongBan" class="form-select" required></select></div>
                        <div class="col-md-6"><label class="form-label">Chức vụ</label><select id="formChucVu" class="form-select" required></select></div>
                        <div class="col-md-6"><label class="form-label">Tài khoản liên kết</label><select id="formAspNetUserId" class="form-select"><option value="">Không liên kết</option></select></div>
                    </form>
                    <div id="employeeFormResult" class="small mt-2"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-primary" id="btnSaveEmployee">Lưu</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="skillFormModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="skillModalTitle">Thêm kỹ năng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body row g-3">
                    <div class="col-md-12">
                        <label class="form-label">Kỹ năng</label>
                        <select id="employeeSkillSelect" class="form-select">
                            <option value="">Chọn kỹ năng</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Mức độ</label>
                        <select id="employeeSkillLevel" class="form-select">
                            <option value="1">Beginner</option>
                            <option value="2">Intermediate</option>
                            <option value="3">Advanced</option>
                            <option value="4">Expert</option>
                            <option value="5">Expert+</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Kinh nghiệm (năm)</label>
                        <input id="employeeSkillExperience" type="number" min="0" max="50" class="form-control" value="1" />
                    </div>
                    <div id="skillFormMessage" class="small"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                    <button type="button" id="btnSaveEmployeeSkill" class="btn btn-primary">Lưu kỹ năng</button>
                </div>
            </div>
        </div>
    </div>

    <div class="offcanvas offcanvas-end hr-catalog-drawer" tabindex="-1" id="catalogDrawer" aria-labelledby="catalogDrawerLabel">
        <div class="offcanvas-header">
            <h5 id="catalogDrawerLabel" class="offcanvas-title">Danh mục kỹ năng</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column gap-3">
            <div>
                <label class="form-label mb-1">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input id="catalogSkillKeyword" class="form-control hr-catalog-search" placeholder="Tìm kỹ năng nhanh..." />
                </div>
            </div>

            <div class="d-flex justify-content-between align-items-center gap-2 flex-wrap">
                <h6 class="mb-0">Danh sách kỹ năng</h6>
                <button id="btnShowInlineCatalogForm" class="btn btn-outline-primary btn-sm" type="button"><i class="bi bi-plus-circle"></i> Thêm kỹ năng</button>
            </div>

            <div id="catalogInlineForm" class="hr-inline-catalog-form d-none">
                <h6 class="mb-2">+ Thêm kỹ năng</h6>
                <div class="mb-2">
                    <label class="form-label form-label-sm">Tên kỹ năng</label>
                    <input id="inlineCatalogSkillName" class="form-control form-control-sm" placeholder="VD: React" />
                </div>
                <div class="mb-2">
                    <label class="form-label form-label-sm">Mô tả</label>
                    <textarea id="inlineCatalogSkillDesc" class="form-control form-control-sm" rows="2" placeholder="Mô tả ngắn kỹ năng"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button id="btnSaveInlineCatalog" class="btn btn-primary btn-sm" type="button">Lưu</button>
                    <button id="btnCancelInlineCatalog" class="btn btn-light btn-sm" type="button">Hủy</button>
                </div>
            </div>

            <div id="catalogSkillMessage" class="small"></div>

            <div class="table-responsive flex-grow-1 hr-catalog-table-wrap">
                <table class="table table-sm align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Tên kỹ năng</th>
                            <th>Mô tả</th>
                            <th class="text-end">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody id="catalogSkillBody">
                        <tr><td colspan="3" class="text-muted">Đang tải danh mục kỹ năng...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="modal fade" id="chucVuModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Quản lý chức vụ</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="row g-2 mb-2">
                        <div class="col-md-9">
                            <input id="chucVuInput" class="form-control" placeholder="Nhập tên chức vụ" />
                        </div>
                        <div class="col-md-3 d-grid">
                            <button id="btnSaveChucVu" class="btn btn-primary" type="button">Lưu chức vụ</button>
                        </div>
                    </div>
                    <div id="chucVuMessage" class="small mb-2"></div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Mã chức vụ</th>
                                    <th>Tên chức vụ</th>
                                    <th class="text-end">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="chucVuBody">
                                <tr><td colspan="3" class="text-muted">Đang tải danh sách chức vụ...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const role = '@currentRole';
        if (role !== 'employee') {
            const employeeBody = document.getElementById('employeeBody');
            const employeeSummary = document.getElementById('employeeSummary');
            const keywordInput = document.getElementById('keyword');
            const phongBanSelect = document.getElementById('phongBan');
            const chucVuSelect = document.getElementById('chucVu');
            const trangThaiSelect = document.getElementById('trangThai');
            const sortBySelect = document.getElementById('sortBy');

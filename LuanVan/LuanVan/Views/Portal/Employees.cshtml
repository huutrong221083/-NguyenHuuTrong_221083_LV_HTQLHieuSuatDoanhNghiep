            function applyAdvancedClientFilters(items) {
                const selectedSkillId = Number(skillFilter.value || 0);
                const selectedBand = kpiBandFilter.value;
                const minExperience = Number(experienceFilter.value || 0);
                const fromTime = toTime(joinDateFrom.value);
                const toTimeValue = toTime(joinDateTo.value);
                const statusRaw = trangThaiSelect.value;

                return items.filter(item => {
                    const detail = state.employeeDetailMap.get(item.maNhanVien);
                    const kpi = state.employeeKpiMap.get(item.maNhanVien)?.latest || 0;

                    if (statusRaw === '2' && Number(item.trangThai) !== 2) {
                        return false;
                    }

                    if (selectedSkillId) {
                        const hasSkill = (detail?.skills || []).some(s => Number(s.maKyNang) === selectedSkillId);
                        if (!hasSkill) return false;
                    }

                    if (selectedBand === 'high' && kpi < 80) return false;
                    if (selectedBand === 'mid' && (kpi < 50 || kpi >= 80)) return false;
                    if (selectedBand === 'low' && kpi >= 50) return false;

                    if (minExperience > 0) {
                        const maxExp = Math.max(0, ...(detail?.skills || []).map(s => Number(s.soDuAnDaDung || 0)));
                        if (maxExp < minExperience) return false;
                    }

                    const joinTime = toTime(detail?.ngayVaoLam || item.ngayVaoLam);
                    if (Number.isFinite(fromTime) && (!Number.isFinite(joinTime) || joinTime < fromTime)) return false;
                    if (Number.isFinite(toTimeValue) && (!Number.isFinite(joinTime) || joinTime > toTimeValue + 86399999)) return false;

                    return true;
                });
            }

            function renderMiniDashboard(items) {
                const total = items.length;
                const active = items.filter(x => Number(x.trangThai) === 1).length;
                const inactive = items.filter(x => Number(x.trangThai) !== 1).length;
                const kpiScores = items
                    .map(x => Number(state.employeeKpiMap.get(x.maNhanVien)?.latest || 0))
                    .filter(v => Number.isFinite(v));
                const avg = kpiScores.length ? (kpiScores.reduce((sum, x) => sum + x, 0) / kpiScores.length) : 0;

                kpiTotalEmployees.textContent = String(total);
                kpiActiveEmployees.textContent = String(active);
                kpiInactiveEmployees.textContent = String(inactive);
                kpiAverage.textContent = `${avg.toFixed(1)}%`;
            }


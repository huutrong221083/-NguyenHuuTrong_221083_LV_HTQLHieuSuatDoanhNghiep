            async function saveChucVu() {
                const tenChucVu = chucVuInput.value.trim();
                if (!tenChucVu) {
                    setChucVuMessage('Tên chức vụ là bắt buộc.');
                    return;
                }

                const isEdit = Number.isInteger(state.editingChucVuId);
                const result = await fetchJson(isEdit ? `/chucvu/${state.editingChucVuId}` : '/chucvu', {
                    method: isEdit ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tenChucVu })
                });

                if (!result.success) {
                    setChucVuMessage(result.message || 'Không thể lưu chức vụ.');
                    return;
                }

                setChucVuMessage(isEdit ? 'Cập nhật chức vụ thành công.' : 'Thêm chức vụ thành công.', true);
                state.editingChucVuId = null;
                chucVuInput.value = '';
                await loadChucVus();
            }

            async function deleteChucVu(id) {
                if (!confirm('Bạn có chắc muốn xóa chức vụ này?')) return;

                const triggerButton = document.activeElement && document.activeElement.matches('button')
                    ? document.activeElement
                    : null;

                const result = await (window.UiButtonLoading?.run
                    ? window.UiButtonLoading.run(triggerButton, () => fetchJson(`/chucvu/${id}`, { method: 'DELETE' }), { profile: 'delete' })
                    : fetchJson(`/chucvu/${id}`, { method: 'DELETE' }));
                if (!result.success) {
                    setChucVuMessage(result.message || 'Không thể xóa chức vụ.');
                    return;
                }

                if (Number(state.editingChucVuId) === Number(id)) {
                    state.editingChucVuId = null;
                    chucVuInput.value = '';

            async function saveEmployee() {
                const normalizedCccd = formCccd.value.trim();
                const normalizedSdt = formSdt.value.trim();
                if (normalizedCccd.length !== 12) {
                    employeeFormResult.className = 'small mt-2 text-danger';
                    employeeFormResult.textContent = 'CCCD phải đúng 12 số.';
                    formCccd.focus();
                    return;
                }

                if (normalizedSdt.length !== 10) {
                    employeeFormResult.className = 'small mt-2 text-danger';
                    employeeFormResult.textContent = 'SĐT phải đúng 10 số.';
                    formSdt.focus();
                    return;
                }

                const payload = {
                    hoTen: formHoTen.value.trim(),
                    ngaySinh: formNgaySinh.value,
                    cccd: normalizedCccd,
                    diaChi: formDiaChi.value.trim(),
                    gioiTinh: formGioiTinh.value,
                    email: formEmail.value.trim(),
                    sdt: normalizedSdt,
                    ngayVaoLam: formNgayVaoLam.value,
                    maPhongBan: Number(formPhongBan.value),
                    maChucVu: Number(formChucVu.value),
                    aspNetUserId: formAspNetUserId.value || null
                };

                const isEdit = !!state.editingEmployeeId;
                const url = isEdit ? `/nhanvien/${state.editingEmployeeId}` : '/nhanvien';
                const method = isEdit ? 'PUT' : 'POST';

                const result = await fetchJson(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                employeeFormResult.className = `small mt-2 ${result.success ? 'text-success' : 'text-danger'}`;
                employeeFormResult.textContent = result.message;
                if (!result.success) return;

                employeeFormModal.hide();
                await loadNhanVien();
            }

            async function deleteEmployee(id) {
                if (!confirm('Bạn có chắc chắn muốn chuyển nhân viên sang trạng thái nghỉ việc?')) return;

                const triggerButton = document.activeElement && document.activeElement.matches('button')
                    ? document.activeElement
                    : null;

                const result = await (window.UiButtonLoading?.run
                    ? window.UiButtonLoading.run(triggerButton, () => fetchJson(`/nhanvien/${id}`, { method: 'DELETE' }), { profile: 'delete' })
                    : fetchJson(`/nhanvien/${id}`, { method: 'DELETE' }));
                if (!result.success) {
                    alert(result.message || 'Không thể cập nhật trạng thái nhân viên.');
                    return;
                }

                await loadNhanVien();
            }

            async function toggleEmployeeStatus(id, currentStatus) {
                const nextStatus = Number(currentStatus) === 1 ? 0 : 1;
                const confirmMessage = nextStatus === 0
                    ? 'Bạn có chắc chắn muốn chuyển nhân viên sang trạng thái nghỉ việc?'
                    : 'Bạn có chắc chắn muốn chuyển nhân viên sang trạng thái đang làm việc?';

                if (!confirm(confirmMessage)) return;

                const triggerButton = document.activeElement && document.activeElement.matches('button')
                    ? document.activeElement
                    : null;

                const result = await (window.UiButtonLoading?.run
                    ? window.UiButtonLoading.run(triggerButton, () => fetchJson(`/nhanvien/${id}/status`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ trangThai: nextStatus })
                    }), { profile: 'save' })
                    : fetchJson(`/nhanvien/${id}/status`, {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ trangThai: nextStatus })
                    }));

                if (!result.success) {
                    alert(result.message || 'Không thể cập nhật trạng thái nhân viên.');
                    return;
                }

                await loadNhanVien();
            }

            function openCreateEmployeeSkill() {
                if (!state.selectedEmployeeId) return;
                state.editingEmployeeSkillId = null;
                skillModalTitle.textContent = 'Thêm kỹ năng';
                skillFormMessage.textContent = '';
                skillFormMessage.className = 'small';
                employeeSkillSelect.disabled = false;
                employeeSkillSelect.value = '';
                employeeSkillLevel.value = '2';
                employeeSkillExperience.value = '1';
                skillFormModal.show();
            }

            function openEditEmployeeSkill(skillId) {
                const row = (state.selectedEmployeeDetail?.skills || []).find(x => x.maKyNang === skillId);
                if (!row) return;

                state.editingEmployeeSkillId = skillId;
                skillModalTitle.textContent = 'Sửa kỹ năng';
                skillFormMessage.textContent = '';
                skillFormMessage.className = 'small';
                employeeSkillSelect.value = String(skillId);
                employeeSkillSelect.disabled = true;
                employeeSkillLevel.value = String(Math.max(1, Number(row.capDo || 1)));
                employeeSkillExperience.value = String(Number(row.soDuAnDaDung || 0));
                skillFormModal.show();
            }

            async function saveEmployeeSkill() {
                if (!state.selectedEmployeeId) return;
                const skillId = Number(employeeSkillSelect.value);
                const capDo = Number(employeeSkillLevel.value);
                const years = Math.max(0, Number(employeeSkillExperience.value || 0));

                if (!skillId || Number.isNaN(skillId)) {
                    skillFormMessage.className = 'small text-danger';
                    skillFormMessage.textContent = 'Bạn cần chọn kỹ năng.';
                    return;
                }

                const existingIds = new Set((state.selectedEmployeeDetail?.skills || []).map(x => x.maKyNang));
                if (!state.editingEmployeeSkillId && existingIds.has(skillId)) {
                    skillFormMessage.className = 'small text-danger';
                    skillFormMessage.textContent = 'Kỹ năng đã tồn tại trên nhân viên.';
                    return;
                }

                const payload = {
                    maKyNang: skillId,
                    capDo,
                    soDuAnDaDung: years
                };

                const url = state.editingEmployeeSkillId
                    ? `/nhanvien/${state.selectedEmployeeId}/skills/${state.editingEmployeeSkillId}`
                    : `/nhanvien/${state.selectedEmployeeId}/skills`;
                const method = state.editingEmployeeSkillId ? 'PUT' : 'POST';

                const result = await fetchJson(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                skillFormMessage.className = `small ${result.success ? 'text-success' : 'text-danger'}`;
                skillFormMessage.textContent = result.message || (result.success ? 'Thành công' : 'Thất bại');
                if (!result.success) return;

                skillFormModal.hide();
                await openEmployeeDrawer(state.selectedEmployeeId);
                await loadNhanVien();
            }

            async function removeSkill(employeeId, skillId) {
                if (!confirm('Bạn có chắc muốn xóa kỹ năng này?')) return;
                const triggerButton = document.activeElement && document.activeElement.matches('button')
                    ? document.activeElement
                    : null;

                const result = await (window.UiButtonLoading?.run
                    ? window.UiButtonLoading.run(triggerButton, () => fetchJson(`/nhanvien/${employeeId}/skills/${skillId}`, { method: 'DELETE' }), { profile: 'delete' })
                    : fetchJson(`/nhanvien/${employeeId}/skills/${skillId}`, { method: 'DELETE' }));
                if (!result.success) {
                    alert(result.message || 'Không thể xóa kỹ năng.');
                    return;
                }

                await openEmployeeDrawer(employeeId);
                await loadNhanVien();
            }

            function openEditCatalogSkill(id) {
                const skill = state.skillCatalog.find(x => x.maKyNang === id);
                if (!skill) return;

                state.editingCatalogSkillId = id;
                state.catalogInlineMode = 'edit-row';
                catalogInlineForm.classList.add('d-none');
                setCatalogMessage('Đang sửa kỹ năng trong dòng dữ liệu.', 'text-muted');
                renderCatalogSkillTable();
            }

            async function saveInlineCatalogCreate() {
                const tenKyNang = inlineCatalogSkillName.value.trim();
                const moTa = inlineCatalogSkillDesc.value.trim();

                if (!tenKyNang) {
                    setCatalogMessage('Tên kỹ năng không được để trống.', 'text-danger');
                    return;
                }

                if (isDuplicateSkillName(tenKyNang)) {
                    setCatalogMessage('Tên kỹ năng đã tồn tại, vui lòng nhập tên khác.', 'text-danger');
                    return;
                }

                const result = await fetchJson('/kynang', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tenKyNang, moTa })
                });

                if (!result.success) {
                    setCatalogMessage(result.message || 'Không thể thêm kỹ năng.', 'text-danger');
                    return;
                }

                await loadSkillCatalog();
                const inserted = state.skillCatalog.find(s => normalizeSkillName(s.tenKyNang) === normalizeSkillName(tenKyNang));
                state.recentCatalogSkillId = inserted?.maKyNang || null;
                hideInlineCatalogForm();
                renderCatalogSkillTable();
                setCatalogMessage('Đã thêm kỹ năng mới.', 'text-success');

                setTimeout(() => {
                    state.recentCatalogSkillId = null;
                    renderCatalogSkillTable();
                }, 1600);

                await loadNhanVien();
            }

            function cancelInlineCatalogEdit() {
                state.catalogInlineMode = null;
                state.editingCatalogSkillId = null;
                setCatalogMessage('');
                renderCatalogSkillTable();
            }

            async function saveInlineCatalogEdit(id) {
                const nameInput = document.getElementById(`editCatalogName-${id}`);
                const descInput = document.getElementById(`editCatalogDesc-${id}`);
                if (!nameInput || !descInput) return;

                const tenKyNang = nameInput.value.trim();
                const moTa = descInput.value.trim();

                if (!tenKyNang) {
                    setCatalogMessage('Tên kỹ năng không được để trống.', 'text-danger');
                    return;
                }

                if (isDuplicateSkillName(tenKyNang, id)) {
                    setCatalogMessage('Tên kỹ năng đã tồn tại, vui lòng nhập tên khác.', 'text-danger');
                    return;
                }

                const result = await fetchJson(`/kynang/${id}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ tenKyNang, moTa })
                });

                if (!result.success) {
                    setCatalogMessage(result.message || 'Không thể cập nhật kỹ năng.', 'text-danger');
                    return;
                }

                await loadSkillCatalog();
                state.recentCatalogSkillId = id;
                cancelInlineCatalogEdit();
                setCatalogMessage('Đã cập nhật kỹ năng.', 'text-success');
                renderCatalogSkillTable();

                setTimeout(() => {
                    state.recentCatalogSkillId = null;
                    renderCatalogSkillTable();
                }, 1600);

                await loadNhanVien();
            }

            async function deleteCatalogSkill(id) {
                if (!confirm('Bạn có chắc muốn xóa?')) return;

                const triggerButton = document.activeElement && document.activeElement.matches('button')
                    ? document.activeElement
                    : null;

                const result = await (window.UiButtonLoading?.run
                    ? window.UiButtonLoading.run(triggerButton, () => fetchJson(`/kynang/${id}`, { method: 'DELETE' }), { profile: 'delete' })
                    : fetchJson(`/kynang/${id}`, { method: 'DELETE' }));
                if (!result.success) {
                    setCatalogMessage(result.message || 'Không thể xóa kỹ năng.', 'text-danger');
                    return;
                }

                state.catalogInlineMode = null;
                state.editingCatalogSkillId = null;
                await loadSkillCatalog();
                await loadNhanVien();
                setCatalogMessage('Đã xóa kỹ năng.', 'text-success');
            }

            
            function exportCsv() {
                if (!state.items.length) return;

                const rows = [
                    ['Họ tên', 'Email', 'Phòng ban', 'Chức vụ', 'KPI', 'Kỹ năng', 'Trạng thái']
                ];

                for (const item of state.items) {
                    const detail = state.employeeDetailMap.get(item.maNhanVien);
                    const roleName = item.tenChucVu || detail?.tenChucVu || '-';
                    const kpi = Number(state.employeeKpiMap.get(item.maNhanVien)?.latest || 0).toFixed(1);
                    const skills = (detail?.skills || [])
                        .map(s => s.tenKyNang)
                        .filter(Boolean)
                        .join(', ');

                    rows.push([
                        item.hoTen || '',
                        item.email || '',
                        item.tenPhongBan || '',
                        roleName,
                        kpi,
                        skills,
                        getEmployeeStatus(item.trangThai).text
                    ]);
                }

                const BOM = '\uFEFF';

                const content = rows
                    .map(row =>
                        row.map(v => `"${String(v).replace(/"/g, '""')}"`).join(';')
                    )
                    .join('\r\n');

                const blob = new Blob([BOM + content], {
                    type: 'text/csv;charset=utf-8;'
                });

                const url = URL.createObjectURL(blob);
                const a = document.createElement('a');
                a.href = url;
                a.download = `nhan-su-page-${state.page}.csv`;
                document.body.appendChild(a);
                a.click();
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }

            const realtimeSearch = debounce(() => {
                state.page = 1;
                loadNhanVien();
            }, 300);

            const bindNumericOnly = (input, maxLength) => {
                if (!input) return;
                input.addEventListener('input', () => {
                    let sanitized = (input.value || '').replace(/\D+/g, '');
                    if (Number.isFinite(maxLength) && maxLength > 0 && sanitized.length > maxLength) {
                        sanitized = sanitized.slice(0, maxLength);
                    }
                    if (input.value !== sanitized) {
                        input.value = sanitized;
                    }
                });
            };

            bindNumericOnly(formCccd, 12);
            bindNumericOnly(formSdt, 10);
            bindNumericOnly(detailSdt, 10);

            keywordInput.addEventListener('input', realtimeSearch);
            skillKeyword.addEventListener('input', () => renderSkillsTab(state.selectedEmployeeDetail));
            catalogSkillKeyword.addEventListener('input', debounce(renderCatalogSkillTable, 180));

            searchButton.addEventListener('click', () => {
                state.page = 1;
                loadNhanVien();
            });

            applyAdvancedFilterBtn.addEventListener('click', () => {
                state.page = 1;
                loadNhanVien();
                bootstrap.Dropdown.getOrCreateInstance(btnAdvancedFilter).hide();
            });

            resetAdvancedFilterBtn.addEventListener('click', () => {
                skillFilter.value = '';
                kpiBandFilter.value = '';
                experienceFilter.value = '';
                joinDateFrom.value = '';
                joinDateTo.value = '';
                state.page = 1;
                loadNhanVien();
            });

            phongBanSelect.addEventListener('change', () => {
                state.page = 1;
                loadNhanVien();
            });

            chucVuSelect.addEventListener('change', () => {
                state.page = 1;
                loadNhanVien();
            });

            sortBySelect.addEventListener('change', () => {
                state.page = 1;
                loadNhanVien();
            });

            trangThaiSelect.addEventListener('change', () => {
                state.page = 1;
                loadNhanVien();
            });

            skillFilter.addEventListener('change', () => {
                state.page = 1;
                loadNhanVien();
            });

            pageSizeSelect.addEventListener('change', () => {
                state.size = Number(pageSizeSelect.value);
                state.page = 1;
                loadNhanVien();
            });

            btnPrevPage.addEventListener('click', () => {
                if (state.page <= 1) return;
                state.page -= 1;
                loadNhanVien();
            });

            btnNextPage.addEventListener('click', () => {
                if (state.page >= state.totalPages) return;
                state.page += 1;
                loadNhanVien();
            });

            btnAddEmployee.addEventListener('click', openCreateEmployee);
            window.UiButtonLoading?.bind(btnExport, exportCsv, { profile: 'export' });
            window.UiButtonLoading?.bind(btnSaveEmployee, saveEmployee, { profile: 'save' });
            window.UiButtonLoading?.bind(btnSavePersonal, savePersonalInfo, { profile: 'save' });
            btnOpenCatalogManager.addEventListener('click', () => {
                setCatalogMessage('');
                hideInlineCatalogForm();
                state.catalogInlineMode = null;
                state.editingCatalogSkillId = null;
                renderCatalogSkillTable();
                catalogDrawer.show();
            });
            btnOpenChucVuManager.addEventListener('click', () => {
                state.editingChucVuId = null;
                chucVuInput.value = '';
                setChucVuMessage('');
                renderChucVuTable();
                chucVuModal.show();
            });
            window.UiButtonLoading?.bind(btnSaveChucVu, saveChucVu, { profile: 'save' });

            btnOpenAddSkill.addEventListener('click', openCreateEmployeeSkill);
            window.UiButtonLoading?.bind(btnSaveEmployeeSkill, saveEmployeeSkill, { profile: 'save' });

            btnShowInlineCatalogForm.addEventListener('click', showInlineCatalogForm);
            btnCancelInlineCatalog.addEventListener('click', hideInlineCatalogForm);
            window.UiButtonLoading?.bind(btnSaveInlineCatalog, saveInlineCatalogCreate, { profile: 'save' });

            employeeBody.addEventListener('click', (event) => {
                const actionButton = event.target.closest('button');
                if (actionButton && actionButton.closest('td')?.classList.contains('text-end')) {
                    return;
                }

                const drawerButton = event.target.closest('[data-open-drawer]');
                if (drawerButton) {
                    openEmployeeDrawer(Number(drawerButton.getAttribute('data-open-drawer')));
                    return;
                }

                const row = event.target.closest('tr[data-row-id]');
                if (row) {
                    openEmployeeDrawer(Number(row.getAttribute('data-row-id')));
                }
            });

            window.openEmployeeDrawer = openEmployeeDrawer;
            window.openEditEmployee = openEditEmployee;
            window.deleteEmployee = deleteEmployee;
            window.toggleEmployeeStatus = toggleEmployeeStatus;
            window.requestEmployeeReport = (maNhanVien, hoTen) => {
                const managerName = role === 'admin' ? 'Admin' : 'Manager';
                const rows = JSON.parse(localStorage.getItem(state.sharedRequestKey) || '[]');
                rows.unshift({
                    time: new Date().toLocaleString('vi-VN'),
                    manager: managerName,
                    employeeId: maNhanVien,
                    employeeName: hoTen,
                    message: `Bạn được yêu cầu gửi báo cáo từ ${managerName}`,
                    status: 'Đã gửi yêu cầu'
                });
                localStorage.setItem(state.sharedRequestKey, JSON.stringify(rows.slice(0, 30)));
                alert(`Đã gửi yêu cầu báo cáo đến ${hoTen}.`);
            };
            window.openEditEmployeeSkill = openEditEmployeeSkill;
            window.removeSkill = removeSkill;
            window.openEditCatalogSkill = openEditCatalogSkill;
            window.cancelInlineCatalogEdit = cancelInlineCatalogEdit;
            window.saveInlineCatalogEdit = saveInlineCatalogEdit;
            window.deleteCatalogSkill = deleteCatalogSkill;
            window.editChucVu = editChucVu;
            window.deleteChucVu = deleteChucVu;

            Promise.allSettled([loadDepartments(), loadChucVus(), loadSkillCatalog()]).then(() => {
                loadNhanVien();
            });
        }
    </script>
}





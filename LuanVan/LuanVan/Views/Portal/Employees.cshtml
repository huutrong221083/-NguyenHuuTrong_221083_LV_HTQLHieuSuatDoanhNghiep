            async function loadEmployeeKpi(employeeId) {
                if (state.employeeKpiMap.has(employeeId)) {
                    return state.employeeKpiMap.get(employeeId);
                }

                const result = await fetchJson(`/kpi/nhanvien/${employeeId}`);
                if (!result.success) {
                    const fallback = { avg: 0, latest: 0, history: [] };
                    state.employeeKpiMap.set(employeeId, fallback);
                    return fallback;
                }

                const history = result.data?.kpiTheoThang || result.data?.KpiTheoThang || [];
                const sorted = [...history].sort((a, b) => {
                    const ay = Number(a.nam || 0);
                    const by = Number(b.nam || 0);
                    const am = Number(a.thang || 0);
                    const bm = Number(b.thang || 0);
                    return (by * 100 + bm) - (ay * 100 + am);
                });

                const scores = history.map(x => Number(x.diem || 0)).filter(x => Number.isFinite(x));
                const avg = scores.length ? (scores.reduce((sum, x) => sum + x, 0) / scores.length) : 0;
                const latest = sorted.length ? Number(sorted[0].diem || 0) : avg;

                const computed = { avg, latest, history };
                state.employeeKpiMap.set(employeeId, computed);
                return computed;
            }


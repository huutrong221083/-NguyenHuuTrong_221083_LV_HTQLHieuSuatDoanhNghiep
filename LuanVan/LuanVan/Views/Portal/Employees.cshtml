                const top = skills.slice(0, 3);
                const more = skills.length - top.length;
                const tooltip = skills.map(s => `${s.tenKyNang || ''} (${levelMeta(s.capDo).text})`).join(', ');
                return `
                    <div class="hr-skill-tag-wrap" title="${escapeHtml(tooltip)}">
                        ${top.map(s => {
                            const lv = levelMeta(s.capDo);
                            return `<span class="hr-skill-tag ${lv.css}">${escapeHtml(s.tenKyNang || '')}</span>`;
                        }).join('')}
                        ${more > 0 ? `<span class="hr-skill-more">+${more}</span>` : ''}

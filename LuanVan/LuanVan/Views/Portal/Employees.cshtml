            async function renderKpiTab(employeeId) {
                const result = await fetchJson(`/kpi/nhanvien/${employeeId}`);
                if (!result.success) {
                    kpiBody.innerHTML = '<tr><td colspan="3" class="text-muted">Không có dữ liệu KPI</td></tr>';
                    return;
                }

                const history = result.data?.kpiTheoThang || result.data?.KpiTheoThang || [];
                if (!history.length) {
                    kpiBody.innerHTML = '<tr><td colspan="3" class="text-muted">Không có dữ liệu KPI</td></tr>';
                } else {
                    kpiBody.innerHTML = history.map(x => `
                        <tr>
                            <td>${x.thang}/${x.nam}</td>
                            <td>${x.diem?.toFixed(1) || 0}</td>
                            <td>${escapeHtml(x.xepLoai || '-')}</td>
                        </tr>
                    `).join('');
                }
            }

            function resolveTaskStatusLabel(row) {
                const rawName = row.tenTrangThai || row.TenTrangThai;
                if (rawName && Number.isNaN(Number(rawName))) {
                    return rawName;
                }

                const statusValue = Number(row.maTrangThai ?? row.MaTrangThai ?? rawName);
                if (statusValue === 1) return 'Chưa bắt đầu';
                if (statusValue === 2) return 'Đang thực hiện';
                if (statusValue === 3) return 'Hoàn thành';
                if (statusValue >= 4) return 'Tạm hoãn';
                return 'Tạm hoãn';
            }

            async function renderTasksTab(employeeId) {
                const result = await fetchJson(`/congviec?maNhanVien=${employeeId}&size=50&page=1`);
                if (!result.success) {
                    taskBody.innerHTML = '<tr><td colspan="5" class="text-muted">Không có dữ liệu công việc</td></tr>';
                    return;
                }

                const rows = result.data?.items || [];
                if (!rows.length) {
                    taskBody.innerHTML = '<tr><td colspan="5" class="text-muted">Không có công việc</td></tr>';
                    return;
                }

                taskBody.innerHTML = rows.map(row => {
                    const deadline = row.hanHoanThanh ? new Date(row.hanHoanThanh) : null;
                    const daysLeft = deadline ? Math.ceil((deadline - new Date()) / 86400000) : 99;
                    const deadlineCss = daysLeft <= 2 ? 'text-danger fw-bold' : (daysLeft <= 5 ? 'text-warning fw-semibold' : '');
                    return `
                        <tr>
                            <td>${escapeHtml(row.tenCongViec || '-')}</td>
                            <td>${escapeHtml(row.tenDuAn || '-')}</td>
                            <td class="${deadlineCss}">${deadline ? deadline.toLocaleDateString('vi-VN') : '-'}</td>
                            <td>
                                <div class="progress" style="height:10px"><div class="progress-bar ${row.tienDoPhanTram >= 70 ? 'good' : (row.tienDoPhanTram >= 40 ? 'warn' : 'bad')}" style="width:${row.tienDoPhanTram || 0}%"></div></div>
                            </td>
                            <td>${escapeHtml(resolveTaskStatusLabel(row))}</td>
                        </tr>
                    `;
                }).join('');
            }

            async function savePersonalInfo() {
                if (!state.selectedEmployeeId) return;
                const normalizedDetailSdt = detailSdt.value.trim();
                if (normalizedDetailSdt.length !== 10) {
                    alert('SĐT phải đúng 10 số.');
                    detailSdt.focus();
                    return;
                }

                const payload = {
                    hoTen: detailHoTen.value.trim(),
                    ngaySinh: detailNgaySinh.value,
                    cccd: detailCccd.value,
                    diaChi: detailDiaChi.value.trim(),
                    gioiTinh: detailGioiTinh.value,
                    email: detailEmail.value.trim(),
                    sdt: normalizedDetailSdt,
                    ngayVaoLam: detailNgayVaoLam.value,
                    maPhongBan: Number(detailPhongBan.value),
                    maChucVu: Number(detailChucVu.value),
                    aspNetUserId: detailAspNetUserId.value || null
                };

                const result = await fetchJson(`/nhanvien/${state.selectedEmployeeId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!result.success) {
                    alert(result.message || 'Không thể cập nhật nhân viên.');
                    return;
                }

                await loadNhanVien();
                await openEmployeeDrawer(state.selectedEmployeeId);
                alert('Đã cập nhật thông tin nhân viên.');
            }


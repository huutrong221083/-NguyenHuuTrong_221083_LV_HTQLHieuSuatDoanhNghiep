                return `<span class="hr-status"><span class="hr-status-dot ${meta.css}"></span>${meta.text}</span>`;
            };

            const roleBadge = (roleName) => {
                if (!roleName) return '<span class="text-muted">-</span>';
                const normalized = String(roleName).toLowerCase();
                const css = normalized.includes('admin')
                    ? 'role-admin'
                    : (normalized.includes('manager') ? 'role-manager' : 'role-employee');
                return `<span class="role-tag ${css}">${escapeHtml(roleName)}</span>`;
            };

            function debounce(fn, delay = 350) {
                let timer;
                return (...args) => {
                    clearTimeout(timer);
                    timer = setTimeout(() => fn(...args), delay);
                };
            }

            async function fetchJson(url, options) {
                try {
                    const res = await fetch(url, options);
                    const raw = await res.text();
                    let payload = null;

                    if (raw) {
                        try {
                            payload = JSON.parse(raw);
                        } catch {
                            payload = null;
                        }
                    }

                    if (!res.ok) {
                        if (payload && typeof payload.success === 'boolean') {
                            return payload;
                        }

                        return {
                            success: false,
                            message: payload?.message || `API ${url} lỗi (HTTP ${res.status}). ${raw ? raw.slice(0, 180) : ''}`
                        };
                    }

                    if (payload && typeof payload.success === 'boolean') {
                        return payload;
                    }

                    return { success: true, data: payload };
                } catch (error) {
                    console.error('Employees API error', { url, options }, error);
                    return {
                        success: false,
                        message: `Không thể kết nối ${url}.`
                    };
                }
            }


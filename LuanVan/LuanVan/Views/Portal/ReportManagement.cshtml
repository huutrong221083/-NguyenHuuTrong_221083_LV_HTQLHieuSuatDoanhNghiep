@{
    var roleKey = (ViewData["RoleKey"]?.ToString() ?? "employee").Trim().ToLowerInvariant();
    var canViewReports = ViewData["CanViewReports"] as bool? ?? false;
    var canManageReports = canViewReports;
}

<style>
    /* ===== REPORT MANAGEMENT MAIN STYLES ===== */
    
    .report-management-container {
        display: flex;
        flex-direction: column;
        gap: 20px;
        padding-bottom: 20px;
    }

    /* Header section */
    .page-head {
        padding: 20px;
        background: linear-gradient(135deg, #ffffff 0%, #eef4ff 100%);
        border-radius: 14px;
        border: 1px solid #e7eef7;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-head div:first-child h2 {
        font-size: 28px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 8px 0;
        letter-spacing: -0.5px;
    }

    .page-head div:first-child p {
        font-size: 14px;
        color: #64748b;
        margin: 0;
    }

    .page-head-actions {
        display: flex;
        gap: 12px;
        align-items: center;
    }

    .report-overview-panel {
        background: white;
        border: 1px solid #e7eef7;
        border-radius: 16px;
        padding: 14px;
        box-shadow: 0 2px 8px rgba(16, 24, 40, 0.04);
    }

    .report-overview-toolbar {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 14px;
        flex-wrap: wrap;
    }

    .report-overview-actions {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
        margin-left: auto;
    }

    .report-overview-filters {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 10px;
        margin-top: 12px;
        align-items: end;
    }

    .report-overview-filters > div {
        display: flex;
        flex-direction: column;
        gap: 4px;
        min-width: 0;
    }

    .report-overview-filters label {
        font-size: 12px;
        font-weight: 600;
        color: #64748b;
    }

    .btn-create-report {
        background: #2563eb;
        color: white;
        border: none;
        height: 38px;
        padding: 0 16px;
        border-radius: 999px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 6px;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.28);
    }

    .btn-create-report:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(37, 99, 235, 0.34);
        background: #1d4ed8;
    }

    /* Breadcrumb */
    .form-select, .form-control {
        height: 38px;
        border: 1px solid #d7e2ef;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 13px;
        background: white;
        color: #1e293b;
        transition: all 0.2s ease;
    }

    .form-select:focus, .form-control:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    .report-filter-actions {
        display: flex;
        gap: 10px;
        justify-content: flex-end;
    }

    .btn {
        height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 600;
        border: 1px solid #e2e8f0;
        background: white;
        color: #475569;
        cursor: pointer;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

    .btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
    }

    .btn-primary {
        background: #2563eb;
        color: white;
        border: none;
        box-shadow: 0 2px 8px rgba(37, 99, 235, 0.2);
    }

    .btn-primary:hover {
        background: #1d4ed8;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.3);
    }

    .btn-success {
        background: #2563eb;
        color: white;
        border: none;
    }

    .btn-success:hover {
        background: #1d4ed8;
    }

    .btn-danger {
        background: #ef4444;
        color: white;
        border: none;
    }

    .btn-danger:hover {
        background: #dc2626;
    }

    .status-tabs {
        display: flex;
        gap: 10px;
        margin-top: 10px;
        flex-wrap: wrap;
    }
    .status-tab {
        border: 1px solid #cbd5e1;
        background: #fff;
        color: #334155;
        border-radius: 20px;
        font-size: 12px;
        padding: 6px 12px;
        cursor: pointer;
    }
    .status-tab.active {
        background: #1d4ed8;
        color: #fff;
        border-color: #1d4ed8;
    }
    .request-panel {
        background: white;
        border: 1px solid #eef2f7;
        border-radius: 12px;
        padding: 16px;
    }
    .request-item {
        padding: 12px;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        margin-bottom: 10px;
    }
    .request-item h4 {
        margin: 0 0 4px;
        font-size: 14px;
        color: #0f172a;
    }
    .request-meta {
        font-size: 12px;
        color: #64748b;
        margin-bottom: 8px;
    }

    /* Report list section */
    .report-list-panel {
        background: white;
        border: 1px solid #e7eef7;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(16, 24, 40, 0.04);
    }

    .report-list-header {
        padding: 20px;
        border-bottom: 1px solid #eef2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .report-list-header h3 {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .table-responsive {
        overflow-x: auto;
        max-height: 600px;
        overflow-y: auto;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .report-table thead {
        background: #f8fafc;
        border-bottom: 1px solid #eef2f7;
        position: sticky;
        top: 0;
        z-index: 1;
    }

    .report-table thead th {
        padding: 14px 16px;
        text-align: left;
        font-weight: 700;
        color: #334155;
        text-transform: uppercase;
        font-size: 12px;
        letter-spacing: 0.5px;
    }

    .report-table tbody tr {
        border-bottom: 1px solid #eef2f7;
        transition: all 0.2s ease;
    }

    .report-table tbody tr:hover {
        background: #f8fafc;
    }

    .report-table tbody td {
        padding: 14px 16px;
        color: #334155;
    }

    .report-name {
        font-weight: 600;
        color: #2563eb;
        cursor: pointer;
    }

    .report-name:hover {
        color: #1d4ed8;
        text-decoration: underline;
    }

    /* Badge styles */
    .badge {
        display: inline-block;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        text-align: center;
    }

    .badge-personal {
        background: #dbeafe;
        color: #0c4a6e;
    }

    .badge-project {
        background: #e9d5ff;
        color: #581c87;
    }

    .badge-department {
        background: #fed7aa;
        color: #7c2d12;
    }

    .badge-ai {
        background: #fed7aa;
        color: #92400e;
    }

    .badge-admin {
        background: #fecaca;
        color: #7f1d1d;
    }

    /* Status badge */
    .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
    }

    .status-completed {
        background: #d1fae5;
        color: #065f46;
    }

    .status-processing {
        background: #fef3c7;
        color: #92400e;
    }

    .status-error {
        background: #fee2e2;
        color: #7f1d1d;
    }

    /* Format badge */
    .format-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        background: #e0e7ff;
        color: #3730a3;
    }

    /* Creator info */
    .creator-info {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .creator-avatar {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        background: #dbeafe;
        color: #0c4a6e;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 12px;
    }

    .creator-name {
        color: #334155;
        font-weight: 500;
    }

    /* Action buttons */
    .action-buttons {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
    }

    .action-btn {
        width: 32px;
        height: 32px;
        border-radius: 6px;
        border: 1px solid #e2e8f0;
        background: white;
        color: #64748b;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        font-size: 14px;
    }

    .action-btn:hover {
        background: #f0f9ff;
        border-color: #bae6fd;
        color: #10b981;
    }

    .action-btn.delete:hover {
        background: #fee2e2;
        border-color: #fecaca;
        color: #ef4444;
    }

    /* Empty state */
    .empty-state {
        padding: 60px 20px;
        text-align: center;
        color: #94a3b8;
    }

    .empty-state-icon {
        font-size: 48px;
        margin-bottom: 16px;
        opacity: 0.5;
    }

    /* Recent history section */
    .report-history-panel {
        background: white;
        border: 1px solid #eef2f7;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 2px 8px rgba(16, 24, 40, 0.04);
        margin-top: 20px;
    }

    .report-history-panel h3 {
        font-size: 16px;
        font-weight: 700;
        color: #1e293b;
        margin: 0 0 16px 0;
    }

    .history-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px;
        border-radius: 6px;
        background: #f8fafc;
        margin-bottom: 8px;
        font-size: 13px;
        transition: all 0.2s ease;
    }

    .history-item:hover {
        background: #eef2f7;
    }

    .history-item-info {
        flex: 1;
    }

    .history-item-name {
        font-weight: 600;
        color: #1e293b;
        margin-bottom: 4px;
    }

    .history-item-meta {
        color: #64748b;
        font-size: 12px;
    }

    .history-item-format {
        background: #e0e7ff;
        color: #3730a3;
        padding: 2px 8px;
        border-radius: 4px;
        font-weight: 600;
        font-size: 11px;
    }

    /* Modal styles */
    .modal-content {
        background: white;
        border-radius: 12px;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        max-width: 90vw;
        max-height: 90vh;
        overflow-y: auto;
        animation: slideUp 0.3s ease;
    }

    .modal-header {
        padding: 24px 24px 16px;
        border-bottom: 1px solid #eef2f7;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .modal-header h2 {
        font-size: 20px;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }

    .modal-body {
        padding: 24px;
    }

    .modal-footer {
        padding: 16px 24px;
        border-top: 1px solid #eef2f7;
        display: flex;
        justify-content: flex-end;
        gap: 12px;
    }

    /* Report detail modal */
    .report-detail-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    .detail-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .detail-label {
        font-size: 12px;
        font-weight: 700;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .detail-value {
        font-size: 14px;
        color: #1e293b;
        font-weight: 500;
    }

    .summary-cards {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        margin-bottom: 24px;
    }

    .summary-card {
        background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%);
        padding: 16px;
        border-radius: 8px;
        border: 1px solid #eef2f7;
        text-align: center;
    }

    .summary-card-value {
        font-size: 28px;
        font-weight: 700;
        color: #10b981;
    }

    .summary-card-label {
        font-size: 12px;
        color: #64748b;
        margin-top: 6px;
    }

    .chart-container {
        background: #f8fafc;
        padding: 16px;
        border-radius: 8px;
        margin-bottom: 20px;
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        border: 1px dashed #cbd5e1;
    }

    /* Form styles */
    .form-group {
        margin-bottom: 16px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }

    .form-label {
        font-size: 13px;
        font-weight: 600;
        color: #334155;
    }

    .form-textarea {
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        padding: 10px 12px;
        font-size: 13px;
        font-family: inherit;
        resize: vertical;
        min-height: 100px;
    }

    .form-textarea:focus {
        border-color: #10b981;
        box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
        outline: none;
    }

    /* Animations */
    /* Responsive */
    @@media (max-width: 1400px) {
        .report-overview-filters {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    @@media (max-width: 1024px) {
        .report-overview-filters {
            grid-template-columns: repeat(3, 1fr);
        }

        .summary-cards {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .report-overview-toolbar {
            flex-direction: column;
        }

        .report-overview-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .report-overview-filters {
            grid-template-columns: 1fr;
        }

        .page-head-actions {
            width: 100%;
            justify-content: flex-start;
        }

        .summary-cards {
            grid-template-columns: 1fr;
        }

        .report-detail-grid {
            grid-template-columns: 1fr;
        }

        .modal-content {
            width: 95vw;
            max-height: 95vh;
        }
    }

    /* ===== COMPACT OVERRIDES ===== */
    .report-management-container {
        gap: 12px;
        padding-bottom: 10px;
    }

    .report-overview-panel {
        padding: 12px;
    }

    .report-overview-filters {
        gap: 8px;
        margin-top: 10px;
    }

    .page-head-actions,
    .report-overview-actions {
        gap: 8px;
    }

    .report-list-header {
        padding: 12px 14px;
    }

    .report-table thead th,
    .report-table tbody td {
        padding: 9px 10px;
    }

    .btn {
        padding: 6px 12px;
        font-size: 12px;
    }

    .action-btn {
        width: 28px;
        height: 28px;
    }

    .report-history-panel,
    .request-panel {
        padding: 12px;
    }

    .report-management-page {
        max-width: 1480px;
        margin: 0 auto;
    }

    .quick-stats {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 12px;
    }

    .quick-stat-card {
        background: #fff;
        border: 1px solid #e7eef7;
        border-radius: 12px;
        padding: 14px;
    }

    .quick-stat-label {
        font-size: 12px;
        color: #64748b;
    }

    .quick-stat-value {
        font-size: 24px;
        font-weight: 700;
        color: #0f172a;
    }

    .report-dashboard-layout {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(320px, 360px);
        gap: 16px;
        align-items: start;
    }

    .report-main,
    .report-side {
        display: flex;
        flex-direction: column;
        gap: 12px;
        min-width: 0;
    }

    .report-side {
        position: sticky;
        top: 90px;
    }

    .filter-card,
    .reports-table-card,
    .recent-history-card,
    .request-card {
        background: #fff;
        border: 1px solid #e7eef7;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(16, 24, 40, 0.04);
    }

    .filter-card {
        padding: 12px;
    }

    .filter-bottom-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 10px;
        gap: 10px;
        flex-wrap: wrap;
    }

    .card-body-compact {
        padding: 12px;
    }

    .request-list.expanded {
        max-height: 420px;
        overflow-y: auto;
    }

    .request-item-title {
        margin: 0 0 4px;
        font-size: 14px;
        color: #0f172a;
    }

    .request-desc {
        font-size: 12px;
        color: #334155;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .request-card-footer-link {
        color: #2563eb;
        font-size: 12px;
        font-weight: 600;
        background: none;
        border: none;
        cursor: pointer;
        padding: 0;
    }

    .recipient-badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 999px;
        background: #f1f5f9;
        color: #64748b;
        font-size: 11px;
        font-weight: 600;
    }

    .status-draft { background: #f1f5f9; color: #475569; }
    .status-submitted { background: #eff6ff; color: #2563eb; }
    .status-approved { background: #dcfce7; color: #15803d; }
    .status-rejected { background: #fee2e2; color: #b91c1c; }
    .status-default { background: #f1f5f9; color: #334155; }

    @@media (max-width: 1200px) {
        .report-dashboard-layout {
            grid-template-columns: 1fr;
        }

        .report-side {
            position: static;
            top: auto;
        }
    }
</style>

<div class="report-management-page">
    <div class="report-management-container">
        <section class="page-head">
            <div>
                <h2>Quản lý báo cáo</h2>
                <p>Theo dõi, lọc, xuất và xử lý các báo cáo trong hệ thống.</p>
            </div>
            <div class="page-head-actions">
                <button class="btn" id="btnMyReports"><i class="bi bi-card-list"></i>Báo cáo của tôi</button>
                <button class="btn btn-create-report" id="btnCreateReport"><i class="bi bi-plus-lg"></i>Tạo mới</button>
            </div>
        </section>

        <section class="quick-stats">
            <article class="quick-stat-card"><div class="quick-stat-label">Tổng báo cáo</div><div class="quick-stat-value" id="statTotalReports">0</div></article>
            <article class="quick-stat-card"><div class="quick-stat-label">Đã duyệt</div><div class="quick-stat-value" id="statApprovedReports">0</div></article>
            <article class="quick-stat-card"><div class="quick-stat-label">Chờ duyệt</div><div class="quick-stat-value" id="statSubmittedReports">0</div></article>
            <article class="quick-stat-card"><div class="quick-stat-label">Yêu cầu mở</div><div class="quick-stat-value" id="statOpenRequests">0</div></article>
        </section>

        <section class="report-dashboard-layout">
            <div class="report-main">
                <section class="filter-card">
                    <div class="report-overview-filters">
                        <div>
                            <label>Thời gian báo cáo</label>
                            <select id="reportPeriodFilter" class="form-select">
                                <option value="">Tất cả thời gian</option>
                                <option value="today">Hôm nay</option>
                                <option value="this_week">Tuần này</option>
                                <option value="this_month">Tháng này</option>
                                <option value="this_quarter">Quý này</option>
                                <option value="this_year">Năm nay</option>
                            </select>
                        </div>
                        <div>
                            <label>Loại báo cáo</label>
                            <select id="reportType" class="form-select">
                                <option value="">Tất cả loại</option>
                                <option value="personal">Báo cáo cá nhân</option>
                                <option value="project">Báo cáo dự án</option>
                                <option value="department">Báo cáo phòng ban</option>
                                <option value="ai">Báo cáo AI</option>
                                @if (roleKey == "admin")
                                {
                                    <option value="admin">Báo cáo quản trị</option>
                                }
                            </select>
                        </div>
                        <div>
                            <label>Phòng ban</label>
                            <select id="departmentFilter" class="form-select">
                                <option value="">Tất cả phòng ban</option>
                            </select>
                        </div>
                        <div>
                            <label>Tìm nhân viên</label>
                            <input type="text" id="employeeSearch" class="form-control" placeholder="Tên / Mã / Email" />
                        </div>
                    </div>
                    <div class="filter-bottom-row">
                        <div class="status-tabs" id="statusTabs">
                            <button class="status-tab active" data-status="">Tất cả</button>
                            <button class="status-tab" data-status="Draft">Nháp</button>
                            <button class="status-tab" data-status="Submitted">Chờ duyệt</button>
                            <button class="status-tab" data-status="Approved">Đã duyệt</button>
                            <button class="status-tab" data-status="Rejected">Từ chối</button>
                        </div>
                        <div class="report-filter-actions">
                            <button class="btn" id="btnRefresh"><i class="bi bi-arrow-repeat"></i>Làm mới</button>

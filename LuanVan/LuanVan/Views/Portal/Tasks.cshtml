@{
    var role = (ViewData["Role"]?.ToString() ?? "Employee").Trim();
    var isAdmin = string.Equals(role, "Admin", StringComparison.OrdinalIgnoreCase);
    var isManager = string.Equals(role, "Manager", StringComparison.OrdinalIgnoreCase);
    var canManageTask = isAdmin || isManager;
    var canEditTask = canManageTask || string.Equals(role, "Employee", StringComparison.OrdinalIgnoreCase);
}


        async function requestJson(url, options = {}) {
            try {
                const res = await fetch(url, { ...options });

                if (!res.ok) {
                    // try to read text body for better diagnostics
                    let text = null;
                    try { text = await res.text(); } catch (e) { /* ignore */ }
                    console.error('Fetch error', url, res.status, res.statusText, text);
                    return { success: false, status: res.status, message: text || res.statusText || 'HTTP error' };
                }

                const contentType = res.headers.get('content-type') || '';
                if (contentType.includes('application/json')) {
                    const txt = await res.text();
                    if (!txt) {
                        return { success: false, message: 'Empty JSON response', status: res.status };
                    }
                    return JSON.parse(txt);
                }

                // Fallback: return raw text
                const txt = await res.text();
                return { success: true, data: txt };
            } catch (error) {
                console.error('Request error:', error);
                return { success: false, message: error?.message || 'Lỗi kết nối' };
            }
        }

        function getPayload(resp) {
            return resp?.data ?? resp?.Data ?? null;
        }

        function extractArray(resp) {
            if (!resp || resp.success === false) return [];
            const data = getPayload(resp);
            if (!data) return [];
            if (Array.isArray(data)) return data;
            if (Array.isArray(data.items)) return data.items;
            if (Array.isArray(data.Items)) return data.Items;
            return [];
        }

        function clampPercent(value) {
            const num = Number(value);
            if (!Number.isFinite(num)) return 0;
            return Math.max(0, Math.min(100, num));
        }

        function isTaskCompleted(task) {
            return Number(task?.maTrangThai || 0) === 3;
        }

        function isTaskOverdue(task) {
            if (!task?.hanHoanThanh) return false;
            const deadline = new Date(task.hanHoanThanh);
            if (Number.isNaN(deadline.getTime())) return false;
            if (isTaskCompleted(task)) return false;
            const now = new Date();
            const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
            return deadline < today;
        }

        function isCompletedOnTime(task) {
            if (!isTaskCompleted(task)) return false;
            if (!task?.hanHoanThanh) return false;
            const deadline = new Date(task.hanHoanThanh);
            if (Number.isNaN(deadline.getTime())) return false;
            const progressUpdates = Array.isArray(task?.lichSuTienDo) ? task.lichSuTienDo : [];
            const completionUpdate = progressUpdates
                .filter(x => Number(x?.phanTramHoanThanh || 0) >= 100)
                .sort((a, b) => new Date(b?.ngayCapNhat || 0) - new Date(a?.ngayCapNhat || 0))[0];
            const completeAt = completionUpdate?.ngayCapNhat ? new Date(completionUpdate.ngayCapNhat) : null;
            if (!completeAt || Number.isNaN(completeAt.getTime())) {
                return deadline >= new Date();
            }
            return completeAt <= deadline;
        }

        function updateMiniKpiHeader(taskList) {
            const tasks = Array.isArray(taskList) ? taskList : [];
            const now = new Date();
            const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());

            const todayCount = tasks.filter(t => {
                if (!t?.hanHoanThanh) return false;
                const d = new Date(t.hanHoanThanh);
                return !Number.isNaN(d.getTime()) && d.toDateString() === today.toDateString();
            }).length;

            const overdueCount = tasks.filter(isTaskOverdue).length;
            const completed = tasks.filter(isTaskCompleted).length;
            const onTimeCompleted = tasks.filter(isCompletedOnTime).length;
            const onTimePercent = completed > 0 ? Math.round((onTimeCompleted / completed) * 100) : 0;
            const displayKpi = clampPercent(state.personalKpiScore ?? onTimePercent);

            if (el.todayTaskCount) el.todayTaskCount.textContent = String(todayCount);
            if (el.overdueCount) el.overdueCount.textContent = String(overdueCount);
            if (el.onTimePercent) el.onTimePercent.textContent = `${onTimePercent}%`;
            if (el.currentKpi) {
                el.currentKpi.textContent = `${Math.round(displayKpi)}`;
                el.currentKpi.title = state.personalKpiSource === 'dashboard'
                    ? 'KPI từ Dashboard'
                    : 'KPI tạm tính từ dữ liệu công việc';
            }
        }

        function renderPersonalKpiFromTasks(taskList) {
            const tasks = Array.isArray(taskList) ? taskList : [];
            const total = tasks.length;
            const completed = tasks.filter(isTaskCompleted).length;
            const completedOnTime = tasks.filter(isCompletedOnTime).length;
            const overdueCount = tasks.filter(isTaskOverdue).length;

            const goalRate = total > 0 ? Math.round((completed / total) * 100) : 0;
            const onTimeRate = completed > 0 ? Math.round((completedOnTime / completed) * 100) : 0;

            const now = new Date();
            const sevenDaysAgo = new Date(now.getFullYear(), now.getMonth(), now.getDate() - 7);
            const monthStart = new Date(now.getFullYear(), now.getMonth(), 1);
            const weekTasks = tasks.filter(t => {
                if (!t?.hanHoanThanh) return false;
                const d = new Date(t.hanHoanThanh);
                return !Number.isNaN(d.getTime()) && d >= sevenDaysAgo && d <= now;
            });
            const monthTasks = tasks.filter(t => {
                if (!t?.hanHoanThanh) return false;
                const d = new Date(t.hanHoanThanh);
                return !Number.isNaN(d.getTime()) && d >= monthStart && d <= now;
            });

            const weekCompleted = weekTasks.filter(isTaskCompleted).length;
            const monthCompleted = monthTasks.filter(isTaskCompleted).length;
            const weekRate = weekTasks.length > 0 ? (weekCompleted / weekTasks.length) * 100 : null;
            const monthRate = monthTasks.length > 0 ? (monthCompleted / monthTasks.length) * 100 : null;

            let weeklyTrend = 0;
            let trendTitle = 'Hiệu suất tạm tính từ công việc';
            if (weekRate != null && monthRate != null) {
                weeklyTrend = clampPercent(Math.round((weekRate * 0.6) + (monthRate * 0.4)));
                trendTitle = `Tuần gần nhất: ${Math.round(weekRate)}%, tháng hiện tại: ${Math.round(monthRate)}%`;
            } else if (weekRate != null) {
                weeklyTrend = clampPercent(Math.round(weekRate));
                trendTitle = `Tuần gần nhất: ${Math.round(weekRate)}%`;
            } else if (monthRate != null) {
                weeklyTrend = clampPercent(Math.round(monthRate));
                trendTitle = `Tháng hiện tại: ${Math.round(monthRate)}%`;
            }

            if (el.kpiGoalRate) el.kpiGoalRate.textContent = `${goalRate}%`;
            if (el.kpiWeeklyTrend) el.kpiWeeklyTrend.textContent = `${weeklyTrend}%`;

            if (el.kpiGoalRateBar) el.kpiGoalRateBar.style.width = `${goalRate}%`;
            if (el.kpiWeeklyTrendBar) {
                el.kpiWeeklyTrendBar.style.width = `${weeklyTrend}%`;
                el.kpiWeeklyTrendBar.title = trendTitle;
            }

            if (el.activityFeedGlobal) {
                const overdueText = overdueCount > 0 ? `${overdueCount} công việc đang trễ hạn` : 'Không có công việc trễ hạn';
                el.activityFeedGlobal.innerHTML = `
                    <div style="font-size:12px; color: var(--text-muted);">
                        <strong>Ghi chú KPI:</strong> Dữ liệu hiệu suất được tính từ danh sách công việc hiện tại. ${overdueText}.
                    </div>
                `;
            }
        }

        function setPersonalKpiScore(score, source) {
            const value = clampPercent(score);
            state.personalKpiScore = value;
            state.personalKpiSource = source || 'task_based';
            if (el.kpiPersonalScore) el.kpiPersonalScore.textContent = `${Math.round(value)}`;
            if (el.kpiPersonalScoreBar) el.kpiPersonalScoreBar.style.width = `${value}%`;
            if (el.kpiPersonalScore) {
                el.kpiPersonalScore.title = state.personalKpiSource === 'dashboard'
                    ? 'KPI chuẩn từ Dashboard'
                    : 'KPI tạm tính từ dữ liệu công việc';
            }
        }

        async function loadPersonalKpi() {
            const now = new Date();
            const thang = now.getMonth() + 1;
            const nam = now.getFullYear();

            const resp = await requestJson(`/dashboard?thang=${thang}&nam=${nam}`);
            if (!resp || resp.success === false) {
                return { success: false, status: resp?.status || 0, message: resp?.message || 'Không thể tải KPI từ dashboard' };
            }

            const payload = getPayload(resp);
            const kpiRaw = payload?.nhanVienContext?.kpiCaNhan ?? payload?.NhanVienContext?.KpiCaNhan;
            const kpiValue = clampPercent(kpiRaw);
            setPersonalKpiScore(kpiValue, 'dashboard');
            return { success: true, kpi: kpiValue };
        }


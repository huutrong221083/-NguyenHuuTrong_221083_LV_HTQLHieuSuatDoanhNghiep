    .btn:disabled,
    .btn.disabled,
    .btn[aria-disabled="true"] {
        opacity: 0.62;
        filter: grayscale(0.14);
        cursor: not-allowed;
        transform: none !important;
        box-shadow: none !important;
    }

    .btn[aria-busy="true"],
    .btn.is-loading {
        position: relative;
        pointer-events: none;
        color: transparent !important;
    }

    .btn[aria-busy="true"]::after,
    .btn.is-loading::after {
        content: "";
        width: 0.95rem;
        height: 0.95rem;
        border-radius: 999px;
        border: 2px solid currentColor;
        border-right-color: transparent;
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        animation: taskBtnSpin 0.75s linear infinite;
        color: #ffffff;
    }

    .btn-secondary[aria-busy="true"]::after,
    .btn-secondary.is-loading::after,
    .btn-light[aria-busy="true"]::after,
    .btn-light.is-loading::after,
    .btn-outline-primary[aria-busy="true"]::after,
    .btn-outline-primary.is-loading::after {
        color: var(--text-dark);
    }

    @@keyframes taskBtnSpin {

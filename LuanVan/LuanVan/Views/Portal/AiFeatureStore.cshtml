@{
    ViewData["Title"] = "Dữ liệu huấn luyện AI";
}

<style>
    .train-shell { color: #12304f; }
    .train-hero { background: #fff; border: 1px solid #d8e2ef; border-radius: 14px; padding: 16px; }
    .train-hero h2 { margin: 0; font-size: 28px; font-weight: 700; }
    .train-hero p { margin: 8px 0 0; color: #54657a; }
    .train-note { margin-top: 8px; font-size: 13px; color: #6b7280; }
    .train-toolbar { margin-top: 12px; background: #fff; border: 1px solid #d8e2ef; border-radius: 14px; padding: 12px; }
    .train-grid { display: grid; grid-template-columns: repeat(6,minmax(0,1fr)); gap: 10px; align-items: end; }
    .train-meta { margin-top: 12px; background: #fff; border: 1px solid #d8e2ef; border-radius: 14px; padding: 12px; }
    .train-meta ul { margin: 0; padding-left: 18px; }
    .train-meta-compact { display: grid; grid-template-columns: 1.2fr 1fr 1.4fr; gap: 10px; }
    .train-meta-card { border: 1px solid #e6edf7; border-radius: 10px; padding: 8px 10px; background: #fbfdff; }
    .train-meta-title { font-size: 12px; color: #64748b; text-transform: uppercase; margin-bottom: 6px; font-weight: 700; letter-spacing: .02em; }
    .train-meta-main { font-size: 14px; color: #10233b; line-height: 1.4; }
    .train-chip-wrap { display: flex; flex-wrap: wrap; gap: 6px; }
    .train-chip { display: inline-block; padding: 3px 8px; border-radius: 999px; background: #edf4ff; color: #1e40af; font-size: 12px; }
    .train-table-wrap { margin-top: 12px; background: #fff; border: 1px solid #d8e2ef; border-radius: 14px; overflow: hidden; }
    .train-empty { padding: 28px; text-align: center; color: #6b7280; }
    .train-warning { margin-top: 10px; border-radius: 10px; padding: 8px 10px; border: 1px solid #fde68a; background: #fffaf0; color: #8a5600; display: none; }
    .train-warning.show { display: block; }
    @@media (max-width: 1200px) {
        .train-grid { grid-template-columns: repeat(3,minmax(0,1fr)); }
        .train-meta-compact { grid-template-columns: 1fr; }
    }
    @@media (max-width: 768px) { .train-grid { grid-template-columns: 1fr; } }
</style>

<section class="train-shell mt-2">
    <div class="train-hero">
        <h2>Dữ liệu huấn luyện AI</h2>
    </div>

    <div class="train-toolbar">
        <ul class="nav nav-pills mb-3" id="trainingTabs">
            <li class="nav-item"><button class="nav-link active" data-model="task-delay" type="button">Dự báo trễ hạn</button></li>
            <li class="nav-item"><button class="nav-link" data-model="performance" type="button">Hiệu suất nhân sự</button></li>
        </ul>
        <div class="train-grid">
            <div>
                <label class="form-label small mb-1">Từ ngày</label>
                <input id="fromDate" type="date" class="form-control form-control-sm" />
            </div>
            <div>
                <label class="form-label small mb-1">Đến ngày</label>
                <input id="toDate" type="date" class="form-control form-control-sm" />
            </div>
            <div>
                <label class="form-label small mb-1">Nhân viên</label>
                <input id="employeeId" type="number" min="1" class="form-control form-control-sm" placeholder="Mã nhân viên" />
            </div>
            <div>
                <label class="form-label small mb-1">Dự án</label>
                <input id="projectId" type="number" min="1" class="form-control form-control-sm" placeholder="Mã dự án" />
            </div>
            <div>
                <label class="form-label small mb-1">Từ khóa</label>
                <input id="keyword" type="text" class="form-control form-control-sm" placeholder="Tên nhân viên/công việc" />
            </div>
            <div class="d-flex gap-2">
                <button id="btnApply" class="btn btn-primary btn-sm">Lọc</button>
                <button id="btnReset" class="btn btn-outline-secondary btn-sm">Xóa lọc</button>
                <button id="btnExport" class="btn btn-outline-primary btn-sm">Xuất CSV</button>
            </div>
        </div>
        <div class="d-flex justify-content-between mt-2">
            <div id="statusText" class="small text-muted">Đang chờ tải dữ liệu...</div>
            <div class="d-flex align-items-center gap-2">
                <button id="btnPrev" class="btn btn-outline-secondary btn-sm">Trước</button>
                <span id="pageText" class="small text-muted">Trang 1</span>
                <button id="btnNext" class="btn btn-outline-secondary btn-sm">Sau</button>
            </div>
        </div>
        <div id="warningBox" class="train-warning"></div>
    </div>

    <div class="train-meta" id="metaBox"></div>

    <div class="train-table-wrap">
        <div class="table-responsive" style="max-height:65vh;">
            <table class="table table-sm table-hover align-middle mb-0">
                <thead id="tableHead"></thead>
                <tbody id="tableBody">
                    <tr><td class="train-empty">Chưa có dữ liệu.</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

@section Scripts {
<script>
(() => {
    const state = {
        model: 'task-delay',
        page: 1,
        pageSize: 50,
        lastRows: [],
        lastColumns: [],
        totalRows: 0
    };

    const els = {
        tabs: document.querySelectorAll('#trainingTabs .nav-link'),
        fromDate: document.getElementById('fromDate'),
        toDate: document.getElementById('toDate'),
        employeeId: document.getElementById('employeeId'),
        projectId: document.getElementById('projectId'),
        keyword: document.getElementById('keyword'),
        btnApply: document.getElementById('btnApply'),
        btnReset: document.getElementById('btnReset'),
        btnExport: document.getElementById('btnExport'),
        btnPrev: document.getElementById('btnPrev'),
        btnNext: document.getElementById('btnNext'),
        statusText: document.getElementById('statusText'),
        pageText: document.getElementById('pageText'),
        warningBox: document.getElementById('warningBox'),
        metaBox: document.getElementById('metaBox'),
        tableHead: document.getElementById('tableHead'),
        tableBody: document.getElementById('tableBody')
    };

    function esc(v){ return String(v ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'",'&#39;'); }

    const columnLabels = {
        assignmentId: { label: 'Mã phân công', hint: 'Định danh bản ghi phân công nhân viên - công việc' },
        employeeId: { label: 'Mã nhân viên', hint: 'Mã nhân viên trong hệ thống' },
        employeeName: { label: 'Nhân viên', hint: 'Họ tên nhân viên' },
        taskId: { label: 'Mã công việc', hint: 'Mã công việc liên quan' },
        taskName: { label: 'Công việc', hint: 'Tên công việc' },
        projectId: { label: 'Mã dự án', hint: 'Mã dự án liên quan' },
        projectName: { label: 'Dự án', hint: 'Tên dự án liên quan' },
        plannedStartDate: { label: 'Bắt đầu dự kiến', hint: 'Ngày bắt đầu dự kiến theo phân công' },
        plannedEndDate: { label: 'Kết thúc dự kiến', hint: 'Ngày kết thúc dự kiến theo phân công' },
        actualStartDate: { label: 'Bắt đầu thực tế', hint: 'Ngày bắt đầu thực tế' },
        actualEndDate: { label: 'Kết thúc thực tế', hint: 'Ngày kết thúc thực tế' },
        deadline: { label: 'Hạn hoàn thành', hint: 'Hạn chót hoàn thành công việc' },
        estimatedHours: { label: 'Giờ ước tính', hint: 'Tính từ ngày bắt đầu đến hạn hoàn thành' },
        spentHours: { label: 'Giờ đã dùng', hint: 'Thời gian thực tế đã tiêu tốn' },
        progressPercent: { label: 'Tiến độ (%)', hint: 'Phần trăm hoàn thành mới nhất' },
        priorityWeight: { label: 'Trọng số ưu tiên', hint: 'Độ ưu tiên dùng làm đặc trưng đầu vào' },
        difficultyWeight: { label: 'Trọng số độ khó', hint: 'Độ khó dùng làm đặc trưng đầu vào' },
        daysUntilDeadline: { label: 'Số ngày còn hạn', hint: 'Giá trị âm nghĩa là đã quá hạn' },
        lateDays: { label: 'Số ngày trễ', hint: 'Biến mục tiêu của mô hình dự báo trễ hạn' },
        lateLabel: { label: 'Nhãn trễ hạn', hint: 'LATE / ON_TIME' },
        month: { label: 'Tháng', hint: 'Kỳ đánh giá theo tháng' },
        year: { label: 'Năm', hint: 'Kỳ đánh giá theo năm' },
        taskCount: { label: 'Tổng công việc', hint: 'Số công việc dùng để tính tỷ lệ' },
        completedTaskCount: { label: 'CV hoàn thành', hint: 'Số công việc đã hoàn thành' },
        lateTaskCount: { label: 'CV trễ hạn', hint: 'Số công việc trễ hạn' },
        completionRate: { label: 'Tỷ lệ hoàn thành', hint: 'completed/taskCount' },
        lateRate: { label: 'Tỷ lệ trễ hạn', hint: 'late/taskCount' },
        avgWorkHours: { label: 'TG TB (giờ)', hint: 'Thời gian xử lý trung bình' },
        kpiAverage: { label: 'KPI trung bình', hint: 'Điểm KPI trung bình đầu vào' },
        totalKpiScore: { label: 'Điểm KPI tổng', hint: 'Ưu tiên từ KETQUAKPI_TONG nếu có' },
        projectCount: { label: 'Số dự án tham gia', hint: 'Số dự án khác nhau của nhân viên' },
        avgProgress: { label: 'Tiến độ TB (%)', hint: 'Biến đầu vào cho mô hình hiệu suất' },
        label: { label: 'Nhãn hiệu suất', hint: 'Biến mục tiêu của mô hình Random Forest' },
        labelSource: { label: 'Nguồn nhãn', hint: 'KETQUAKPI_TONG hoặc RULE_FALLBACK' }
    };

    function getColumnMeta(columnKey) {
        return columnLabels[columnKey] || { label: columnKey, hint: `Tên kỹ thuật: ${columnKey}` };
    }

    function buildQuery() {
        const p = new URLSearchParams();
        p.set('model', state.model);
        p.set('page', String(state.page));
        p.set('pageSize', String(state.pageSize));
        if (els.fromDate.value) p.set('fromDate', els.fromDate.value);
        if (els.toDate.value) p.set('toDate', els.toDate.value);
        if (els.employeeId.value) p.set('employeeId', els.employeeId.value);
        if (els.projectId.value) p.set('projectId', els.projectId.value);
        if (els.keyword.value.trim()) p.set('keyword', els.keyword.value.trim());
        return p.toString();
    }

    function mapDataset(payload) {
        return state.model === 'task-delay' ? payload?.taskDelay : payload?.performance;
    }

    function renderMeta(ds) {
        if (!ds) {
            els.metaBox.innerHTML = '<div class="train-empty">Không có metadata.</div>';
            return;
        }

        const sourceTables = (ds.sourceTables || []).map(x => `<span class="train-chip" title="Bảng nguồn dữ liệu">${esc(x)}</span>`).join('');
        const features = (ds.features || []).map(x => `<span class="train-chip" title="Đặc trưng đầu vào">${esc(x)}</span>`).join('');
        const modelVn = state.model === 'task-delay' ? 'Dự báo trễ hạn công việc' : 'Phân loại hiệu suất nhân sự';
        const algorithmVn = String(ds.algorithm || '').toLowerCase().includes('linear')
            ? 'Hồi quy tuyến tính (Linear Regression)'
            : 'Rừng ngẫu nhiên (Random Forest)';
        const targetVn = state.model === 'task-delay'
            ? 'Số ngày trễ (late_days)'
            : 'Nhãn hiệu suất (performance_label)';

        els.metaBox.innerHTML = `
            <div class="train-meta-compact">
                <div class="train-meta-card">
                    <div class="train-meta-title">Mô hình</div>
                    <div class="train-meta-main">
                        <strong>${esc(modelVn)}</strong><br/>
                        Thuật toán: ${esc(algorithmVn)}<br/>
                        Biến mục tiêu: ${esc(targetVn)}
                    </div>
                </div>
                <div class="train-meta-card">
                    <div class="train-meta-title">Nguồn dữ liệu</div>
                    <div class="train-chip-wrap">${sourceTables || '<span class="text-muted">—</span>'}</div>
                </div>
                <div class="train-meta-card">
                    <div class="train-meta-title">Đặc trưng đầu vào AI</div>
                    <div class="train-chip-wrap">${features || '<span class="text-muted">—</span>'}</div>
                </div>
            </div>`;

        const dq = ds.dataQuality;
        if (dq && dq.isLowData) {
            els.warningBox.textContent = dq.warningMessage || 'Dữ liệu huấn luyện hiện còn ít.';
            els.warningBox.classList.add('show');
        } else {
            els.warningBox.classList.remove('show');
            els.warningBox.textContent = '';
        }
    }

    function renderTable(rows) {
        if (!Array.isArray(rows) || rows.length === 0) {
            els.tableHead.innerHTML = '';
            els.tableBody.innerHTML = '<tr><td class="train-empty">Chưa có dữ liệu huấn luyện phù hợp với bộ lọc hiện tại. Hãy đổi khoảng thời gian hoặc kiểm tra dữ liệu công việc/KPI.</td></tr>';
            state.lastRows = [];
            state.lastColumns = [];
            return;
        }

        const cols = Object.keys(rows[0].values || {});
        state.lastRows = rows;
        state.lastColumns = cols;

        els.tableHead.innerHTML = `<tr>${cols.map(c => {
            const meta = getColumnMeta(c);
            return `<th title="${esc(meta.hint)}">${esc(meta.label)}</th>`;
        }).join('')}</tr>`;
        els.tableBody.innerHTML = rows.map(r => {
            const vals = r.values || {};
            return `<tr>${cols.map(c => `<td>${esc(vals[c] ?? '—')}</td>`).join('')}</tr>`;
        }).join('');
    }

    async function loadData() {
        els.statusText.textContent = 'Đang tải dữ liệu huấn luyện AI...';
        try {
            const resp = await fetch(`/ai/training-data?${buildQuery()}`, { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' });
            const raw = await resp.text();
            let payload = null;
            try {
                payload = raw ? JSON.parse(raw) : null;
            } catch {
                payload = null;
            }

            if (!resp.ok || !payload?.success) {
                const fallbackMessage = raw && raw.length < 500 ? raw : `Lỗi tải dữ liệu (${resp.status})`;
                throw new Error(payload?.message || fallbackMessage);
            }

            const ds = mapDataset(payload.data);
            if (!ds) {
                renderMeta(null);
                renderTable([]);
                state.totalRows = 0;
                els.statusText.textContent = 'Không có dataset theo model đã chọn.';
                els.pageText.textContent = `Trang ${state.page}`;
                return;
            }

            state.totalRows = ds.totalRows || 0;
            renderMeta(ds);
            renderTable(ds.rows || []);
            els.statusText.textContent = `Đang hiển thị ${(ds.rows || []).length} / ${state.totalRows} dòng dữ liệu.`;
            const totalPages = Math.max(1, Math.ceil(state.totalRows / state.pageSize));
            els.pageText.textContent = `Trang ${state.page}/${totalPages}`;
            els.btnPrev.disabled = state.page <= 1;
            els.btnNext.disabled = state.page >= totalPages;
        } catch (e) {
            console.error(e);
            renderMeta(null);
            renderTable([]);
            els.statusText.textContent = e?.message || 'Không tải được dữ liệu.';
        }
    }

    function resetFilters() {
        els.fromDate.value = '';
        els.toDate.value = '';
        els.employeeId.value = '';
        els.projectId.value = '';
        els.keyword.value = '';
        state.page = 1;
        loadData();
    }

    function exportCsv() {
        if (!state.lastRows.length || !state.lastColumns.length) {
            els.statusText.textContent = 'Không có dữ liệu để xuất CSV.';
            return;
        }

        const header = state.lastColumns.join(';');
        const lines = state.lastRows.map(r => {
            const values = r.values || {};
            return state.lastColumns.map(c => {
                const v = String(values[c] ?? '');
                return `"${v.replaceAll('"', '""').replaceAll('\n', ' ')}"`;
            }).join(';');
        });

        const csv = ['\ufeff' + header, ...lines].join('\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `ai-training-${state.model}-${new Date().toISOString().slice(0,10)}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        els.statusText.textContent = `Đã xuất ${state.lastRows.length} dòng CSV.`;
    }

    els.tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            els.tabs.forEach(x => x.classList.remove('active'));
            tab.classList.add('active');
            state.model = tab.getAttribute('data-model') || 'task-delay';
            state.page = 1;
            loadData();
        });
    });

    els.btnApply.addEventListener('click', () => { state.page = 1; loadData(); });
    els.btnReset.addEventListener('click', resetFilters);
    els.btnExport.addEventListener('click', exportCsv);
    els.btnPrev.addEventListener('click', () => { if (state.page > 1) { state.page -= 1; loadData(); } });
    els.btnNext.addEventListener('click', () => { state.page += 1; loadData(); });

    loadData();
})();
</script>
}

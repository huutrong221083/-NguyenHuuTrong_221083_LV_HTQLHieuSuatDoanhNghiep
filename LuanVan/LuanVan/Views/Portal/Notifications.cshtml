@{
    var roleKey = (ViewData["RoleKey"]?.ToString() ?? "admin").Trim().ToLowerInvariant();
}

<section class="page-head">
    <div>
        <h2>Trung tâm thông báo</h2>
    </div>
    <div class="badge role-badge">Role: @roleKey.ToUpperInvariant()</div>
</section>

<nav class="crumb">Trang chủ / Thông báo</nav>

<section class="panel mt-3 notification-page-toolbar">
    <div class="notification-page-filters">
        <button class="notification-filter-chip active" type="button" data-tab="all">Tất cả</button>
        <button class="notification-filter-chip" type="button" data-tab="unread">Chưa đọc</button>

        <select class="form-select form-select-sm" id="notifyTypeFilter" style="max-width: 220px;">
            <option value="">Tất cả loai</option>
            <option value="task">Task</option>
            <option value="kpi">KPI</option>
            <option value="alert">Canh bao</option>
            <option value="ai">AI</option>
            <option value="system">He thông</option>
        </select>

        <button class="btn btn-outline-secondary btn-sm" type="button" id="btnPageMarkAllRead">
            <i class="bi bi-check2-all"></i> Đánh dấu tất cả đã đọc
        </button>
    </div>
</section>

<section class="panel mt-3">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0 notification-full-table">
            <thead>
                <tr>
                    <th>Noi dung</th>
                    <th>Loai</th>
                    <th>Thoi gian</th>
                    <th>Trạng thái</th>
                    <th class="text-end">Tac vu</th>
                </tr>
            </thead>
            <tbody id="notificationPageBody">
                <tr><td colspan="5" class="text-muted">Đang tải thông báo...</td></tr>
            </tbody>
        </table>
    </div>

    <div class="notification-page-footer mt-3">
        <div id="notificationPageMeta" class="text-muted small">-</div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" type="button" id="btnNotificationPrev">Truoc</button>
            <button class="btn btn-outline-secondary btn-sm" type="button" id="btnNotificationNext">Sau</button>
        </div>
    </div>
</section>

@section Scripts {
<script>
(() => {
    const role = '@roleKey';

    const state = {
        tab: 'all',
        type: '',
        page: 1,
        size: 12,
        totalPages: 1,
        totalItems: 0,
        items: [],
        loading: false
    };

    const body = document.getElementById('notificationPageBody');
    const pageMeta = document.getElementById('notificationPageMeta');
    const btnPrev = document.getElementById('btnNotificationPrev');
    const btnNext = document.getElementById('btnNotificationNext');
    const typeFilter = document.getElementById('notifyTypeFilter');
    const tabButtons = [...document.querySelectorAll('.notification-filter-chip[data-tab]')];

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function formatTime(iso) {
        if (!iso) return '--';
        const d = new Date(iso);
        if (Number.isNaN(d.getTime())) return '--';
        return d.toLocaleString('vi-VN', {
            hour: '2-digit',
            minute: '2-digit',
            day: '2-digit',
            month: '2-digit',
            year: 'numeric'
        });
    }

    function typePill(item) {
        return `<span class="notify-type-pill ${escapeHtml(item.mau || '')}"><i class="${escapeHtml(item.icon || 'bi bi-gear')}"></i> ${escapeHtml(item.loaiHienThi || 'He thông')}</span>`;
    }

    async function fetchJson(url, options) {
        const response = await fetch(url, options);
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }
        const payload = await response.json();
        if (!payload.success) {
            throw new Error(payload.message || 'Không thể tai dữ liệu');
        }
        return payload.data;
    }

    function notify(message, type = 'info') {
        if (window.UiToast && typeof window.UiToast.show === 'function') {
            window.UiToast.show({ message, type });
            return;
        }

        window.alert(type === 'error' ? `Lỗi: ${message}` : message);
    }

    async function loadData() {
        if (state.loading) return;
        state.loading = true;

        body.innerHTML = '<tr><td colspan="5" class="text-muted">Đang tải thông báo...</td></tr>';

        try {
            const params = new URLSearchParams({
                role,
                tab: state.tab,
                page: String(state.page),
                size: String(state.size)
            });

            const data = await fetchJson(`/thongbao?${params.toString()}`);
            let items = data.page?.items || [];
            if (state.type) {
                items = items.filter(x => String(x.loai || '').toLowerCase() === state.type);
            }

            state.items = items;
            state.totalItems = Number(data.page?.totalItems || 0);
            state.totalPages = Number(data.page?.totalPages || 1);
            render();
        } catch (error) {
            body.innerHTML = `<tr><td colspan="5" class="text-danger">Không tai được thông báo: ${escapeHtml(error.message || error)}</td></tr>`;
        } finally {
            state.loading = false;
        }
    }

    function render() {
        if (!state.items.length) {
            body.innerHTML = '<tr><td colspan="5" class="text-muted">Không có thông báo phu hop bộ lọc.</td></tr>';
        } else {
            body.innerHTML = state.items.map(item => {
                const unread = !!item.isUnread;
                return `
                    <tr class="${unread ? 'notify-row-unread' : ''}">
                        <td>
                            <div class="notify-row-content">
                                <div class="notify-row-title">${escapeHtml(item.noiDung)}</div>
                                <a href="${escapeHtml(item.detailUrl || '#')}" class="notify-row-link">Mo trang lien quan</a>
                            </div>
                        </td>
                        <td>${typePill(item)}</td>
                        <td>${formatTime(item.thoiGian)}</td>
                        <td>${unread ? '<span class="pill warning">Chưa đọc</span>' : '<span class="pill info">Đã đọc</span>'}</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-light" data-action="mark" data-id="${item.maThongBao}" ${unread ? '' : 'disabled'}>
                                <i class="bi bi-check2"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" data-action="delete" data-id="${item.maThongBao}">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        pageMeta.textContent = `Trang ${state.page}/${state.totalPages} - ${state.totalItems} thông báo`;
        btnPrev.disabled = state.page <= 1;
        btnNext.disabled = state.page >= state.totalPages;
    }

    async function markRead(maThongBao) {
        await fetchJson(`/thongbao/${maThongBao}/mark-read`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ role })
        });
    }

    async function deleteNotification(maThongBao) {
        await fetchJson(`/thongbao/${maThongBao}?role=${encodeURIComponent(role)}`, {
            method: 'DELETE'
        });
    }

    body.addEventListener('click', async (event) => {
        const button = event.target.closest('button[data-action][data-id]');
        if (!button) return;

        const id = Number(button.dataset.id || '0');
        if (!id) return;

        try {
            if (button.dataset.action === 'mark') {
                await markRead(id);
            }
            if (button.dataset.action === 'delete') {
                await deleteNotification(id);
            }
            await loadData();
        } catch (error) {
            notify(`Tac vu không thành công: ${error.message || error}`, 'error');
        }
    });

    tabButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            tabButtons.forEach(x => x.classList.remove('active'));
            btn.classList.add('active');
            state.tab = btn.dataset.tab || 'all';
            state.page = 1;
            loadData();
        });
    });

    typeFilter.addEventListener('change', () => {
        state.type = String(typeFilter.value || '').toLowerCase();
        state.page = 1;
        loadData();
    });

    btnPrev.addEventListener('click', () => {
        if (state.page <= 1) return;
        state.page -= 1;
        loadData();
    });

    btnNext.addEventListener('click', () => {
        if (state.page >= state.totalPages) return;
        state.page += 1;
        loadData();
    });

    document.getElementById('btnPageMarkAllRead')?.addEventListener('click', async () => {
        try {
            await fetchJson('/thongbao/mark-all-read', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ role })
            });
            state.page = 1;
            await loadData();
        } catch (error) {
            notify(`Không thể danh dau đã đọc: ${error.message || error}`, 'error');
        }
    });

    loadData();
})();
</script>
}






